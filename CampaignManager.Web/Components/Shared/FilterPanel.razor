@namespace CampaignManager.Web.Components.Shared

<div class="sticky top-0 z-10 cm-card mb-4">
    <div class="cm-card-header">
        <div class="flex items-center gap-2">
            <span class="cm-section-title">@Title</span>
            <button @onclick="TogglePanel" class="text-gray-500 hover:text-gray-700 transition-colors text-sm">
                <i class="fas @(IsExpanded ? "fa-chevron-up" : "fa-chevron-down")"></i>
            </button>
        </div>
        <div class="flex gap-2">
            @ActionButtons
        </div>
    </div>

    @if (IsExpanded)
    {
        <div class="cm-card-body">
            @ChildContent
        </div>
    }
</div>

@code {
    [Parameter] public string Title { get; set; } = "Фильтры";
    [Parameter] public bool IsExpanded { get; set; } = true;
    [Parameter] public EventCallback<bool> IsExpandedChanged { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? ActionButtons { get; set; }

    private async Task TogglePanel()
    {
        IsExpanded = !IsExpanded;
        await IsExpandedChanged.InvokeAsync(IsExpanded);
    }
}

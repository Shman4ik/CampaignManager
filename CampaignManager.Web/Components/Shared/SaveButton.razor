<button @onclick="OnClick"
        disabled="@IsLoading"
        type="button"
        class="cm-btn cm-btn-success mr-2">
    @if (IsLoading)
    {
        <i class="fas fa-spinner fa-spin"></i>
    }
    <span>@(IsLoading ? "Сохранение..." : ChildContent)</span>
</button>

@code {
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public EventCallback OnClick { get; set; }
    [Parameter] public RenderFragment ChildContent { get; set; } = builder => builder.AddContent(0, "Сохранить");
}

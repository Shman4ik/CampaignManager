@using CampaignManager.Web.Components.Features.Characters.Model

@if (Value > 0)
{
    <span class="skill-level-badge @BadgeClass" title="@LevelLabel">@ShortLabel</span>
}

@code {
    [Parameter] public int Value { get; set; }

    private string ShortLabel => Value switch
    {
        >= 90 => "Мс",
        >= 75 => "Эк",
        >= 50 => "Пр",
        >= 20 => "Лб",
        >= 6  => "Нч",
        _     => "Нв"
    };

    private string LevelLabel => Value switch
    {
        >= 90 => "Мастер",
        >= 75 => "Эксперт",
        >= 50 => "Профессионал",
        >= 20 => "Любитель",
        >= 6  => "Начинающий",
        _     => "Новичок"
    };

    private string BadgeClass => Value switch
    {
        >= 90 => "badge-master",
        >= 75 => "badge-expert",
        >= 50 => "badge-professional",
        >= 20 => "badge-amateur",
        >= 6  => "badge-beginner",
        _     => "badge-novice"
    };
}

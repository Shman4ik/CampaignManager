@rendermode InteractiveServer
@using CampaignManager.Web.Components.Features.Chase.Model
@using CampaignManager.Web.Components.Features.Chase.Services
@using CampaignManager.Web.Components.Features.Combat.Services

@inject ChaseService ChaseService

<div class="bg-white rounded-md shadow-sm border border-gray-200 p-4 space-y-4">
    <div>
        <h3 class="text-base font-semibold text-gray-800 mb-1">Проверка скорости</h3>
        <p class="text-xs text-gray-500">
            Каждый участник бросает ВЫН (пешком) или Вождение (транспорт).
            Чрезвычайный успех: СКО +1. Провал: СКО −1.
        </p>
    </div>

    <!-- Таблица участников -->
    <div class="space-y-3">
        @foreach (var participant in ChaseService.Participants)
        {
            var skillName = participant.IsInVehicle ? "Вождение" : "ВЫН";
            var skillValue = participant.IsInVehicle
                ? (participant.DrivingSkill > 0 ? participant.DrivingSkill : 20)
                : participant.ConstitutionValue;
            var baseMov = participant.IsInVehicle ? participant.VehicleSpeed : participant.MovementRate;

            <div @key="participant.Id" class="border border-gray-200 rounded-md p-3 @(participant.SpeedCheckCompleted ? "bg-green-50 border-green-200" : "bg-white")">
                <div class="flex items-center justify-between gap-4">
                    <!-- Имя и роль -->
                    <div class="min-w-0">
                        <div class="flex items-center gap-2">
                            <span class="font-medium text-gray-900 text-sm truncate">@participant.Name</span>
                            @if (participant.Role == ChaseRole.Prey)
                            {
                                <span class="bg-green-100 text-green-700 text-xs px-1.5 py-0.5 rounded shrink-0">Жертва</span>
                            }
                            else
                            {
                                <span class="bg-red-100 text-red-700 text-xs px-1.5 py-0.5 rounded shrink-0">Преследователь</span>
                            }
                        </div>
                        <div class="text-xs text-gray-500 mt-0.5">
                            @skillName: @skillValue &middot; Базовый СКО: @baseMov
                        </div>
                    </div>

                    @if (!participant.SpeedCheckCompleted)
                    {
                        <!-- Ввод броска -->
                        <div class="flex items-center gap-2 shrink-0">
                            <div class="text-xs text-gray-600">
                                Бросок d100<br/>
                                <span class="text-gray-400">(против @skillValue)</span>
                            </div>
                            <input type="number" min="1" max="100"
                                   @bind="_rolls[participant.Id]"
                                   placeholder="01–100"
                                   class="w-20 text-sm border border-gray-300 rounded px-2 py-1.5 text-center" />
                            <button type="button" class="cm-btn cm-btn-primary cm-btn-sm"
                                    @onclick="() => ResolveCheck(participant.Id)">
                                <span>Проверить</span>
                            </button>
                        </div>
                    }
                    else
                    {
                        <!-- Результат -->
                        <div class="text-right shrink-0">
                            <div class="text-sm font-semibold @GetModColor(participant.MovModifier)">
                                СКО @participant.AdjustedMov
                                <span class="text-xs font-normal">
                                    (@baseMov @(participant.MovModifier >= 0 ? "+" : "")@participant.MovModifier)
                                </span>
                            </div>
                            <div class="text-xs text-gray-500">
                                @CombatService.GetSuccessLevelText(CombatService.CalculateSuccessLevel(
                                    _resolvedRolls.GetValueOrDefault(participant.Id, 0), skillValue))
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    <!-- Сводка -->
    @if (ChaseService.AllSpeedChecksCompleted())
    {
        var eval = ChaseService.EvaluateChaseStart();

        <div class="border rounded-md p-3 @(eval.ChaseHappens ? "bg-amber-50 border-amber-200" : "bg-green-50 border-green-200")">
            <p class="text-sm font-medium @(eval.ChaseHappens ? "text-amber-800" : "text-green-800")">
                @eval.Reason
            </p>

            @if (eval.ChaseHappens)
            {
                <!-- Таблица скорректированных СКО -->
                <div class="mt-2 text-xs text-gray-600 space-y-0.5">
                    @foreach (var p in ChaseService.Participants.OrderByDescending(p => p.AdjustedMov))
                    {
                        <div class="flex justify-between">
                            <span>@p.Name (@ChaseService.GetRoleText(p.Role))</span>
                            <span class="font-mono font-semibold">СКО @p.AdjustedMov</span>
                        </div>
                    }
                </div>

                <div class="mt-3 flex gap-2">
                    <button type="button" class="cm-btn cm-btn-success"
                            @onclick="StartChase">
                        <span>Начать погоню</span>
                    </button>
                </div>
            }
            else
            {
                <div class="mt-3">
                    <button type="button" class="cm-btn cm-btn-secondary"
                            @onclick="PreyEscaped">
                        <span>Жертва убежала</span>
                    </button>
                </div>
            }
        </div>
    }
    else
    {
        <p class="text-xs text-gray-400 text-center">
            Ожидание бросков: @ChaseService.Participants.Count(p => !p.SpeedCheckCompleted) из @ChaseService.Participants.Count
        </p>
    }
</div>

@code {
    [Parameter] public EventCallback OnChaseStarted { get; set; }
    [Parameter] public EventCallback OnPreyEscaped { get; set; }

    private readonly Dictionary<Guid, int> _rolls = [];
    private readonly Dictionary<Guid, int> _resolvedRolls = [];

    protected override void OnInitialized()
    {
        foreach (var participant in ChaseService.Participants)
            _rolls.TryAdd(participant.Id, 0);
    }

    private void ResolveCheck(Guid participantId)
    {
        _rolls.TryGetValue(participantId, out var roll);
        var actualRoll = roll > 0 ? roll : (int?)null;
        var result = ChaseService.ResolveSpeedCheck(participantId, actualRoll);
        _resolvedRolls[participantId] = result.Roll;
    }

    private static string GetModColor(int mod) => mod switch
    {
        > 0 => "text-green-700",
        < 0 => "text-red-700",
        _ => "text-gray-800"
    };

    private async Task StartChase()
    {
        ChaseService.StartChase();
        await OnChaseStarted.InvokeAsync();
    }

    private async Task PreyEscaped()
    {
        ChaseService.ResetChase();
        await OnPreyEscaped.InvokeAsync();
    }
}

@page "/npcs"
@using CampaignManager.Web.Components.Features.Characters.Services
@using CampaignManager.Web.Components.Features.Characters.Model
@using CampaignManager.Web.Extensions
@using CampaignManager.Web.Model
@using CampaignManager.Web.Components.Features.NPC.Components
@using CampaignManager.Web.Utilities.Services
@attribute [Authorize]

@inject CharacterService CharacterService
@inject NavigationManager NavigationManager
@inject IdentityService IdentityService
@rendermode InteractiveServer

<PageTitle>Управление шаблонами персонажей</PageTitle>

@if (!_isKeeper)
{
    <div class="max-w-7xl mx-auto px-4 py-6">
        <Alert Type="error" Title="Доступ запрещён">
            Эта страница доступна только для Хранителя.
        </Alert>
    </div>
}
else
{
<div class="max-w-7xl mx-auto px-4 py-6">
    <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl font-bold text-gray-800">Шаблоны персонажей</h1>
        <div class="flex gap-2">
            <Button OnClick="CreateNewPregen" Variant="success" Icon="fa-user-plus">
                Добавить преген
            </Button>
            <Button OnClick="CreateNewTemplate" Variant="info" Icon="fa-plus">
                Добавить NPC
            </Button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_notification.Message))
    {
        <div class="mb-4">
            <NotificationAlert Type="@_notification.Type" Message="@_notification.Message" OnClose="ClearNotification"/>
        </div>
    }

    @if (_isLoading)
    {
        <div class="flex justify-center p-12">
            <LoadingIndicator/>
        </div>
    }
    else if (_characterTemplates == null || !_characterTemplates.Any())
    {
        <div class="bg-gray-50 border border-gray-200 text-gray-700 px-6 py-8 rounded-lg text-center">
            <div class="mb-3">
                <i class="fa-solid fa-users-slash text-4xl text-gray-400"></i>
            </div>
            <h3 class="text-lg font-medium text-gray-800 mb-2">Нет доступных шаблонов</h3>
            <p class="text-gray-600 mb-4">Создайте свой первый шаблон персонажа</p>
            <Button OnClick="CreateNewTemplate" Variant="info" Icon="fa-plus">
                Добавить шаблон
            </Button>
        </div>
    }
    else
    {
        <!-- Tab filter for Pregens vs NPCs -->
        <div class="border-b border-gray-200 mb-6">
            <nav class="flex gap-1 -mb-px">
                <button type="button"
                        class="px-4 py-2 text-sm font-medium rounded-t-md border-b-2 transition-colors @(_activeTab == "all" ? "border-accent-500 text-accent-600 bg-white" : "border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300")"
                        @onclick='() => _activeTab = "all"'>
                    Все (@_characterTemplates.Count)
                </button>
                <button type="button"
                        class="px-4 py-2 text-sm font-medium rounded-t-md border-b-2 transition-colors @(_activeTab == "pregens" ? "border-accent-500 text-accent-600 bg-white" : "border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300")"
                        @onclick='() => _activeTab = "pregens"'>
                    <i class="fa-solid fa-user mr-1"></i> Преген-персонажи (@_pregens.Count)
                </button>
                <button type="button"
                        class="px-4 py-2 text-sm font-medium rounded-t-md border-b-2 transition-colors @(_activeTab == "npcs" ? "border-accent-500 text-accent-600 bg-white" : "border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300")"
                        @onclick='() => _activeTab = "npcs"'>
                    <i class="fa-solid fa-masks-theater mr-1"></i> NPC (@_npcs.Count)
                </button>
            </nav>
        </div>

        @if (_activeTab == "npcs")
        {
            <div class="flex gap-2 mb-4">
                <button type="button"
                        class="px-3 py-1 text-xs font-medium rounded-full transition-colors @(_roleFilter is null ? "bg-gray-700 text-white" : "bg-gray-100 text-gray-600 hover:bg-gray-200")"
                        @onclick="() => _roleFilter = null">
                    Все роли
                </button>
                @foreach (var role in Enum.GetValues<NpcRole>())
                {
                    <button type="button"
                            class="px-3 py-1 text-xs font-medium rounded-full transition-colors @(_roleFilter == role ? "bg-gray-700 text-white" : "bg-gray-100 text-gray-600 hover:bg-gray-200")"
                            @onclick="() => _roleFilter = role">
                        @role.ToRussianString()
                    </button>
                }
            </div>
        }

        <!-- Card Grid View -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var template in FilteredTemplates)
            {
                <CharacterTemplateCard
                    Template="@template"
                    OnDelete="@(async (template) => await ConfirmDeleteTemplate(template))"
                    OnLinkToScenario="@(async (template) => await ShowLinkToScenarioDialog(template))"/>
            }
        </div>

        @if (!FilteredTemplates.Any())
        {
            <div class="bg-gray-50 border border-gray-200 text-gray-700 px-6 py-8 rounded-lg text-center mt-4">
                <p class="text-gray-600">Нет шаблонов в этой категории</p>
            </div>
        }
    }
</div>

<ConfirmationModal IsVisible="_showDeleteConfirmation"
                   OnConfirm="DeleteTemplate"
                   OnCancel="CancelDelete"
                   Title="Подтверждение удаления"
                   Message="@($"Вы уверены, что хотите удалить шаблон \"{_templateToDelete?.CharacterName}\"? Это действие нельзя отменить.")"
                   ConfirmText="Удалить"
                   IconType="error"
                   WarningText="" />

@if (_showLinkDialog && _templateToLink != null)
{
    <LinkToScenarioDialog
        CharacterTemplateId="@_templateToLink.Id"
        OnCancel="@CloseLinkDialog"
        OnSave="@SaveCharacterTemplateWithScenario"/>
}
}

@code {
    private List<CharacterStorageDto>? _characterTemplates;
    private List<CharacterStorageDto> _pregens = [];
    private List<CharacterStorageDto> _npcs = [];
    private bool _isLoading = true;
    private bool _isKeeper;
    private bool _showDeleteConfirmation = false;
    private CharacterStorageDto? _templateToDelete;
    private string _activeTab = "all";
    private NpcRole? _roleFilter;

    private IEnumerable<CharacterStorageDto> FilteredTemplates => _activeTab switch
    {
        "pregens" => _pregens,
        "npcs" => _roleFilter.HasValue
            ? _npcs.Where(t => t.NpcRole == _roleFilter.Value)
            : _npcs,
        _ => _characterTemplates ?? []
    };

    // Link to scenario dialog
    private bool _showLinkDialog = false;
    private CharacterStorageDto? _templateToLink;

    private struct Notification
    {
        public string Type { get; set; }
        public string Message { get; set; }
    }

    private Notification _notification;

    protected override async Task OnInitializedAsync()
    {
        _isKeeper = await IdentityService.IsKeeper();
        await LoadTemplatesAsync();
    }

    private async Task LoadTemplatesAsync()
    {
        _isLoading = true;

        try
        {
            // Load all character templates
            _characterTemplates = await CharacterService.GetAllCharacterTemplatesAsync();
            _pregens = _characterTemplates
                .Where(t => t.Character?.CharacterType == CharacterType.PlayerCharacter)
                .ToList();
            _npcs = _characterTemplates
                .Where(t => t.Character?.CharacterType == CharacterType.NonPlayerCharacter)
                .ToList();
        }
        catch (Exception ex)
        {
            _notification = new Notification
            {
                Type = "error",
                Message = $"Ошибка при загрузке шаблонов персонажей: {ex.Message}"
            };
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void CreateNewTemplate()
    {
        NavigationManager.NavigateTo("/character/create/template");
    }

    private void CreateNewPregen()
    {
        NavigationManager.NavigateTo("/character/create/pregen");
    }

    private void EditTemplate(Guid id)
    {
        NavigationManager.NavigateTo($"/character/{id}");
    }

    private async Task ConfirmDeleteTemplate(CharacterStorageDto template)
    {
        _templateToDelete = template;
        _showDeleteConfirmation = true;
        await Task.CompletedTask;
    }

    private void CancelDelete()
    {
        _templateToDelete = null;
        _showDeleteConfirmation = false;
    }

    private async Task DeleteTemplate()
    {
        if (_templateToDelete == null)
            return;

        try
        {
            await CharacterService.SetCharacterStatusAsync(_templateToDelete.Id, CharacterStatus.Archived);

            _notification = new Notification
            {
                Type = "success",
                Message = $"Шаблон \"{_templateToDelete.CharacterName}\" успешно удален"
            };

            await LoadTemplatesAsync();
        }
        catch (Exception ex)
        {
            _notification = new Notification
            {
                Type = "error",
                Message = $"Ошибка при удалении шаблона: {ex.Message}"
            };
        }
        finally
        {
            _showDeleteConfirmation = false;
            _templateToDelete = null;
        }
    }

    private void ClearNotification()
    {
        _notification = new Notification();
        StateHasChanged();
    }

    // Show dialog to link character to scenario
    private async Task ShowLinkToScenarioDialog(CharacterStorageDto characterStorage)
    {
        _templateToLink = characterStorage;
        _showLinkDialog = true;
        await Task.CompletedTask;
    }

    // Close the link dialog
    private void CloseLinkDialog()
    {
        _showLinkDialog = false;
        _templateToLink = null;
    }

    // Save character template with scenario link
    private async Task SaveCharacterTemplateWithScenario()
    {
        _notification = new Notification
        {
            Type = "success",
            Message = "Персонаж успешно привязан к сценарию"
        };

        CloseLinkDialog();
        await LoadTemplatesAsync();
    }

}

@page "/skills"
@using CampaignManager.Web.Components.Features.Skills.Components
@using CampaignManager.Web.Components.Features.Skills.Model
@using CampaignManager.Web.Components.Features.Skills.Services
@using CampaignManager.Web.Components.Shared
@using CampaignManager.Web.Extensions
@attribute [Authorize]

@inject SkillService SkillService
@inject NavigationManager NavigationManager
@inject ILogger<SkillsPage> Logger
@rendermode InteractiveServer
<PageTitle>Навыки</PageTitle>

<div class="max-w-7xl mx-auto px-2 py-4 font-sans">
    <h1 class="cm-h2 mb-4">Навыки</h1>
    <FilterPanel Title="Фильтры" @bind-IsExpanded="_isSearchPanelVisible">
        <ActionButtons>
            @if (_isSearchPanelVisible)
            {
                <button type="button" class="cm-btn cm-btn-outline-primary cm-btn-sm" @onclick="ClearFilters">
                    <i class="fas fa-undo-alt"></i> <span>Сбросить</span>
                </button>
            }
            <button type="button" class="cm-btn cm-btn-info cm-btn-sm" @onclick="CreateNewSkill">
                <i class="fas fa-plus"></i> <span>Добавить</span>
            </button>
        </ActionButtons>
        <ChildContent>
            <div class="flex flex-col sm:flex-row gap-2">
                <div class="flex-grow">
                    <label for="searchQuery" class="block text-xs font-medium text-gray-700 mb-1">Поиск</label>
                    <div class="relative">
                        <input type="text" id="searchQuery"
                               class="w-full border border-primary-300 rounded-lg pl-8 pr-3 py-1 text-sm text-primary-700 bg-primary-50 focus:outline-none focus:ring-2 focus:ring-accent-500/25 focus:border-accent-500 hover:border-primary-400 hover:bg-white transition-colors shadow-sm"
                               placeholder="Поиск по названию..." @bind="_searchTerm" @bind:event="oninput"
                               @onkeyup="SearchKeyUp" />
                        <div class="absolute inset-y-0 left-0 pl-2 flex items-center pointer-events-none">
                            <i class="fas fa-search text-gray-400 text-xs"></i>
                        </div>
                    </div>
                </div>
                <div class="w-full sm:w-48">
                    <label for="categoryFilter" class="block text-xs font-medium text-gray-700 mb-1">Категория навыка</label>
                    <select id="categoryFilter"
                            class="w-full border border-primary-300 rounded-lg px-2 py-1 text-sm text-primary-700 bg-primary-50 focus:outline-none focus:ring-2 focus:ring-accent-500/25 focus:border-accent-500 hover:border-primary-400 hover:bg-white transition-colors shadow-sm"
                            @onchange="CategorySelectionChanged">
                        <option value="">Все категории</option>
                        @foreach (var category in EnumExtensions.GetEnumTypes<SkillCategory>())
                        {
                            <option value="@category">@category.ToRussianString()</option>
                        }
                    </select>
                </div>
            </div>
        </ChildContent>
    </FilterPanel>

    @if (_loading)
    {
        <LoadingIndicator />
    }
    else if (_skills.Count == 0)
    {
        <EmptyState IconClass="fa-book"
                    Title="Навыки не найдены"
                    Message="@(!string.IsNullOrEmpty(_searchTerm) || _selectedCategory != "" ? "Нет навыков, соответствующих критериям поиска." : "В базе данных нет навыков. Добавьте первый навык, чтобы начать.")">
            <ActionButton>
                @if (!string.IsNullOrEmpty(_searchTerm) || _selectedCategory != "")
                {
                    <button type="button" class="cm-btn cm-btn-secondary" @onclick="ClearFilters">
                        <span>Очистить фильтры</span>
                    </button>
                }
            </ActionButton>
        </EmptyState>
    }
    else
    {
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            @foreach (var skill in _skills)
            {
                <SkillCard Skill="@skill" OnDelete="@(s => ConfirmDelete(s))" />
            }
        </div>
        <Pagination CurrentPage="@_currentPage"
                    TotalPages="@TotalPages"
                    TotalItems="@_totalItems"
                    ItemsPerPage="@_pageSize"
                    ItemsLabel="навыков"
                    OnPageChanged="GoToPage" />
    }
</div>

<ConfirmationModal IsVisible="@_showDeleteModal"
                  OnConfirm="DeleteSkill"
                  OnCancel="() => _showDeleteModal = false"
                  Title="Подтверждение удаления"
                  Message="@($"Вы уверены, что хотите удалить навык? Это действие нельзя отменить.")"
                  ConfirmText="Удалить"
                  CancelText="Отмена">
    <DetailsContent>
        <p class="text-gray-700 text-base">
            <span class="font-semibold text-gray-900">Название:</span> @(_skillToDelete?.Name)
        </p>
    </DetailsContent>
</ConfirmationModal>

@code {
    private List<SkillModel> _skills = [];
    private bool _loading = true;
    private string _searchTerm = "";
    private string _selectedCategory = "";
    private bool _isSearchPanelVisible = true;

    private bool _showDeleteModal;
    private SkillModel? _skillToDelete;

    private int _currentPage = 1;
    private readonly int _pageSize = 6;
    private int _totalItems;
    private int TotalPages => (int)Math.Ceiling((double)_totalItems / _pageSize);

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            _loading = true;
            _totalItems = await SkillService.GetSkillCountAsync(_searchTerm, _selectedCategory);
            _skills = await SkillService.GetAllSkillsAsync(_searchTerm, _selectedCategory, _currentPage, _pageSize);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading skills data");
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnSearchTermChanged(string searchTerm)
    {
        _searchTerm = searchTerm;
        _currentPage = 1;
        await LoadData();
    }

    private async Task CategorySelectionChanged(ChangeEventArgs e)
    {
        _selectedCategory = e.Value?.ToString() ?? "";
        _currentPage = 1;
        await LoadData();
    }

    private async Task ClearFilters()
    {
        _searchTerm = "";
        _selectedCategory = "";
        _currentPage = 1;
        await LoadData();
    }

    private async Task SearchKeyUp(KeyboardEventArgs e)
    {
        await OnSearchTermChanged(_searchTerm);
    }

    private void CreateNewSkill()
    {
        NavigationManager.NavigateTo("/skills/edit");
    }

    private void ConfirmDelete(SkillModel skill)
    {
        _skillToDelete = skill;
        _showDeleteModal = true;
    }

    private async Task DeleteSkill()
    {
        if (_skillToDelete is null) return;

        try
        {
            var success = await SkillService.DeleteSkillAsync(_skillToDelete.Id);
            if (success) await LoadData();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error deleting skill {SkillId}", _skillToDelete.Id);
        }
        finally
        {
            _showDeleteModal = false;
            _skillToDelete = null;
        }
    }

    private async Task GoToPage(int page)
    {
        _currentPage = page;
        await LoadData();
    }
}

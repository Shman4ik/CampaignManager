@page "/combat"
@rendermode InteractiveServer
@attribute [Authorize]

@using Microsoft.AspNetCore.Authorization
@using CampaignManager.Web.Components.Features.Combat.Services
@using CampaignManager.Web.Components.Features.Combat.Model
@using CampaignManager.Web.Components.Features.Combat.Components
@using CampaignManager.Web.Components.Features.Characters.Services
@using CampaignManager.Web.Components.Features.Characters.Model
@using CampaignManager.Web.Components.Features.Bestiary.Services
@using CampaignManager.Web.Components.Features.Bestiary.Model
@using CampaignManager.Web.Components.Features.Campaigns.Models
@using CampaignManager.Web.Components.Features.Campaigns.Services
@using CampaignManager.Web.Components.Features.Scenarios.Model
@using CampaignManager.Web.Components.Features.Scenarios.Services
@using CampaignManager.Web.Components.Shared
@using CampaignManager.Web.Utilities.Services

@inject CombatService CombatService
@inject CreatureService CreatureService
@inject CampaignService CampaignService
@inject ScenarioService ScenarioService
@inject CharacterService CharacterService
@inject IdentityService IdentityService
@implements IDisposable

<PageTitle>Боевой помощник</PageTitle>

<PageHeader Title="Боевой помощник"/>

@if (!_isKeeper)
{
    <div class="max-w-7xl mx-auto px-2 py-4 font-sans">
        <Alert Type="error" Title="Доступ запрещён">
            Эта страница доступна только для мастера игры.
        </Alert>
    </div>
}
else
{
<div class="max-w-7xl mx-auto px-2 py-4 font-sans">
    <!-- Заголовок -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-4">
        <h1 class="cm-h2">Боевой помощник</h1>
        <div class="flex flex-wrap items-center gap-3">
            <CampaignSelector OnCampaignSelected="HandleCampaignSelected" />
            @if (_selectedCampaign != null && _campaignScenarios.Count > 0)
            {
                <ScenarioSelector Scenarios="_campaignScenarios"
                                  SelectedScenarioId="_selectedScenario?.Id"
                                  OnScenarioSelected="HandleScenarioSelected" />
            }
        </div>
    </div>

    <!-- Панель раундов -->
    <div class="bg-white shadow-sm rounded-md border border-gray-200 p-3 mb-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
        <div class="flex items-center gap-4">
            <span class="text-sm font-semibold text-gray-800">Раунд: @CombatService.CurrentRound</span>
            <span class="text-sm text-gray-500">Ход: @(CombatService.CurrentTurnIndex + 1) / @Math.Max(1, CombatService.Combatants.Count)</span>
            @if (CombatService.GetActiveCombatant() != null)
            {
                <span class="text-sm font-medium text-blue-700">
                    → @CombatService.GetActiveCombatant()!.Name
                </span>
            }
        </div>
        <div class="flex gap-2">
            <button type="button" class="cm-btn cm-btn-primary cm-btn-sm" @onclick="NextTurn"><span>Следующий ход</span></button>
            <button type="button" class="cm-btn cm-btn-secondary cm-btn-sm" @onclick="NextRound"><span>Следующий раунд</span></button>
            <button type="button" class="cm-btn cm-btn-info cm-btn-sm" @onclick="ToggleCombatLog">
                <span>@(_showCombatLog ? "Скрыть журнал" : "Журнал боя")</span>
            </button>
        </div>
    </div>

    <!-- Колонки -->
    <div class="grid grid-cols-12 gap-4">

        <!-- Левая: Список инициативы + Добавление -->
        <div class="col-span-12 lg:col-span-4 space-y-3">
            <!-- Участники -->
            <div class="bg-white shadow-sm rounded-md border border-gray-200 p-3">
                <h3 class="text-sm font-semibold text-gray-800 mb-2">Порядок инициативы</h3>
                <div class="max-h-[40vh] overflow-y-auto pr-1">
                    @if (CombatService.Combatants.Any())
                    {
                        @foreach (var combatant in CombatService.Combatants)
                        {
                            <CombatantCard Combatant="combatant"
                                           IsActive="@(combatant == CombatService.GetActiveCombatant())"
                                           OnRemoveCallback="RemoveCombatant"
                                           OnDelayTurn="HandleDelayTurn"
                                           OnSortNeeded="SortInitiative" />
                        }
                    }
                    else
                    {
                        <p class="text-sm text-gray-400 text-center py-4">Нет участников</p>
                    }
                </div>
            </div>

            <!-- Добавить участника -->
            <div class="bg-white shadow-sm rounded-md border border-gray-200 p-3">
                <h3 class="text-sm font-semibold text-gray-800 mb-2">Добавить участника</h3>

                <div class="flex flex-wrap gap-1 mb-2">
                    <button @onclick='() => _showAddMode = "characters"'
                            class="px-2 py-1 text-xs rounded font-medium transition-colors @(_showAddMode == "characters" ? "bg-blue-100 text-blue-700" : "bg-gray-100 text-gray-600 hover:bg-gray-200")">
                        Персонажи
                    </button>
                    <button @onclick='() => _showAddMode = "creatures"'
                            class="px-2 py-1 text-xs rounded font-medium transition-colors @(_showAddMode == "creatures" ? "bg-red-100 text-red-700" : "bg-gray-100 text-gray-600 hover:bg-gray-200")">
                        Существа
                    </button>
                    @if (_selectedScenario != null)
                    {
                        <button @onclick='() => _showAddMode = "scenario-npcs"'
                                class="px-2 py-1 text-xs rounded font-medium transition-colors @(_showAddMode == "scenario-npcs" ? "bg-purple-100 text-purple-700" : "bg-gray-100 text-gray-600 hover:bg-gray-200")">
                            НПС
                        </button>
                        <button @onclick='() => _showAddMode = "scenario-creatures"'
                                class="px-2 py-1 text-xs rounded font-medium transition-colors @(_showAddMode == "scenario-creatures" ? "bg-orange-100 text-orange-700" : "bg-gray-100 text-gray-600 hover:bg-gray-200")">
                            Монстры сцен.
                        </button>
                    }
                </div>

                @if (_showAddMode == "creatures")
                {
                    <input type="text"
                           class="w-full border border-gray-200 rounded-md px-2 py-1 text-xs mb-1 focus:outline-none focus:ring-1 focus:ring-accent-500/25 focus:border-accent-500"
                           placeholder="Поиск существа..."
                           @bind="_creatureSearch"
                           @bind:event="oninput" />
                }

                <div class="max-h-[25vh] overflow-y-auto border border-gray-100 rounded-md">
                    @if (_showAddMode == "characters")
                    {
                        @if (_availableCharacters == null)
                        {
                            <p class="text-xs text-gray-400 p-2">@(_selectedCampaign == null ? "Выберите кампанию" : "Загрузка...")</p>
                        }
                        else if (!_availableCharacters.Any())
                        {
                            <p class="text-xs text-gray-400 p-2">Нет персонажей</p>
                        }
                        else
                        {
                            @foreach (var chara in _availableCharacters)
                            {
                                <div class="flex justify-between items-center px-2 py-1.5 hover:bg-blue-50 cursor-pointer text-sm border-b border-gray-50 last:border-0"
                                     @onclick="() => AddCharacter(chara)">
                                    <span class="text-gray-800">@chara.PersonalInfo.Name</span>
                                    <span class="text-xs text-gray-400">ЛВК @chara.Characteristics.Dexterity.Regular</span>
                                </div>
                            }
                        }
                    }
                    else if (_showAddMode == "scenario-npcs")
                    {
                        @if (!_scenarioNpcs.Any())
                        {
                            <p class="text-xs text-gray-400 p-2">Нет НПС в сценарии</p>
                        }
                        else
                        {
                            @foreach (var npc in _scenarioNpcs)
                            {
                                <div class="flex justify-between items-center px-2 py-1.5 hover:bg-purple-50 cursor-pointer text-sm border-b border-gray-50 last:border-0"
                                     @onclick="() => AddNpc(npc)">
                                    <span class="text-gray-800">@npc.CharacterName</span>
                                    <span class="text-xs text-gray-400">ЛВК @npc.Character.Characteristics.Dexterity.Regular</span>
                                </div>
                            }
                        }
                    }
                    else if (_showAddMode == "scenario-creatures")
                    {
                        @if (!_scenarioCreatures.Any())
                        {
                            <p class="text-xs text-gray-400 p-2">Нет монстров в сценарии</p>
                        }
                        else
                        {
                            @foreach (var monster in _scenarioCreatures)
                            {
                                <div class="flex justify-between items-center px-2 py-1.5 hover:bg-orange-50 cursor-pointer text-sm border-b border-gray-50 last:border-0"
                                     @onclick="() => AddMonster(monster)">
                                    <span class="text-gray-800">@monster.Name</span>
                                    <span class="text-xs text-gray-400">ЛВК @monster.CreatureCharacteristics.Dexterity.Value</span>
                                </div>
                            }
                        }
                    }
                    else
                    {
                        @if (_availableCreatures == null)
                        {
                            <p class="text-xs text-gray-400 p-2">Загрузка...</p>
                        }
                        else
                        {
                            var filtered = string.IsNullOrWhiteSpace(_creatureSearch)
                                ? _availableCreatures
                                : _availableCreatures.Where(c => c.Name.Contains(_creatureSearch, StringComparison.OrdinalIgnoreCase)).ToList();
                            @foreach (var monster in filtered)
                            {
                                <div class="flex justify-between items-center px-2 py-1.5 hover:bg-red-50 cursor-pointer text-sm border-b border-gray-50 last:border-0"
                                     @onclick="() => AddMonster(monster)">
                                    <span class="text-gray-800">@monster.Name</span>
                                    <span class="text-xs text-gray-400">ЛВК @monster.CreatureCharacteristics.Dexterity.Value</span>
                                </div>
                            }
                        }
                    }
                </div>
            </div>

            <button type="button" class="cm-btn cm-btn-error cm-btn-sm w-full" @onclick="ResetCombat"><span>Сбросить бой</span></button>
        </div>

        <!-- Центральная: Панель действий -->
        <div class="col-span-12 @(_showCombatLog ? "lg:col-span-5" : "lg:col-span-8") space-y-3">
            @if (CombatService.PendingResult != null)
            {
                <AttackResultDisplay Result="CombatService.PendingResult"
                                     OnApply="ApplyPendingResult"
                                     OnCancel="CancelPendingResult" />
            }
            else
            {
                <div class="bg-white shadow-sm rounded-md border border-gray-200 p-4">
                    <!-- Активный боец (контекст) -->
                    @if (CombatService.GetActiveCombatant() is { } active)
                    {
                        <div class="flex items-center gap-2 mb-3 px-2 py-1.5 bg-blue-50 rounded-md border border-blue-100">
                            <span class="text-xs text-blue-500 font-medium">Ход:</span>
                            <span class="text-sm font-bold text-blue-800">@active.Name</span>
                            <span class="text-xs text-gray-500">ОЗ @active.CurrentHitPoints/@active.MaxHitPoints</span>
                            @if (active.IsDying)
                            {
                                <span class="text-xs font-bold text-red-600 ml-auto">⚠ ПРИ СМЕРТИ</span>
                            }
                        </div>
                    }

                    <!-- Вкладки -->
                    <div class="flex flex-wrap gap-1 mb-4 border-b border-gray-200 pb-2">
                        <button @onclick='() => _activeTab = "attack"'
                                class="px-2.5 py-1 text-xs rounded font-medium transition-colors @(_activeTab == "attack" ? "bg-blue-100 text-blue-800 border border-blue-200" : "text-gray-500 hover:text-gray-700 hover:bg-gray-100")">
                            ⚔ Атака
                        </button>
                        <button @onclick='() => _activeTab = "maneuver"'
                                class="px-2.5 py-1 text-xs rounded font-medium transition-colors @(_activeTab == "maneuver" ? "bg-blue-100 text-blue-800 border border-blue-200" : "text-gray-500 hover:text-gray-700 hover:bg-gray-100")">
                            🤼 Манёвр
                        </button>
                        <button @onclick='() => _activeTab = "cover"'
                                class="px-2.5 py-1 text-xs rounded font-medium transition-colors @(_activeTab == "cover" ? "bg-blue-100 text-blue-800 border border-blue-200" : "text-gray-500 hover:text-gray-700 hover:bg-gray-100")">
                            🛡 Укрытие
                        </button>
                        <button @onclick='() => _activeTab = "flee"'
                                class="px-2.5 py-1 text-xs rounded font-medium transition-colors @(_activeTab == "flee" ? "bg-blue-100 text-blue-800 border border-blue-200" : "text-gray-500 hover:text-gray-700 hover:bg-gray-100")">
                            🏃 Бегство
                        </button>
                        <button @onclick='() => _activeTab = "firstaid"'
                                class="px-2.5 py-1 text-xs rounded font-medium transition-colors @(_activeTab == "firstaid" ? "bg-green-100 text-green-800 border border-green-200" : "text-gray-500 hover:text-gray-700 hover:bg-gray-100")">
                            🩹 Первая помощь
                        </button>
                        <button @onclick='() => _activeTab = "medicine"'
                                class="px-2.5 py-1 text-xs rounded font-medium transition-colors @(_activeTab == "medicine" ? "bg-green-100 text-green-800 border border-green-200" : "text-gray-500 hover:text-gray-700 hover:bg-gray-100")">
                            💊 Медицина
                        </button>
                        <button @onclick='() => _activeTab = "sanity"'
                                class="px-2.5 py-1 text-xs rounded font-medium transition-colors @(_activeTab == "sanity" ? "bg-purple-100 text-purple-800 border border-purple-200" : "text-gray-500 hover:text-gray-700 hover:bg-gray-100")">
                            🧠 Рассудок
                        </button>
                        <button @onclick='() => _activeTab = "dice"'
                                class="px-2.5 py-1 text-xs rounded font-medium transition-colors @(_activeTab == "dice" ? "bg-gray-200 text-gray-800 border border-gray-300" : "text-gray-500 hover:text-gray-700 hover:bg-gray-100")">
                            🎲 Кубики
                        </button>
                    </div>

                    @{ var activeId = CombatService.GetActiveCombatant()?.Id; }
                    @if (_activeTab == "attack")
                    {
                        <AttackSetupPanel Combatants="CombatService.Combatants"
                                          ActiveCombatantId="activeId"
                                          OnAttackResolved="HandleAttackResolved" />
                    }
                    else if (_activeTab == "maneuver")
                    {
                        <ManeuverSetupPanel Combatants="CombatService.Combatants"
                                            ActiveCombatantId="activeId"
                                            OnManeuverResolved="HandleManeuverResolved" />
                    }
                    else if (_activeTab == "cover")
                    {
                        <TakeCoverPanel Combatants="CombatService.Combatants"
                                        ActiveCombatantId="activeId"
                                        OnTakeCoverResolved="HandleTakeCoverResolved" />
                    }
                    else if (_activeTab == "flee")
                    {
                        <FleePanel Combatants="CombatService.Combatants"
                                   ActiveCombatantId="activeId"
                                   OnFleeResolved="HandleFleeResolved" />
                    }
                    else if (_activeTab == "firstaid")
                    {
                        <FirstAidPanel Combatants="CombatService.Combatants"
                                       ActiveCombatantId="activeId"
                                       OnFirstAidApplied="HandleFirstAidApplied" />
                    }
                    else if (_activeTab == "medicine")
                    {
                        <MedicinePanel Combatants="CombatService.Combatants"
                                       ActiveCombatantId="activeId"
                                       OnMedicineApplied="HandleMedicineApplied" />
                    }
                    else if (_activeTab == "sanity")
                    {
                        <SanityCheckPanel Combatants="CombatService.Combatants"
                                          OnSanityResolved="HandleSanityResolved" />
                    }
                    else
                    {
                        <DiceRoller />
                    }
                </div>
            }
        </div>

        <!-- Правая: Боевой журнал (скрывается) -->
        @if (_showCombatLog)
        {
            <div class="col-span-12 lg:col-span-3">
                <CombatLog LogEntries="CombatService.CombatLog" />
            </div>
        }
    </div>
</div>

<DyingCheckModal IsVisible="_showDyingModal"
                 DyingCombatants="_dyingCombatants"
                 OnApplied="HandleDyingModalApplied"
                 OnCancel="HandleDyingModalCancel" />
}

@code {
    private bool _isKeeper;
    private string _showAddMode = "characters";
    private string _activeTab = "attack";
    private bool _showDyingModal;
    private List<Combatant> _dyingCombatants = [];
    private bool _showCombatLog;
    private Campaign? _selectedCampaign;
    private List<Character>? _availableCharacters;
    private List<Creature>? _availableCreatures;
    private string _creatureSearch = "";
    private List<Scenario> _campaignScenarios = [];
    private Scenario? _selectedScenario;
    private List<CharacterStorageDto> _scenarioNpcs = [];
    private List<ScenarioCreature> _scenarioCreatures = [];

    protected override async Task OnInitializedAsync()
    {
        CombatService.OnChange += StateHasChanged;
        _isKeeper = await IdentityService.IsKeeper();

        if (_isKeeper)
        {
            _availableCreatures = await CreatureService.GetAllCreaturesAsync("", null, 1, 200);
        }
    }

    private async Task HandleCampaignSelected(Campaign? campaign)
    {
        _selectedCampaign = campaign;
        _selectedScenario = null;
        _scenarioNpcs = [];
        _scenarioCreatures = [];

        if (campaign != null)
        {
            CombatService.SetCampaign(campaign.Id);

            var fullCampaign = await CampaignService.GetCampaignWithCharactersAsync(campaign.Id);
            _availableCharacters = fullCampaign?.Players
                .SelectMany(p => p.Characters)
                .Where(c => c.Status == CharacterStatus.Active)
                .Select(c => c.Character)
                .ToList() ?? [];

            _campaignScenarios = await ScenarioService.GetCampaignScenariosAsync(campaign.Id);

            var latestScenario = _campaignScenarios.MaxBy(s => s.LastUpdated);
            if (latestScenario != null)
                await HandleScenarioSelected(latestScenario);
        }
        else
        {
            _availableCharacters = null;
            _campaignScenarios = [];
        }

        StateHasChanged();
    }

    private async Task HandleScenarioSelected(Scenario? scenario)
    {
        _selectedScenario = scenario;
        _scenarioNpcs = [];
        _scenarioCreatures = [];

        if (scenario != null)
        {
            _scenarioNpcs = await CharacterService.GetCharacterTemplatesByScenarioIdAsync(scenario.Id);

            var full = await ScenarioService.GetScenarioByIdAsync(scenario.Id);
            if (full is not null)
                _scenarioCreatures = [.. full.ScenarioCreatures];
        }

        StateHasChanged();
    }

    private void AddCharacter(Character character)
    {
        CombatService.AddCombatant(new Combatant(character));
        CombatService.SortByInitiative();
    }

    private void AddNpc(CharacterStorageDto npc)
    {
        CombatService.AddCombatant(new Combatant(npc.Character));
        CombatService.SortByInitiative();
    }

    private void AddMonster(Creature creature)
    {
        CombatService.AddCombatant(new Combatant(creature));
        CombatService.SortByInitiative();
    }

    private void RemoveCombatant(Combatant combatant)
    {
        CombatService.RemoveCombatant(combatant);
    }

    private void ToggleCombatLog() => _showCombatLog = !_showCombatLog;

    private void NextTurn() => CombatService.NextTurn();

    private void NextRound()
    {
        _dyingCombatants = CombatService.GetDyingCombatants();
        if (_dyingCombatants.Any())
            _showDyingModal = true;
        else
        {
            CombatService.NextRound();
            CombatService.SortByInitiative();
        }
    }

    private void HandleDyingModalCancel() => _showDyingModal = false;

    private void HandleDyingModalApplied()
    {
        _showDyingModal = false;
        _dyingCombatants = [];
        CombatService.NextRound();
        CombatService.SortByInitiative();
    }

    private void HandleDelayTurn(Combatant combatant) => CombatService.DelayTurn(combatant.Id);

    private void HandleTakeCoverResolved((Combatant combatant, bool success, CombatActionResult logEntry) args)
    {
        CombatService.ApplyFirstAidLog(args.logEntry);
        StateHasChanged();
    }

    private void HandleFleeResolved((Combatant fleer, CombatActionResult logEntry) args)
    {
        CombatService.ApplyFirstAidLog(args.logEntry);
        StateHasChanged();
    }

    private void HandleMedicineApplied(CombatActionResult result)
    {
        CombatService.ApplyFirstAidLog(result);
        StateHasChanged();
    }

    private void SortInitiative() => CombatService.SortByInitiative();
    private void ResetCombat() => CombatService.ResetCombat();

    private void HandleAttackResolved(CombatActionResult result)
    {
        CombatService.SetPendingResult(result);
    }

    private void HandleManeuverResolved(CombatActionResult result)
    {
        CombatService.SetPendingResult(result);
    }

    private void HandleFirstAidApplied((Combatant target, bool isDying, CombatActionResult logEntry) args)
    {
        CombatService.ApplyFirstAidLog(args.logEntry);
        StateHasChanged();
    }

    private void HandleSanityResolved(CombatActionResult result)
    {
        CombatService.ApplyResult(result);
    }

    private void ApplyPendingResult()
    {
        if (CombatService.PendingResult != null)
            CombatService.ApplyResult(CombatService.PendingResult);
    }

    private void CancelPendingResult()
    {
        CombatService.CancelPendingResult();
    }

    public void Dispose()
    {
        CombatService.OnChange -= StateHasChanged;
    }
}

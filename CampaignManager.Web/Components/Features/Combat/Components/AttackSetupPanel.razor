@using CampaignManager.Web.Components.Features.Combat.Model
@using CampaignManager.Web.Components.Features.Combat.Services
@using CampaignManager.Web.Components.Features.Weapons.Model

@inject CombatService CombatService

<div>
    <h4 class="text-base font-semibold text-gray-900 mb-3">Настройка атаки</h4>

    <!-- Атакующий -->
    <div class="mb-3">
        <label class="block text-xs font-medium text-gray-600 mb-1">Атакующий</label>
        <select class="border border-primary-300 rounded-md px-2 py-1.5 text-sm text-primary-700 bg-primary-50 w-full focus:outline-none focus:ring-1 focus:ring-accent-500/25 focus:border-accent-500 hover:border-primary-400 hover:bg-white transition-colors"
                value="@_selectedAttackerId"
                @onchange="OnAttackerChanged">
            <option value="">— Выберите —</option>
            @foreach (var c in AvailableAttackers)
            {
                <option value="@c.Id">@c.Name (@(c.IsPlayer ? "игрок" : "существо"))</option>
            }
        </select>
    </div>

    @if (_selectedAttacker != null)
    {
        <!-- Оружие / Атака -->
        <div class="mb-3">
            <label class="block text-xs font-medium text-gray-600 mb-1">Оружие / Атака</label>
            <select class="border border-primary-300 rounded-md px-2 py-1.5 text-sm text-primary-700 bg-primary-50 w-full focus:outline-none focus:ring-1 focus:ring-accent-500/25 focus:border-accent-500 hover:border-primary-400 hover:bg-white transition-colors"
                    value="@_selectedWeaponIndex"
                    @onchange="OnWeaponChanged">
                <option value="-1">— Выберите —</option>
                @for (var i = 0; i < _attackOptions.Count; i++)
                {
                    <option value="@i">@_attackOptions[i].Name — @_attackOptions[i].Damage</option>
                }
            </select>
        </div>

        @if (_selectedWeaponIndex >= 0)
        {
            <!-- Тип атаки -->
            <div class="mb-2 text-xs">
                <span class="inline-block px-2 py-0.5 rounded font-medium @(_isMelee ? "bg-orange-100 text-orange-700" : "bg-blue-100 text-blue-700")">
                    @(_isMelee ? "Ближний бой" : "Дальний бой")
                </span>
            </div>

            <!-- Навык атаки -->
            <div class="mb-3">
                <label class="block text-xs font-medium text-gray-600 mb-1">Навык атаки</label>
                <input type="number" @bind="_attackSkillValue"
                       class="border border-primary-300 rounded-md px-2 py-1 text-sm text-primary-700 bg-primary-50 w-full focus:outline-none focus:ring-1 focus:ring-accent-500/25 focus:border-accent-500 hover:border-primary-400 hover:bg-white transition-colors" />
            </div>

            <!-- Дальность (только для дальнего боя) -->
            @if (!_isMelee)
            {
                <div class="mb-3">
                    <label class="block text-xs font-medium text-gray-600 mb-1">Дальность</label>
                    <div class="flex gap-2">
                        <label class="flex items-center gap-1 text-xs cursor-pointer">
                            <input type="radio" name="range" checked="@(_rangeLevel == RangeLevel.Base)"
                                   @onchange="() => SetRangeLevel(RangeLevel.Base)" />
                            <span>Обычная (@_attackSkillValue)</span>
                        </label>
                        <label class="flex items-center gap-1 text-xs cursor-pointer">
                            <input type="radio" name="range" checked="@(_rangeLevel == RangeLevel.Long)"
                                   @onchange="() => SetRangeLevel(RangeLevel.Long)" />
                            <span>Большая (@(_attackSkillValue / 2))</span>
                        </label>
                        <label class="flex items-center gap-1 text-xs cursor-pointer">
                            <input type="radio" name="range" checked="@(_rangeLevel == RangeLevel.Extreme)"
                                   @onchange="() => SetRangeLevel(RangeLevel.Extreme)" />
                            <span>Сверхбольшая (@(_attackSkillValue / 5))</span>
                        </label>
                    </div>
                </div>
            }

            <!-- Цель -->
            <div class="mb-3">
                <label class="block text-xs font-medium text-gray-600 mb-1">Цель</label>
                <select class="border border-primary-300 rounded-md px-2 py-1.5 text-sm text-primary-700 bg-primary-50 w-full focus:outline-none focus:ring-1 focus:ring-accent-500/25 focus:border-accent-500 hover:border-primary-400 hover:bg-white transition-colors"
                        value="@_selectedDefenderId"
                        @onchange="OnDefenderChanged">
                    <option value="">— Выберите —</option>
                    @foreach (var c in AvailableDefenders)
                    {
                        <option value="@c.Id">@c.Name (@(c.IsPlayer ? "игрок" : "существо"))</option>
                    }
                </select>
            </div>

            @if (_selectedDefender != null && _isMelee)
            {
                <!-- Предупреждение о численном превосходстве -->
                @if (_selectedDefender.DefenseCountThisRound >= _selectedDefender.AttacksPerRound && _selectedDefender.DefenseCountThisRound > 0)
                {
                    <div class="bg-yellow-50 border border-yellow-200 rounded-md p-2 mb-2 text-xs text-yellow-800">
                        ⚠ @_selectedDefender.Name уже защищался в этом раунде (@_selectedDefender.DefenseCountThisRound/@_selectedDefender.AttacksPerRound) — атакующий получает <strong>1 бонусную кость</strong>.
                    </div>
                }

                <!-- Реакция защитника -->
                <div class="mb-3">
                    <label class="block text-xs font-medium text-gray-600 mb-1">Реакция защитника</label>
                    <div class="flex gap-3">
                        <label class="flex items-center gap-1.5 text-sm text-gray-700 cursor-pointer">
                            <input type="radio" name="defenderReaction" checked="@(_defenderReaction == CombatActionType.Dodge)"
                                   @onchange="() => SetDefenderReaction(CombatActionType.Dodge)" />
                            Уклонение
                        </label>
                        <label class="flex items-center gap-1.5 text-sm text-gray-700 cursor-pointer">
                            <input type="radio" name="defenderReaction" checked="@(_defenderReaction == CombatActionType.FightBack)"
                                   @onchange="() => SetDefenderReaction(CombatActionType.FightBack)" />
                            Ответный удар
                        </label>
                    </div>
                </div>

                <!-- Навык защиты -->
                <div class="mb-3">
                    <label class="block text-xs font-medium text-gray-600 mb-1">
                        Навык защиты (@(_defenderReaction == CombatActionType.Dodge ? "Уклонение" : "Ближний бой"))
                    </label>
                    <input type="number" @bind="_defenderSkillValue"
                           class="border border-primary-300 rounded-md px-2 py-1 text-sm text-primary-700 bg-primary-50 w-full focus:outline-none focus:ring-1 focus:ring-accent-500/25 focus:border-accent-500 hover:border-primary-400 hover:bg-white transition-colors" />
                </div>

                <!-- Формула урона контратаки (fight back) -->
                @if (_defenderReaction == CombatActionType.FightBack)
                {
                    <div class="mb-3">
                        <label class="block text-xs font-medium text-gray-600 mb-1">
                            Урон контратаки @_selectedDefender.Name
                        </label>
                        <input type="text" @bind="_counterDamageFormula"
                               class="border border-primary-300 rounded-md px-2 py-1 text-sm text-primary-700 bg-primary-50 w-full focus:outline-none focus:ring-1 focus:ring-accent-500/25 focus:border-accent-500 hover:border-primary-400 hover:bg-white transition-colors"
                               placeholder="1D3, 1D6, ..." />
                    </div>
                }
            }

            <!-- ═══ БРОСКИ КУБИКОВ ═══ -->
            <div class="border-t border-gray-200 pt-3 mt-3">
                <div class="text-xs font-semibold text-gray-700 mb-2 uppercase tracking-wide">Броски кубиков</div>

                <!-- Бросок атакующего -->
                <div class="mb-3">
                    <div class="flex items-center gap-2">
                        <label class="text-xs font-medium text-gray-600 w-36 shrink-0">
                            @_selectedAttacker.Name (d100)
                        </label>
                        <input type="number" min="1" max="100"
                               value="@_attackerRoll"
                               @oninput="e => OnRollInput(e, isAttacker: true)"
                               class="border border-primary-300 rounded-md px-2 py-1 text-sm text-primary-700 bg-primary-50 w-20 focus:outline-none focus:ring-1 focus:ring-accent-500/25 focus:border-accent-500"
                               placeholder="1–100" />
                        <button @onclick="AutoRollAttacker" class="text-xs px-2 py-1 rounded bg-gray-100 hover:bg-gray-200 text-gray-600 whitespace-nowrap">🎲 авто</button>
                    </div>
                    @if (_attackerRoll.HasValue)
                    {
                        <div class="mt-0.5 ml-36 text-xs font-medium @GetLevelColor(_attackerSuccessLevel)">
                            → @CombatService.GetSuccessLevelText(_attackerSuccessLevel)
                        </div>
                    }
                </div>

                <!-- Бросок защитника (ближний бой) -->
                @if (_isMelee && _selectedDefender != null && !_targetUnaware)
                {
                    <div class="mb-3">
                        <div class="flex items-center gap-2">
                            <label class="text-xs font-medium text-gray-600 w-36 shrink-0">
                                @_selectedDefender.Name (d100)
                            </label>
                            <input type="number" min="1" max="100"
                                   value="@_defenderRoll"
                                   @oninput="e => OnRollInput(e, isAttacker: false)"
                                   class="border border-primary-300 rounded-md px-2 py-1 text-sm text-primary-700 bg-primary-50 w-20 focus:outline-none focus:ring-1 focus:ring-accent-500/25 focus:border-accent-500"
                                   placeholder="1–100" />
                            <button @onclick="AutoRollDefender" class="text-xs px-2 py-1 rounded bg-gray-100 hover:bg-gray-200 text-gray-600 whitespace-nowrap">🎲 авто</button>
                        </div>
                        @if (_defenderRoll.HasValue)
                        {
                            <div class="mt-0.5 ml-36 text-xs font-medium @GetLevelColor(_defenderSuccessLevel)">
                                → @CombatService.GetSuccessLevelText(_defenderSuccessLevel)
                            </div>
                        }
                    </div>
                }
                @if (_targetUnaware)
                {
                    <div class="mb-3 text-xs text-amber-700 bg-amber-50 rounded p-2">
                        Цель не подозревает — бросок защитника не используется.
                    </div>
                }

                <!-- Модификаторы (скрываются) -->
                <details class="mb-3">
                    <summary class="text-xs font-medium text-gray-500 cursor-pointer hover:text-gray-700">Модификаторы и условия</summary>
                    <div class="mt-2 space-y-2 pl-1">
                        <div class="flex items-center gap-3">
                            <label class="text-xs text-gray-600 w-36 shrink-0">Бонусные кости</label>
                            <input type="number" min="0" max="2" @bind="_bonusDice"
                                   class="border border-primary-300 rounded-md px-2 py-1 text-sm w-16 focus:outline-none" />
                        </div>
                        <div class="flex items-center gap-3">
                            <label class="text-xs text-gray-600 w-36 shrink-0">Штрафные кости</label>
                            <input type="number" min="0" max="2" @bind="_penaltyDice"
                                   class="border border-primary-300 rounded-md px-2 py-1 text-sm w-16 focus:outline-none" />
                        </div>
                        <label class="flex items-center gap-2 text-xs text-gray-700 cursor-pointer">
                            <input type="checkbox" @bind="_surpriseAttack" />
                            Внезапная атака
                        </label>
                        <label class="flex items-center gap-2 text-xs text-gray-700 cursor-pointer">
                            <input type="checkbox" @bind="_targetUnaware" />
                            Цель не подозревает (автопопадание, нет броска защиты)
                        </label>

                        @if (!_isMelee)
                        {
                            <div class="border-t border-gray-200 pt-2 mt-2">
                                <div class="text-xs font-semibold text-gray-500 mb-1">Модификаторы стрельбы</div>
                                <div class="space-y-1">
                                    <label class="flex items-center gap-2 text-xs text-gray-700 cursor-pointer">
                                        <input type="checkbox" @bind="_isPointBlank" />
                                        В упор (≤ЛВК/15 м) → +1 бонусная
                                    </label>
                                    <label class="flex items-center gap-2 text-xs text-gray-700 cursor-pointer">
                                        <input type="checkbox" @bind="_isAiming" />
                                        Прицеливание (потрачен раунд) → +1 бонусная
                                    </label>
                                    <label class="flex items-center gap-2 text-xs text-gray-700 cursor-pointer">
                                        <input type="checkbox" @bind="_isTargetTakingCover" />
                                        Цель укрылась от огня → +1 штрафная
                                    </label>
                                    <label class="flex items-center gap-2 text-xs text-gray-700 cursor-pointer">
                                        <input type="checkbox" @bind="_isTargetBehindCover" />
                                        Частичное укрытие (≥50%) → +1 штрафная
                                    </label>
                                    <label class="flex items-center gap-2 text-xs text-gray-700 cursor-pointer">
                                        <input type="checkbox" @bind="_isTargetFastMoving" />
                                        Быстро движущаяся цель (СКО ≥8) → +1 штрафная
                                    </label>
                                    <label class="flex items-center gap-2 text-xs text-gray-700 cursor-pointer">
                                        <input type="checkbox" @bind="_isFiringIntoMelee" />
                                        Стрельба в ближнем бою → +1 штрафная
                                    </label>
                                    <label class="flex items-center gap-2 text-xs text-gray-700 cursor-pointer">
                                        <input type="checkbox" @bind="_isMultipleShot" />
                                        Серия выстрелов из пистолета → +1 штрафная
                                    </label>
                                    <label class="flex items-center gap-2 text-xs text-gray-700 cursor-pointer">
                                        <input type="checkbox" @bind="_isReloadAndFire" />
                                        Зарядка + выстрел → +1 штрафная
                                    </label>
                                </div>

                                @{
                                    var (autoBonus, autoPenalty) = CalculateAutoFirearmModifiers();
                                    var netDice = autoBonus + _bonusDice - autoPenalty - _penaltyDice;
                                }
                                <div class="mt-2 text-xs text-gray-600 bg-gray-50 rounded p-1.5">
                                    Итого: <strong class="text-green-700">+@(autoBonus + _bonusDice) бонусн.</strong>
                                    / <strong class="text-red-700">−@(autoPenalty + _penaltyDice) штрафн.</strong>
                                    @if (_selectedDefender != null && _selectedDefender.Build >= 4)
                                    {
                                        <span class="text-green-600"> (крупная цель)</span>
                                    }
                                    @if (_selectedDefender != null && _selectedDefender.Build <= -2)
                                    {
                                        <span class="text-red-600"> (мелкая цель)</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </details>

                <!-- Урон (показывается когда бросок введён и атака успешна) -->
                @if (_attackerRoll.HasValue && _attackerSuccessLevel > SuccessLevel.Failure)
                {
                    var option = _attackOptions[_selectedWeaponIndex];
                    bool isExtraordinary = _attackerSuccessLevel >= SuccessLevel.ExtremeSuccess;
                    bool isImpaling = CombatService.IsImpalingWeapon(option.Weapon ?? new Weapon { Name = option.Name, Type = WeaponType.Melee });

                    <div class="bg-gray-50 rounded-md border border-gray-100 p-3 mb-3">
                        <div class="text-xs font-semibold text-gray-600 mb-2">
                            Урон (@option.Damage
                            @if (_selectedAttacker.DamageBonus != "0") { <span> + БкУ @_selectedAttacker.DamageBonus</span> })
                        </div>

                        @if (isExtraordinary)
                        {
                            var maxDmg = CombatService.MaximizeDiceFormula(option.Damage);
                            var maxDb = _isMelee ? CombatService.MaximizeDiceFormula(_selectedAttacker.DamageBonus) : 0;
                            <div class="text-xs text-green-700 mb-2">
                                @(isImpaling ? "Проникающая рана" : "Чрезвычайный успех") — максимальный урон:
                                <strong>@maxDmg@(maxDb != 0 ? $" + {maxDb}" : "")</strong>
                                @if (isImpaling) { <span> + доп. бросок @option.Damage</span> }
                            </div>
                            @if (isImpaling && _isMelee)
                            {
                                <div class="flex items-center gap-2 mb-1">
                                    <label class="text-xs text-gray-600 w-36 shrink-0">Доп. бросок (@option.Damage)</label>
                                    <input type="number" min="0" value="@_extraImpalingRoll"
                                           @oninput="e => OnDamageInput(e, DamageField.ExtraImpaling)"
                                           class="border border-primary-300 rounded-md px-2 py-1 text-xs w-20 focus:outline-none"
                                           placeholder="рез." />
                                    <button @onclick="() => AutoRollDamage(DamageField.ExtraImpaling, option.Damage)" class="text-xs px-2 py-1 rounded bg-gray-100 hover:bg-gray-200 text-gray-600">🎲</button>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="flex items-center gap-2 mb-1">
                                <label class="text-xs text-gray-600 w-36 shrink-0">Урон оружия</label>
                                <input type="number" min="0" value="@_weaponDamageRoll"
                                       @oninput="e => OnDamageInput(e, DamageField.Weapon)"
                                       class="border border-primary-300 rounded-md px-2 py-1 text-xs w-20 focus:outline-none"
                                       placeholder="рез." />
                                <button @onclick="() => AutoRollDamage(DamageField.Weapon, option.Damage)" class="text-xs px-2 py-1 rounded bg-gray-100 hover:bg-gray-200 text-gray-600">🎲</button>
                            </div>
                            @if (_isMelee && _selectedAttacker.DamageBonus != "0")
                            {
                                <div class="flex items-center gap-2 mb-1">
                                    <label class="text-xs text-gray-600 w-36 shrink-0">БкУ (@_selectedAttacker.DamageBonus)</label>
                                    <input type="number" value="@_damageBonusRoll"
                                           @oninput="e => OnDamageInput(e, DamageField.DamageBonus)"
                                           class="border border-primary-300 rounded-md px-2 py-1 text-xs w-20 focus:outline-none"
                                           placeholder="рез." />
                                    <button @onclick="() => AutoRollDamage(DamageField.DamageBonus, _selectedAttacker.DamageBonus)" class="text-xs px-2 py-1 rounded bg-gray-100 hover:bg-gray-200 text-gray-600">🎲</button>
                                </div>
                            }
                        }

                        <!-- Контратака (fight back защитника победил) -->
                        @if (_defenderReaction == CombatActionType.FightBack && _defenderRoll.HasValue
                             && !ResolveOpposed())
                        {
                            <div class="border-t border-gray-200 pt-2 mt-2">
                                <div class="text-xs font-semibold text-red-700 mb-1">Контратака @_selectedDefender!.Name</div>
                                <div class="flex items-center gap-2 mb-1">
                                    <label class="text-xs text-gray-600 w-36 shrink-0">Урон контратаки</label>
                                    <input type="number" min="0" value="@_counterWeaponRoll"
                                           @oninput="e => OnDamageInput(e, DamageField.CounterWeapon)"
                                           class="border border-primary-300 rounded-md px-2 py-1 text-xs w-20 focus:outline-none"
                                           placeholder="рез." />
                                    <button @onclick='() => AutoRollDamage(DamageField.CounterWeapon, _counterDamageFormula)' class="text-xs px-2 py-1 rounded bg-gray-100 hover:bg-gray-200 text-gray-600">🎲</button>
                                </div>
                                @if (_selectedDefender.DamageBonus != "0")
                                {
                                    <div class="flex items-center gap-2 mb-1">
                                        <label class="text-xs text-gray-600 w-36 shrink-0">БкУ (@_selectedDefender.DamageBonus)</label>
                                        <input type="number" value="@_counterBonusRoll"
                                               @oninput="e => OnDamageInput(e, DamageField.CounterBonus)"
                                               class="border border-primary-300 rounded-md px-2 py-1 text-xs w-20 focus:outline-none"
                                               placeholder="рез." />
                                        <button @onclick='() => AutoRollDamage(DamageField.CounterBonus, _selectedDefender.DamageBonus)' class="text-xs px-2 py-1 rounded bg-gray-100 hover:bg-gray-200 text-gray-600">🎲</button>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- Кнопка атаки -->
            <button type="button" class="cm-btn cm-btn-error w-full" @onclick="ResolveAttack" disabled="@(!CanResolve())">
                <span>Провести атаку</span>
            </button>
        }
    }
</div>

@code {
    [Parameter] public List<Combatant> Combatants { get; set; } = [];
    [Parameter] public EventCallback<CombatActionResult> OnAttackResolved { get; set; }
    [Parameter] public Guid? ActiveCombatantId { get; set; }

    private Guid? _lastActiveId;

    protected override void OnParametersSet()
    {
        if (ActiveCombatantId.HasValue && ActiveCombatantId != _lastActiveId)
        {
            _lastActiveId = ActiveCombatantId;
            var active = Combatants.FirstOrDefault(c => c.Id == ActiveCombatantId.Value && !c.IsDead && !c.IsUnconscious);
            if (active != null) SelectAttacker(active);
        }
    }

    private string _selectedAttackerId = "";
    private string _selectedDefenderId = "";
    private int _selectedWeaponIndex = -1;
    private Combatant? _selectedAttacker;
    private Combatant? _selectedDefender;
    private int _attackSkillValue;
    private int _defenderSkillValue;
    private bool _isMelee;
    private CombatActionType _defenderReaction = CombatActionType.Dodge;
    private RangeLevel _rangeLevel = RangeLevel.Base;
    private string _counterDamageFormula = "1D3";

    // Броски кубиков
    private int? _attackerRoll;
    private int? _defenderRoll;
    private int? _weaponDamageRoll;
    private int? _damageBonusRoll;
    private int? _extraImpalingRoll;
    private int? _counterWeaponRoll;
    private int? _counterBonusRoll;

    // Уровни успеха (вычисляются в реальном времени)
    private SuccessLevel _attackerSuccessLevel;
    private SuccessLevel _defenderSuccessLevel;

    // Модификаторы
    private int _bonusDice;
    private int _penaltyDice;
    private bool _surpriseAttack;
    private bool _targetUnaware;

    // Модификаторы стрельбы (CoC 7e стр. 110–113)
    private bool _isPointBlank;
    private bool _isAiming;
    private bool _isFiringIntoMelee;
    private bool _isTargetTakingCover;
    private bool _isTargetBehindCover;
    private bool _isTargetFastMoving;
    private bool _isMultipleShot;
    private bool _isReloadAndFire;

    // Ручной ввод ВЫН
    private int? _manualConRoll;
    private int? _manualCounterConRoll;

    private List<AttackOption> _attackOptions = [];

    private IEnumerable<Combatant> AvailableAttackers =>
        Combatants.Where(c => !c.IsDead && !c.IsUnconscious);

    private IEnumerable<Combatant> AvailableDefenders =>
        Combatants.Where(c => !c.IsDead && c.Id != _selectedAttacker?.Id);

    private void OnAttackerChanged(ChangeEventArgs e)
    {
        var id = e.Value?.ToString() ?? "";
        var combatant = Guid.TryParse(id, out var guid) ? Combatants.FirstOrDefault(c => c.Id == guid) : null;
        SelectAttacker(combatant);
    }

    private void SelectAttacker(Combatant? attacker)
    {
        _selectedAttacker = attacker;
        _selectedAttackerId = attacker?.Id.ToString() ?? "";
        _selectedWeaponIndex = -1;
        _attackOptions.Clear();
        ResetRolls();

        if (_selectedAttacker == null) return;

        if (_selectedAttacker.CharacterSource != null)
        {
            foreach (var w in _selectedAttacker.CharacterSource.Weapons)
            {
                _attackOptions.Add(new AttackOption
                {
                    Name = w.Name,
                    Damage = w.Damage,
                    Weapon = w,
                    IsMelee = w.Type == WeaponType.Melee,
                    SkillValue = CombatService.FindSkillValue(_selectedAttacker.CharacterSource, w.Skill)
                });
            }
        }
        else if (_selectedAttacker.CreatureSource != null)
        {
            foreach (var kvp in _selectedAttacker.CreatureSource.CombatDescriptions)
            {
                _attackOptions.Add(new AttackOption
                {
                    Name = kvp.Key,
                    Damage = kvp.Value,
                    IsMelee = true,
                    SkillValue = 50
                });
            }
        }

        _attackOptions.Add(new AttackOption
        {
            Name = "Безоружная атака",
            Damage = "1D3",
            IsMelee = true,
            SkillValue = _selectedAttacker.FightingSkill
        });
    }

    private void OnWeaponChanged(ChangeEventArgs e)
    {
        _selectedWeaponIndex = int.TryParse(e.Value?.ToString(), out var idx) ? idx : -1;
        ResetRolls();
        if (_selectedWeaponIndex >= 0 && _selectedWeaponIndex < _attackOptions.Count)
        {
            var option = _attackOptions[_selectedWeaponIndex];
            _isMelee = option.IsMelee;
            _attackSkillValue = option.SkillValue;
            _rangeLevel = RangeLevel.Base;
        }
    }

    private void OnDefenderChanged(ChangeEventArgs e)
    {
        _selectedDefenderId = e.Value?.ToString() ?? "";
        _selectedDefender = Guid.TryParse(_selectedDefenderId, out var id)
            ? Combatants.FirstOrDefault(c => c.Id == id) : null;
        ResetRolls();
        UpdateDefenderSkill();
        UpdateCounterFormula();
    }

    private void SetDefenderReaction(CombatActionType reaction)
    {
        _defenderReaction = reaction;
        ResetRolls();
        UpdateDefenderSkill();
    }

    private void SetRangeLevel(RangeLevel range)
    {
        _rangeLevel = range;
        ResetRolls();
    }

    private void UpdateDefenderSkill()
    {
        if (_selectedDefender == null) return;
        _defenderSkillValue = _defenderReaction == CombatActionType.Dodge
            ? _selectedDefender.DodgeSkill
            : _selectedDefender.FightingSkill;
    }

    private void UpdateCounterFormula()
    {
        if (_selectedDefender?.CharacterSource?.Weapons.Count > 0)
            _counterDamageFormula = _selectedDefender.CharacterSource.Weapons[0].Damage;
        else
            _counterDamageFormula = "1D3";
    }

    private void ResetRolls()
    {
        _attackerRoll = null;
        _defenderRoll = null;
        _weaponDamageRoll = null;
        _damageBonusRoll = null;
        _extraImpalingRoll = null;
        _counterWeaponRoll = null;
        _counterBonusRoll = null;
        _manualConRoll = null;
        _manualCounterConRoll = null;
        _attackerSuccessLevel = SuccessLevel.Failure;
        _defenderSuccessLevel = SuccessLevel.Failure;
        _isPointBlank = false;
        _isAiming = false;
        _isFiringIntoMelee = false;
        _isTargetTakingCover = false;
        _isTargetBehindCover = false;
        _isTargetFastMoving = false;
        _isMultipleShot = false;
        _isReloadAndFire = false;
    }

    private void OnRollInput(ChangeEventArgs e, bool isAttacker)
    {
        if (!int.TryParse(e.Value?.ToString(), out var v)) return;
        v = Math.Clamp(v, 1, 100);

        if (isAttacker)
        {
            _attackerRoll = v;
            var eff = CombatService.GetEffectiveSkillForRange(_attackSkillValue, _rangeLevel);
            _attackerSuccessLevel = CombatService.CalculateSuccessLevel(v, eff);
        }
        else
        {
            _defenderRoll = v;
            _defenderSuccessLevel = CombatService.CalculateSuccessLevel(v, _defenderSkillValue);
        }
    }

    private void OnDamageInput(ChangeEventArgs e, DamageField field)
    {
        if (!int.TryParse(e.Value?.ToString(), out var v)) return;
        switch (field)
        {
            case DamageField.Weapon: _weaponDamageRoll = v; break;
            case DamageField.DamageBonus: _damageBonusRoll = v; break;
            case DamageField.ExtraImpaling: _extraImpalingRoll = v; break;
            case DamageField.CounterWeapon: _counterWeaponRoll = v; break;
            case DamageField.CounterBonus: _counterBonusRoll = v; break;
        }
    }

    private void AutoRollAttacker()
    {
        _attackerRoll = CombatService.RollD100();
        var eff = CombatService.GetEffectiveSkillForRange(_attackSkillValue, _rangeLevel);
        _attackerSuccessLevel = CombatService.CalculateSuccessLevel(_attackerRoll.Value, eff);
    }

    private void AutoRollDefender()
    {
        _defenderRoll = CombatService.RollD100();
        _defenderSuccessLevel = CombatService.CalculateSuccessLevel(_defenderRoll.Value, _defenderSkillValue);
    }

    private void AutoRollDamage(DamageField field, string formula)
    {
        var roll = CombatService.RollDiceFormula(formula);
        switch (field)
        {
            case DamageField.Weapon: _weaponDamageRoll = roll; break;
            case DamageField.DamageBonus: _damageBonusRoll = roll; break;
            case DamageField.ExtraImpaling: _extraImpalingRoll = roll; break;
            case DamageField.CounterWeapon: _counterWeaponRoll = roll; break;
            case DamageField.CounterBonus: _counterBonusRoll = roll; break;
        }
    }

    private bool ResolveOpposed()
    {
        if (!_defenderRoll.HasValue) return true;
        return CombatService.ResolveOpposedRoll(
            _attackerSuccessLevel, _attackSkillValue,
            _defenderSuccessLevel, _defenderSkillValue,
            _defenderReaction);
    }

    private bool CanResolve() =>
        _selectedAttacker != null && _selectedWeaponIndex >= 0
        && (_selectedDefender != null || !_isMelee);

    private async Task ResolveAttack()
    {
        if (_selectedAttacker == null || _selectedWeaponIndex < 0) return;
        if (_isMelee && _selectedDefender == null) return;

        var option = _attackOptions[_selectedWeaponIndex];
        var hasNumericalSuperiority = _isMelee && _selectedDefender != null
            && _selectedDefender.DefenseCountThisRound >= _selectedDefender.AttacksPerRound
            && _selectedDefender.DefenseCountThisRound > 0;

        // Для дальнего боя: суммируем ручные + авто-модификаторы стрельбы
        int effectiveBonusDice, effectivePenaltyDice;
        if (!_isMelee)
        {
            var (autoBonus, autoPenalty) = CalculateAutoFirearmModifiers();
            effectiveBonusDice = _bonusDice + autoBonus;
            effectivePenaltyDice = _penaltyDice + autoPenalty;
        }
        else
        {
            effectiveBonusDice = _bonusDice + (hasNumericalSuperiority ? 1 : 0);
            effectivePenaltyDice = _penaltyDice;
        }

        var setup = new AttackSetup
        {
            AttackerId = _selectedAttacker.Id,
            DefenderId = _selectedDefender?.Id ?? Guid.Empty,
            SelectedWeapon = option.Weapon,
            CreatureAttackName = option.Weapon == null ? option.Name : null,
            CreatureAttackDamage = option.Weapon == null ? option.Damage : null,
            AttackSkillValue = _attackSkillValue,
            IsMelee = _isMelee,
            DefenderReaction = _defenderReaction,
            DefenderSkillValue = _defenderSkillValue,
            RangeLevel = _rangeLevel,
            BonusDice = effectiveBonusDice,
            PenaltyDice = effectivePenaltyDice,
            IsSurpriseAttack = _surpriseAttack,
            TargetUnawareMeansAutoSuccess = _targetUnaware,
            CounterAttackDamageFormula = _counterDamageFormula,
            ManualAttackerRoll = _attackerRoll,
            ManualDefenderRoll = _defenderRoll,
            ManualWeaponDamageRoll = _weaponDamageRoll,
            ManualDamageBonusRoll = _damageBonusRoll,
            ManualExtraImpalingRoll = _extraImpalingRoll,
            ManualCounterWeaponDamageRoll = _counterWeaponRoll,
            ManualCounterDamageBonusRoll = _counterBonusRoll,
            ManualMajorWoundConRoll = _manualConRoll,
            ManualCounterMajorWoundConRoll = _manualCounterConRoll,
            IsPointBlank = _isPointBlank,
            IsAiming = _isAiming,
            IsFiringIntoMelee = _isFiringIntoMelee,
            IsTargetTakingCover = _isTargetTakingCover,
            IsTargetBehindCover = _isTargetBehindCover,
            IsTargetFastMoving = _isTargetFastMoving,
            IsMultipleShot = _isMultipleShot,
            IsReloadAndFire = _isReloadAndFire
        };

        var result = _isMelee
            ? CombatService.ResolveMeleeAttack(setup)
            : CombatService.ResolveRangedAttack(setup);

        ResetRolls();
        await OnAttackResolved.InvokeAsync(result);
    }

    private (int bonus, int penalty) CalculateAutoFirearmModifiers()
    {
        int bonus = 0, penalty = 0;
        if (_isPointBlank) bonus++;
        if (_isAiming) bonus++;
        if (_selectedDefender?.Build >= 4) bonus++;
        if (_isTargetTakingCover) penalty++;
        if (_isTargetBehindCover) penalty++;
        if (_isTargetFastMoving) penalty++;
        if (_isFiringIntoMelee) penalty++;
        if (_isMultipleShot) penalty++;
        if (_isReloadAndFire) penalty++;
        if (_selectedDefender?.Build <= -2) penalty++;
        return (bonus, penalty);
    }

    private static string GetLevelColor(SuccessLevel level) => level switch
    {
        SuccessLevel.CriticalSuccess => "text-yellow-600",
        SuccessLevel.ExtremeSuccess => "text-green-600",
        SuccessLevel.HardSuccess => "text-green-700",
        SuccessLevel.RegularSuccess => "text-green-800",
        SuccessLevel.Failure => "text-red-600",
        SuccessLevel.Fumble => "text-red-800",
        _ => "text-gray-600"
    };

    private enum DamageField { Weapon, DamageBonus, ExtraImpaling, CounterWeapon, CounterBonus }

    private class AttackOption
    {
        public string Name { get; set; } = "";
        public string Damage { get; set; } = "";
        public Weapon? Weapon { get; set; }
        public bool IsMelee { get; set; }
        public int SkillValue { get; set; }
    }
}

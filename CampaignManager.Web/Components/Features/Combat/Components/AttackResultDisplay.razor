@using CampaignManager.Web.Components.Features.Combat.Model
@using CampaignManager.Web.Components.Features.Combat.Services

<div class="bg-white rounded-md shadow-md border-2 border-blue-200 p-4">
    <h4 class="text-base font-semibold text-gray-900 mb-3">Результат атаки</h4>

    @if (Result.ActionType == CombatActionType.Maneuver)
    {
        <!-- Манёвр -->
        <div class="bg-gray-50 rounded-md p-3 mb-2 text-sm">
            <span class="font-semibold">@Result.AttackerName</span>
            <span class="text-gray-500"> — </span>
            <span>@CombatService.GetManeuverName(Result.ManeuverType ?? ManeuverType.Disadvantage)</span>
            <span class="text-gray-500"> против </span>
            <span class="font-semibold">@Result.DefenderName</span>
        </div>
        <div class="flex gap-3 mb-3">
            @RollBadge(Result.AttackerName, Result.AttackerRoll, Result.AttackerSkillValue, Result.AttackerSuccessLevel)
            @RollBadge(Result.DefenderName, Result.DefenderRoll, Result.DefenderSkillValue, Result.DefenderSuccessLevel)
        </div>
        <div class="rounded-md p-3 mb-3 @(Result.ManeuverSucceeded ? "bg-green-50 border border-green-200" : "bg-red-50 border border-red-200")">
            <div class="text-sm font-semibold @(Result.ManeuverSucceeded ? "text-green-800" : "text-red-800")">
                @(Result.ManeuverSucceeded ? "Манёвр удался!" : "Манёвр не удался")
            </div>
        </div>
    }
    else
    {
        <!-- Бросок атакующего -->
        <div class="bg-gray-50 rounded-md p-3 mb-2 text-sm">
            <span class="font-semibold text-gray-900">@Result.AttackerName</span>
            <span class="text-gray-400 mx-1">→</span>
            <span class="font-bold text-lg text-gray-900">@Result.AttackerRoll</span>
            <span class="text-gray-400 mx-1">/</span>
            <span class="font-semibold text-gray-700">@Result.AttackerSkillValue</span>
            <span class="mx-2">—</span>
            <span class="font-semibold @GetLevelColor(Result.AttackerSuccessLevel)">
                @CombatService.GetSuccessLevelText(Result.AttackerSuccessLevel)
            </span>
        </div>

        <!-- Бросок защитника -->
        @if (Result.ActionType == CombatActionType.MeleeAttack && Result.DefenderId.HasValue)
        {
            <div class="bg-gray-50 rounded-md p-3 mb-2 text-sm">
                <span class="font-semibold text-gray-900">@Result.DefenderName</span>
                <span class="text-gray-400 mx-1 text-xs">(@(Result.DefenderReaction == CombatActionType.FightBack ? "ответный удар" : "уклонение"))</span>
                <span class="text-gray-400 mx-1">→</span>
                <span class="font-bold text-lg text-gray-900">@Result.DefenderRoll</span>
                <span class="text-gray-400 mx-1">/</span>
                <span class="font-semibold text-gray-700">@Result.DefenderSkillValue</span>
                <span class="mx-2">—</span>
                <span class="font-semibold @GetLevelColor(Result.DefenderSuccessLevel)">
                    @CombatService.GetSuccessLevelText(Result.DefenderSuccessLevel)
                </span>
            </div>
        }

        @if (Result.IsMalfunction)
        {
            <div class="rounded-md p-3 mb-3 bg-orange-50 border border-orange-300">
                <div class="text-sm font-semibold text-orange-800">🔧 @Result.MalfunctionMessage</div>
                <div class="text-xs text-orange-600 mt-1">Ремонт: проверка Механики или Стрельбы, 1d6 раундов.</div>
            </div>
        }

        <!-- Итог бросков -->
        <div class="rounded-md p-3 mb-3 @(Result.IsMalfunction ? "bg-orange-50 border border-orange-200" : Result.AttackerWins ? "bg-green-50 border border-green-200" : "bg-red-50 border border-red-200")">
            @if (Result.AttackerWins)
            {
                <div class="text-sm font-semibold text-green-800 mb-1">Попадание!</div>

                @if (Result.TotalDamage > 0 || Result.IsInstantDeath)
                {
                    <!-- Формула урона -->
                    <div class="text-sm text-gray-700 mb-1">
                        @Result.DamageFormula = <span class="font-semibold">@Result.DamageRolled</span>
                        @if (Result.BonusDamage != 0)
                        {
                            <span class="text-gray-500"> + БкУ <span class="font-semibold text-gray-700">@Result.BonusDamage</span></span>
                        }
                        @if (Result.ExtraDamage > 0)
                        {
                            <span class="text-purple-600"> + доп. <strong>@Result.ExtraDamage</strong></span>
                        }
                        @if (Result.ArmorReduction > 0)
                        {
                            <span class="text-gray-400"> = @Result.RawDamage</span>
                            <span class="text-blue-600 text-xs"> − броня @Result.ArmorReduction</span>
                        }
                        <span class="ml-1 font-bold text-base @(Result.IsInstantDeath ? "text-red-700" : "text-gray-900")">
                            = @Result.TotalDamage
                        </span>
                    </div>

                    @if (Result.IsCritical)
                    {
                        <div class="text-xs font-bold text-yellow-700 bg-yellow-50 rounded px-2 py-1 inline-block">⚡ Критический удар!</div>
                    }
                    else if (Result.IsExtreme)
                    {
                        <div class="text-xs font-bold @(Result.IsImpalingWeapon ? "text-red-700 bg-red-50" : "text-orange-700 bg-orange-50") rounded px-2 py-1 inline-block">
                            @(Result.IsImpalingWeapon ? "🗡 Проникающая рана!" : "💥 Максимальный урон!")
                        </div>
                    }
                }

                <div class="text-sm text-gray-600 mt-1.5">
                    ОЗ @Result.DefenderName: @Result.DefenderHpBefore →
                    <span class="font-semibold @(Result.DefenderHpAfter <= 0 ? "text-red-700" : "text-gray-900")">@Result.DefenderHpAfter</span>
                </div>
            }
            else if (Result.DefenderReaction == CombatActionType.FightBack && Result.CounterTotalDamage > 0)
            {
                <div class="text-sm font-semibold text-amber-700">Промах! Атакующий получает контратаку.</div>
            }
            else
            {
                <div class="text-sm font-semibold text-red-800">Промах!</div>
            }
        </div>

        <!-- Мгновенная смерть -->
        @if (Result.IsInstantDeath)
        {
            <div class="bg-gray-900 text-white rounded-md p-3 mb-3 text-sm font-bold text-center">
                ☠ @Result.DefenderName уничтожен мгновенно!
            </div>
        }

        <!-- Тяжёлая рана защитника -->
        @if (Result.TriggeredMajorWound && !Result.IsInstantDeath)
        {
            <div class="bg-orange-50 border border-orange-300 rounded-md p-3 mb-3">
                <div class="text-sm font-bold text-orange-800">⚠ Тяжёлая рана!</div>
                <div class="text-sm text-gray-700 mt-1">
                    @Result.DefenderName падает. Проверка ВЫН:
                    бросок <strong>@Result.MajorWoundConRoll</strong>
                    — <span class="font-semibold @(Result.MajorWoundConRollSuccess ? "text-green-700" : "text-red-700")">
                        @(Result.MajorWoundConRollSuccess ? "успех" : "провал")
                    </span>
                </div>
                @if (Result.DefenderKnockedUnconscious)
                {
                    <div class="text-sm font-bold text-red-700 mt-1">@Result.DefenderName теряет сознание!</div>
                }
            </div>
        }

        <!-- Состояния защитника -->
        @if (Result.DefenderDead && !Result.IsInstantDeath)
        {
            <div class="bg-gray-800 text-white rounded-md p-3 mb-3 text-sm font-bold text-center">
                ☠ @Result.DefenderName мёртв!
            </div>
        }
        else if (Result.DefenderDying)
        {
            <div class="bg-red-700 text-white rounded-md p-3 mb-3 text-sm font-bold text-center">
                💀 @Result.DefenderName при смерти! (Проверка ВЫН каждый раунд)
            </div>
        }
        else if (Result.DefenderKnockedUnconscious && !Result.TriggeredMajorWound)
        {
            <div class="bg-amber-600 text-white rounded-md p-3 mb-3 text-sm font-bold text-center">
                @Result.DefenderName теряет сознание!
            </div>
        }

        <!-- Контратака (fight back) — урон по атакующему -->
        @if (Result.CounterTotalDamage > 0 || (Result.DefenderReaction == CombatActionType.FightBack && !Result.AttackerWins))
        {
            <div class="border border-red-200 bg-red-50 rounded-md p-3 mb-3">
                <div class="text-sm font-bold text-red-800 mb-1">
                    ↩ Контратака @Result.DefenderName → @Result.AttackerName
                </div>
                @if (Result.CounterTotalDamage > 0)
                {
                    <div class="text-sm text-gray-700">
                        @Result.CounterAttackDamageFormula = <strong>@Result.CounterDamageRolled</strong>
                        @if (Result.CounterBonusDamage != 0)
                        {
                            <span class="text-gray-500"> + БкУ <strong>@Result.CounterBonusDamage</strong></span>
                        }
                        @if (Result.CounterArmorReduction > 0)
                        {
                            <span class="text-blue-600 text-xs"> − броня @Result.CounterArmorReduction</span>
                        }
                        <span class="font-bold text-base ml-1">= @Result.CounterTotalDamage</span>
                    </div>
                    <div class="text-sm text-gray-600 mt-0.5">
                        ОЗ @Result.AttackerName: @Result.AttackerHpBefore →
                        <span class="font-semibold @(Result.AttackerHpAfter <= 0 ? "text-red-700" : "text-gray-900")">@Result.AttackerHpAfter</span>
                    </div>

                    @if (Result.AttackerTriggeredMajorWound)
                    {
                        <div class="text-xs text-orange-700 mt-1">
                            Тяжёлая рана! Проверка ВЫН: @Result.AttackerMajorWoundConRoll
                            — <span class="font-semibold @(Result.AttackerMajorWoundConRollSuccess ? "text-green-700" : "text-red-700")">
                                @(Result.AttackerMajorWoundConRollSuccess ? "успех" : "провал")
                            </span>
                        </div>
                    }
                    @if (Result.AttackerKnockedUnconscious)
                    {
                        <div class="text-xs font-bold text-red-700 mt-1">@Result.AttackerName теряет сознание!</div>
                    }
                    else if (Result.AttackerDying)
                    {
                        <div class="text-xs font-bold text-red-800 mt-1">@Result.AttackerName при смерти!</div>
                    }
                    else if (Result.AttackerDead)
                    {
                        <div class="text-xs font-bold text-gray-900 mt-1">@Result.AttackerName убит!</div>
                    }
                }
            </div>
        }
    }

    <!-- Кнопки -->
    <div class="flex gap-2">
        <button type="button" class="cm-btn cm-btn-primary w-full" @onclick="OnApply"><span>Применить</span></button>
        <button type="button" class="cm-btn cm-btn-secondary w-full" @onclick="OnCancel"><span>Отменить</span></button>
    </div>
</div>

@code {
    [Parameter] public required CombatActionResult Result { get; set; }
    [Parameter] public EventCallback OnApply { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private static string GetLevelColor(SuccessLevel level) => level switch
    {
        SuccessLevel.CriticalSuccess => "text-yellow-600",
        SuccessLevel.ExtremeSuccess => "text-green-600",
        SuccessLevel.HardSuccess => "text-green-700",
        SuccessLevel.RegularSuccess => "text-green-800",
        SuccessLevel.Failure => "text-red-600",
        SuccessLevel.Fumble => "text-red-800",
        _ => "text-gray-600"
    };

    private RenderFragment RollBadge(string name, int roll, int skill, SuccessLevel level) =>
        @<div class="bg-gray-50 rounded p-2 flex-1 text-xs">
            <div class="font-semibold text-gray-700">@name</div>
            <div class="mt-0.5">@roll / @skill</div>
            <div class="font-medium @GetLevelColor(level)">@CombatService.GetSuccessLevelText(level)</div>
        </div>;
}


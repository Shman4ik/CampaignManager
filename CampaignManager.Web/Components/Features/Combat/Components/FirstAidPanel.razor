@using CampaignManager.Web.Components.Features.Combat.Model
@using CampaignManager.Web.Components.Features.Combat.Services

@inject CombatService CombatService

<div>
    <h4 class="text-base font-semibold text-gray-900 mb-3">Первая помощь</h4>

    <div class="bg-green-50 border border-green-200 rounded-md p-2 mb-3 text-xs text-green-800">
        CoC 7e: Первая помощь в бою — успешная проверка возвращает 1 ОЗ.
        При смерти: останавливает умирание, но не восстанавливает здоровье.
    </div>

    <!-- Целитель -->
    <div class="mb-3">
        <label class="block text-xs font-medium text-gray-600 mb-1">Целитель</label>
        <select class="border border-primary-300 rounded-md px-2 py-1.5 text-sm text-primary-700 bg-primary-50 w-full focus:outline-none focus:ring-1 focus:ring-accent-500/25 focus:border-accent-500"
                value="@_healerId"
                @onchange="OnHealerChanged">
            <option value="">— Выберите —</option>
            @foreach (var c in Combatants.Where(c => !c.IsDead))
            {
                <option value="@c.Id">@c.Name</option>
            }
        </select>
    </div>

    @if (_healer != null)
    {
        <!-- Цель лечения -->
        <div class="mb-3">
            <label class="block text-xs font-medium text-gray-600 mb-1">Раненый</label>
            <select class="border border-primary-300 rounded-md px-2 py-1.5 text-sm text-primary-700 bg-primary-50 w-full focus:outline-none focus:ring-1 focus:ring-accent-500/25 focus:border-accent-500"
                    value="@_targetId"
                    @onchange="OnTargetChanged">
                <option value="">— Выберите —</option>
                @foreach (var c in Combatants.Where(c => !c.IsDead && c.CurrentHitPoints < c.MaxHitPoints))
                {
                    <option value="@c.Id">@c.Name (ОЗ: @c.CurrentHitPoints / @c.MaxHitPoints@(c.IsDying ? " — ПРИ СМЕРТИ" : ""))</option>
                }
            </select>
        </div>

        @if (_target != null)
        {
            // Отображаем состояние цели
            @if (_target.IsDying)
            {
                <div class="bg-red-50 border border-red-300 rounded-md p-2 mb-3 text-xs text-red-800">
                    ⚠ @_target.Name при смерти! Успешная первая помощь остановит умирание,
                    но не восстановит ОЗ. Также требуется проверка ВЫН для стабилизации.
                </div>
            }

            <!-- Навык первой помощи -->
            <div class="mb-3">
                <label class="block text-xs font-medium text-gray-600 mb-1">Навык «Первая помощь» @_healer.Name</label>
                <input type="number" min="1" max="100" @bind="_firstAidSkill"
                       class="border border-primary-300 rounded-md px-2 py-1 text-sm w-full focus:outline-none focus:ring-1 focus:ring-accent-500/25 focus:border-accent-500" />
            </div>

            <!-- Бросок -->
            <div class="mb-3 border-t border-gray-200 pt-3">
                <div class="text-xs font-semibold text-gray-700 mb-2 uppercase tracking-wide">Бросок</div>
                <div class="flex items-center gap-2">
                    <label class="text-xs font-medium text-gray-600 w-36 shrink-0">d100 (@_healer.Name)</label>
                    <input type="number" min="1" max="100"
                           value="@_roll"
                           @oninput="OnRollInput"
                           class="border border-primary-300 rounded-md px-2 py-1 text-sm w-20 focus:outline-none"
                           placeholder="1–100" />
                    <button @onclick="AutoRoll" class="text-xs px-2 py-1 rounded bg-gray-100 hover:bg-gray-200 text-gray-600">🎲 авто</button>
                </div>
                @if (_roll.HasValue)
                {
                    var success = _roll.Value <= _firstAidSkill;
                    <div class="mt-1 ml-36 text-xs font-medium @(success ? "text-green-700" : "text-red-700")">
                        → @(_roll.Value) / @_firstAidSkill — @(success ? "успех!" : "неудача")
                    </div>
                }
            </div>

            <!-- Предпросмотр результата -->
            @if (_roll.HasValue)
            {
                var success = _roll.Value <= _firstAidSkill;
                <div class="bg-@(success ? "green" : "red")-50 border border-@(success ? "green" : "red")-200 rounded-md p-3 mb-3">
                    @if (success)
                    {
                        @if (_target.IsDying)
                        {
                            <div class="text-sm font-semibold text-green-700">✓ Умирание остановлено</div>
                            <div class="text-xs text-gray-600 mt-0.5">@_target.Name стабилизирован (ОЗ не восстанавливаются)</div>
                        }
                        else
                        {
                            <div class="text-sm font-semibold text-green-700">✓ +1 ОЗ (@_target.Name: @_target.CurrentHitPoints → @Math.Min(_target.CurrentHitPoints + 1, _target.MaxHitPoints))</div>
                        }
                    }
                    else
                    {
                        <div class="text-sm font-semibold text-red-700">✗ Первая помощь не удалась</div>
                    }
                </div>

                <div class="flex gap-2">
                    <button type="button" class="cm-btn cm-btn-primary w-full" @onclick="Apply" disabled="@(!success)">
                        <span>Применить</span>
                    </button>
                    <button type="button" class="cm-btn cm-btn-secondary w-full" @onclick="Reset">
                        <span>Сброс</span>
                    </button>
                </div>
            }
            else
            {
                <p class="text-xs text-gray-400 text-center">Введите бросок для оценки результата</p>
            }
        }
    }
</div>

@code {
    [Parameter] public List<Combatant> Combatants { get; set; } = [];
    [Parameter] public EventCallback<(Combatant target, bool isDying, CombatActionResult logEntry)> OnFirstAidApplied { get; set; }
    [Parameter] public Guid? ActiveCombatantId { get; set; }

    private Guid? _lastActiveId;

    protected override void OnParametersSet()
    {
        if (ActiveCombatantId.HasValue && ActiveCombatantId != _lastActiveId)
        {
            _lastActiveId = ActiveCombatantId;
            var active = Combatants.FirstOrDefault(c => c.Id == ActiveCombatantId.Value && !c.IsDead);
            if (active != null) { _healerId = active.Id.ToString(); _healer = active; _roll = null; }
        }
    }

    private string _healerId = "";
    private string _targetId = "";
    private Combatant? _healer;
    private Combatant? _target;
    private int _firstAidSkill = 30;
    private int? _roll;

    private void OnHealerChanged(ChangeEventArgs e)
    {
        _healerId = e.Value?.ToString() ?? "";
        _healer = Guid.TryParse(_healerId, out var id) ? Combatants.FirstOrDefault(c => c.Id == id) : null;
        _roll = null;
    }

    private void OnTargetChanged(ChangeEventArgs e)
    {
        _targetId = e.Value?.ToString() ?? "";
        _target = Guid.TryParse(_targetId, out var id) ? Combatants.FirstOrDefault(c => c.Id == id) : null;
        _roll = null;
    }

    private void OnRollInput(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var v))
            _roll = Math.Clamp(v, 1, 100);
    }

    private void AutoRoll()
    {
        _roll = CombatService.RollD100();
    }

    private async Task Apply()
    {
        if (_target == null || !_roll.HasValue) return;
        var success = _roll.Value <= _firstAidSkill;
        if (!success) return;

        var wasDying = _target.IsDying;
        var hpBefore = _target.CurrentHitPoints;

        if (wasDying)
        {
            _target.IsDying = false; // стабилизация
        }
        else
        {
            _target.CurrentHitPoints = Math.Min(_target.CurrentHitPoints + 1, _target.MaxHitPoints);
        }

        var logEntry = new CombatActionResult
        {
            Round = CombatService.CurrentRound,
            AttackerId = _healer!.Id,
            AttackerName = _healer.Name,
            ActionType = CombatActionType.FirstAid,
            DefenderId = _target.Id,
            DefenderName = _target.Name,
            DefenderHpBefore = hpBefore,
            DefenderHpAfter = _target.CurrentHitPoints,
            AttackerRoll = _roll.Value,
            AttackerSkillValue = _firstAidSkill,
            AttackerSuccessLevel = SuccessLevel.RegularSuccess,
            AttackerWins = true,
            Summary = wasDying
                ? $"{_healer.Name} оказывает первую помощь {_target.Name}: бросок {_roll.Value}/{_firstAidSkill} — успех. Умирание остановлено."
                : $"{_healer.Name} оказывает первую помощь {_target.Name}: бросок {_roll.Value}/{_firstAidSkill} — успех. +1 ОЗ ({hpBefore}→{_target.CurrentHitPoints})."
        };

        await OnFirstAidApplied.InvokeAsync((_target, wasDying, logEntry));
        Reset();
    }

    private void Reset()
    {
        _roll = null;
    }
}

@using CampaignManager.Web.Components.Features.Combat.Model
@using CampaignManager.Web.Components.Features.Combat.Services

@inject CombatService CombatService

<div>
    <h4 class="text-base font-semibold text-gray-900 mb-3">Медицина</h4>

    <div class="bg-green-50 border border-green-200 rounded-md p-2 mb-3 text-xs text-green-800">
        CoC 7e: Медицина — минимум 1 час. Успех: +1d3 ОЗ. Для умирающих: сначала требуется успешная Первая помощь, затем Медицина снимает статус «При смерти» и даёт +1d3 ОЗ.
    </div>

    <!-- Врач -->
    <div class="mb-3">
        <label class="block text-xs font-medium text-gray-600 mb-1">Врач / медик</label>
        <select class="border border-primary-300 rounded-md px-2 py-1.5 text-sm text-primary-700 bg-primary-50 w-full focus:outline-none focus:ring-1 focus:ring-accent-500/25 focus:border-accent-500"
                value="@_doctorId"
                @onchange="OnDoctorChanged">
            <option value="">— Выберите —</option>
            @foreach (var c in Combatants.Where(c => !c.IsDead))
            {
                <option value="@c.Id">@c.Name</option>
            }
        </select>
    </div>

    @if (_doctor != null)
    {
        <!-- Цель -->
        <div class="mb-3">
            <label class="block text-xs font-medium text-gray-600 mb-1">Пациент</label>
            <select class="border border-primary-300 rounded-md px-2 py-1.5 text-sm text-primary-700 bg-primary-50 w-full focus:outline-none focus:ring-1 focus:ring-accent-500/25 focus:border-accent-500"
                    value="@_targetId"
                    @onchange="OnTargetChanged">
                <option value="">— Выберите —</option>
                @foreach (var c in Combatants.Where(c => !c.IsDead && (c.CurrentHitPoints < c.MaxHitPoints || c.IsDying)))
                {
                    <option value="@c.Id">@c.Name (ОЗ: @c.CurrentHitPoints/@c.MaxHitPoints@(c.IsDying ? " — ПРИ СМЕРТИ" : ""))</option>
                }
            </select>
        </div>

        @if (_target != null)
        {
            @if (_target.IsDying)
            {
                <div class="bg-red-50 border border-red-300 rounded-md p-2 mb-3 text-xs text-red-800">
                    ⚠ @_target.Name при смерти! Сначала оказывается Первая помощь. При успехе Медицины: снять статус «При смерти», +1d3 ОЗ.
                </div>
            }

            <!-- Навык -->
            <div class="mb-3">
                <label class="block text-xs font-medium text-gray-600 mb-1">Навык «Медицина» @_doctor.Name</label>
                <input type="number" min="1" max="100" @bind="_medicineSkill"
                       class="border border-primary-300 rounded-md px-2 py-1 text-sm w-full focus:outline-none" />
            </div>

            <!-- Бросок -->
            <div class="mb-3 border-t border-gray-200 pt-3">
                <div class="text-xs font-semibold text-gray-700 mb-2 uppercase tracking-wide">Бросок d100</div>
                <div class="flex items-center gap-2">
                    <label class="text-xs font-medium text-gray-600 w-32 shrink-0">d100 (@_doctor.Name)</label>
                    <input type="number" min="1" max="100"
                           value="@_skillRoll"
                           @oninput="OnSkillRollInput"
                           class="border border-primary-300 rounded-md px-2 py-1 text-sm w-20 focus:outline-none"
                           placeholder="1–100" />
                    <button @onclick="AutoSkillRoll" class="text-xs px-2 py-1 rounded bg-gray-100 hover:bg-gray-200 text-gray-600">🎲 авто</button>
                </div>
                @if (_skillRoll.HasValue)
                {
                    var success = _skillRoll.Value <= _medicineSkill;
                    <div class="mt-1 ml-32 text-xs font-medium @(success ? "text-green-700" : "text-red-700")">
                        → @_skillRoll.Value / @_medicineSkill — @(success ? "успех!" : "неудача")
                    </div>
                }
            </div>

            @if (_skillRoll.HasValue && _skillRoll.Value <= _medicineSkill)
            {
                <!-- Бросок лечения -->
                <div class="mb-3">
                    <div class="text-xs font-semibold text-gray-700 mb-2 uppercase tracking-wide">Бросок лечения (1d3 ОЗ)</div>
                    <div class="flex items-center gap-2">
                        <label class="text-xs font-medium text-gray-600 w-32 shrink-0">1d3</label>
                        <input type="number" min="1" max="3"
                               value="@_healRoll"
                               @oninput="OnHealRollInput"
                               class="border border-primary-300 rounded-md px-2 py-1 text-sm w-20 focus:outline-none"
                               placeholder="1–3" />
                        <button @onclick="AutoHealRoll" class="text-xs px-2 py-1 rounded bg-gray-100 hover:bg-gray-200 text-gray-600">🎲 авто</button>
                    </div>
                </div>
            }

            @if (_skillRoll.HasValue)
            {
                var success = _skillRoll.Value <= _medicineSkill;
                <div class="rounded-md p-3 mb-3 @(success ? "bg-green-50 border border-green-200" : "bg-red-50 border border-red-200")">
                    @if (success && _healRoll.HasValue)
                    {
                        var newHp = Math.Min(_target.CurrentHitPoints + _healRoll.Value, _target.MaxHitPoints);
                        @if (_target.IsDying)
                        {
                            <div class="text-sm font-semibold text-green-700">✓ Медицина успешна</div>
                            <div class="text-xs text-gray-600 mt-0.5">Статус «При смерти» снят. ОЗ: @_target.CurrentHitPoints → @newHp (+@_healRoll.Value)</div>
                        }
                        else
                        {
                            <div class="text-sm font-semibold text-green-700">✓ +@_healRoll.Value ОЗ (@_target.Name: @_target.CurrentHitPoints → @newHp)</div>
                        }
                    }
                    else if (success)
                    {
                        <div class="text-sm font-semibold text-green-700">✓ Успех — введите бросок лечения (1d3)</div>
                    }
                    else
                    {
                        <div class="text-sm font-semibold text-red-700">✗ Медицина не помогла</div>
                    }
                </div>

                <div class="flex gap-2">
                    <button type="button" class="cm-btn cm-btn-primary w-full" @onclick="Apply"
                            disabled="@(!success || !_healRoll.HasValue)">
                        <span>Применить</span>
                    </button>
                    <button type="button" class="cm-btn cm-btn-secondary w-full" @onclick="Reset">
                        <span>Сброс</span>
                    </button>
                </div>
            }
            else
            {
                <p class="text-xs text-gray-400 text-center">Введите бросок навыка</p>
            }
        }
    }
</div>

@code {
    [Parameter] public List<Combatant> Combatants { get; set; } = [];
    [Parameter] public EventCallback<CombatActionResult> OnMedicineApplied { get; set; }
    [Parameter] public Guid? ActiveCombatantId { get; set; }

    private Guid? _lastActiveId;

    protected override void OnParametersSet()
    {
        if (ActiveCombatantId.HasValue && ActiveCombatantId != _lastActiveId)
        {
            _lastActiveId = ActiveCombatantId;
            var active = Combatants.FirstOrDefault(c => c.Id == ActiveCombatantId.Value && !c.IsDead);
            if (active != null) { _doctorId = active.Id.ToString(); _doctor = active; Reset(); }
        }
    }

    private string _doctorId = "";
    private string _targetId = "";
    private Combatant? _doctor;
    private Combatant? _target;
    private int _medicineSkill = 30;
    private int? _skillRoll;
    private int? _healRoll;

    private void OnDoctorChanged(ChangeEventArgs e)
    {
        _doctorId = e.Value?.ToString() ?? "";
        _doctor = Guid.TryParse(_doctorId, out var id) ? Combatants.FirstOrDefault(c => c.Id == id) : null;
        Reset();
    }

    private void OnTargetChanged(ChangeEventArgs e)
    {
        _targetId = e.Value?.ToString() ?? "";
        _target = Guid.TryParse(_targetId, out var id) ? Combatants.FirstOrDefault(c => c.Id == id) : null;
        _skillRoll = null;
        _healRoll = null;
    }

    private void OnSkillRollInput(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var v)) _skillRoll = Math.Clamp(v, 1, 100);
    }

    private void OnHealRollInput(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var v)) _healRoll = Math.Clamp(v, 1, 3);
    }

    private void AutoSkillRoll() => _skillRoll = CombatService.RollD100();
    private void AutoHealRoll() => _healRoll = CombatService.RollDice(3);

    private async Task Apply()
    {
        if (_target == null || _doctor == null || !_skillRoll.HasValue || !_healRoll.HasValue) return;
        if (_skillRoll.Value > _medicineSkill) return;

        var hpBefore = _target.CurrentHitPoints;
        var wasDying = _target.IsDying;

        if (wasDying)
        {
            _target.IsDying = false;
        }
        _target.CurrentHitPoints = Math.Min(_target.CurrentHitPoints + _healRoll.Value, _target.MaxHitPoints);

        var logEntry = new CombatActionResult
        {
            Round = CombatService.CurrentRound,
            AttackerId = _doctor.Id,
            AttackerName = _doctor.Name,
            ActionType = CombatActionType.Medicine,
            DefenderId = _target.Id,
            DefenderName = _target.Name,
            DefenderHpBefore = hpBefore,
            DefenderHpAfter = _target.CurrentHitPoints,
            AttackerRoll = _skillRoll.Value,
            AttackerSkillValue = _medicineSkill,
            AttackerSuccessLevel = CombatService.CalculateSuccessLevel(_skillRoll.Value, _medicineSkill),
            AttackerWins = true,
            Summary = wasDying
                ? $"{_doctor.Name} применяет Медицину на {_target.Name}: {_skillRoll.Value}/{_medicineSkill} — успех. Статус «При смерти» снят. ОЗ: {hpBefore}→{_target.CurrentHitPoints} (+{_healRoll.Value})."
                : $"{_doctor.Name} применяет Медицину на {_target.Name}: {_skillRoll.Value}/{_medicineSkill} — успех. +{_healRoll.Value} ОЗ ({hpBefore}→{_target.CurrentHitPoints})."
        };

        await OnMedicineApplied.InvokeAsync(logEntry);
        Reset();
    }

    private void Reset()
    {
        _skillRoll = null;
        _healRoll = null;
    }
}

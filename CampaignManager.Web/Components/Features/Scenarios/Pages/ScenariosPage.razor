@page "/scenarios"
@using CampaignManager.Web.Components.Features.Scenarios.Model
@using CampaignManager.Web.Components.Features.Scenarios.Services
@using CampaignManager.Web.Utilities.Services
@attribute [Authorize]
@inject ScenarioService ScenarioService
@inject NavigationManager NavigationManager
@inject ILogger<ScenariosPage> Logger
@inject IdentityService IdentityService
@rendermode InteractiveServer
<PageTitle>Шаблоны сценариев</PageTitle>

@if (!_isKeeper)
{
    <div class="max-w-7xl mx-auto px-4 py-6">
        <Alert Type="error" Title="Доступ запрещён">
            Эта страница доступна только для Хранителя.
        </Alert>
    </div>
}
else
{
<div class="container mx-auto px-4 py-8">
    <div class="flex justify-between items-center mb-6">
        <h1 class="text-3xl font-bold">Шаблоны сценариев</h1>
        <button type="button" class="cm-btn cm-btn-info" @onclick="@(() => NavigationManager.NavigateTo("/scenarios/new"))">
            <i class="fas fa-plus"></i> <span>Новый шаблон</span>
        </button>
    </div>

    @if (_loading)
    {
        <div class="flex justify-center items-center h-64">
            <div class="animate-spin rounded-full h-12 w-12 border-t-2 border-b-2 border-blue-500"></div>
        </div>
    }
    else if (_scenarios.Count == 0)
    {
        <div class="bg-white shadow-md rounded-lg p-6 text-center">
            <p class="text-lg text-gray-600 mb-4">Шаблонов нет.</p>
            <p class="text-gray-500">Создайте новый шаблон.</p>
        </div>
    }
    else
    {
        <div class="mb-4">
            <input type="search" placeholder="Поиск по названию..."
                   class="w-full px-4 py-2 border border-primary-300 bg-primary-50 rounded-md focus:outline-none focus:ring-2 focus:ring-accent-500/25 focus:border-accent-500 hover:border-primary-400 hover:bg-white transition-colors"
                   @bind="_searchTerm" @bind:event="oninput"/>
        </div>

        @if (!FilteredScenarios.Any())
        {
            <div class="bg-white shadow-md rounded-lg p-6 text-center">
                <p class="text-gray-500">Шаблоны не найдены.</p>
            </div>
        }
        else
        {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var scenario in FilteredScenarios)
            {
                <div
                    class="bg-white shadow-md rounded-md overflow-hidden hover:shadow-lg transition-shadow duration-300 flex flex-col h-full">
                    <div class="p-4 flex-grow">
                        <h2 class="cm-h4 mb-3">@scenario.Name</h2>

                        <div class="flex items-center text-sm text-gray-600 mb-3">
                            @if (!string.IsNullOrEmpty(scenario.Era) || !string.IsNullOrEmpty(scenario.Location))
                            {
                                <div class="flex space-x-2">
                                    @if (!string.IsNullOrEmpty(scenario.Era))
                                    {
                                        <span
                                            class="inline-block bg-secondary-100 text-secondary-800 rounded-md px-2 py-0.5 cm-text-sm">
                                            @scenario.Era
                                        </span>
                                    }
                                    @if (!string.IsNullOrEmpty(scenario.Location))
                                    {
                                        <span
                                            class="inline-block bg-primary-100 text-primary-800 rounded-md px-2 py-0.5 cm-text-sm">
                                            @scenario.Location
                                        </span>
                                    }
                                </div>
                            }
                        </div>

                        <p class="cm-text-body text-gray-600 line-clamp-3">
                            @(string.IsNullOrEmpty(scenario.Description)
                                ? "Описание отсутствует."
                                : scenario.Description)
                        </p>
                    </div>
                    <div class="bg-gray-50 px-4 py-3 mt-auto border-t border-gray-100 flex flex-col gap-1.5">
                        <button type="button" class="cm-btn cm-btn-secondary cm-btn-sm w-full justify-center" @onclick="@(() => NavigationManager.NavigateTo($"/scenarios/{scenario.Id}"))">
                            <i class="fas fa-eye"></i> <span>Просмотр</span>
                        </button>
                        <div class="grid grid-cols-2 gap-1.5">
                            <button type="button" class="cm-btn cm-btn-info cm-btn-sm justify-center" @onclick="@(() => NavigationManager.NavigateTo($"/scenarios/{scenario.Id}/edit"))">
                                <i class="fas fa-edit"></i> <span>Редактировать</span>
                            </button>
                            <button type="button" class="cm-btn cm-btn-error cm-btn-sm justify-center" @onclick="@(() => ConfirmDelete(scenario))">
                                <i class="fas fa-trash"></i> <span>Удалить</span>
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
        }
    }
</div>

<!-- Delete Confirmation Modal -->
<ConfirmationModal IsVisible="_showDeleteModal"
                   OnConfirm="DeleteScenario"
                   OnCancel="@(() => { _showDeleteModal = false; _scenarioToDelete = null; })"
                   Title="Подтверждение удаления"
                   Message="@($"Вы уверены что хотите удалить шаблон сценария \"{_scenarioToDelete?.Name}\"?")"
                   ConfirmText="Удалить"
                   IconType="error" />
}

@code {
    private List<Scenario> _scenarios = [];
    private bool _loading = true;
    private bool _showDeleteModal;
    private Scenario? _scenarioToDelete;
    private string _searchTerm = string.Empty;
    private bool _isKeeper;

    private IEnumerable<Scenario> FilteredScenarios => string.IsNullOrWhiteSpace(_searchTerm)
        ? _scenarios
        : _scenarios.Where(s => s.Name.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        _isKeeper = await IdentityService.IsKeeper();
        await LoadScenarios();
    }

    private async Task LoadScenarios()
    {
        try
        {
            _loading = true;
            _scenarios = await ScenarioService.GetAllScenariosAsync(true);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading scenario templates");
        }
        finally
        {
            _loading = false;
        }
    }

    private void ConfirmDelete(Scenario scenario)
    {
        _scenarioToDelete = scenario;
        _showDeleteModal = true;
    }

    private async Task DeleteScenario()
    {
        if (_scenarioToDelete is null)
        {
            return;
        }

        try
        {
            var success = await ScenarioService.DeleteScenarioAsync(_scenarioToDelete.Id);
            if (success)
            {
                await LoadScenarios();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error deleting scenario {ScenarioId}", _scenarioToDelete.Id);
        }
        finally
        {
            _showDeleteModal = false;
            _scenarioToDelete = null;
        }
    }

}

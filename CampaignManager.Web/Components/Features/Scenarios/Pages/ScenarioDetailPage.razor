@page "/scenarios/{Id:guid}"
@using CampaignManager.Web.Components.Features.Campaigns.Models
@using CampaignManager.Web.Components.Features.Campaigns.Services
@using CampaignManager.Web.Components.Features.Scenarios.Model
@using CampaignManager.Web.Components.Features.Scenarios.Services
@using CampaignManager.Web.Utilities.Services
@using CampaignManager.Web.Components.Features.NPC.Components
@using CampaignManager.Web.Model
@using CampaignManager.Web.Components.Features.Characters.Services
@using CampaignManager.Web.Components.Features.Scenarios.Components
@using CampaignManager.Web.Components.Features.Bestiary.Model
@attribute [Authorize]
@inject ScenarioService ScenarioService
@inject NavigationManager NavigationManager
@inject ILogger<ScenarioDetailPage> Logger
@inject CampaignService CampaignService
@inject MarkdownService MarkdownService
@inject IdentityService IdentityService
@inject CharacterService CharacterService
@rendermode InteractiveServer
<PageTitle>@(_scenario?.Name ?? "Сценарий")</PageTitle>

@if (!_isKeeper)
{
    <div class="max-w-7xl mx-auto px-4 py-6">
        <Alert Type="error" Title="Доступ запрещён">
            Эта страница доступна только для Хранителя.
        </Alert>
    </div>
}
else
{
@if (_loading)
{
    <div class="flex justify-center items-center h-64">
        <div class="animate-spin rounded-full h-12 w-12 border-t-2 border-b-2 border-blue-500"></div>
    </div>
}
else if (_scenario is null)
{
    <div class="container mx-auto px-4 py-8">
        <div class="bg-white shadow-md rounded-lg p-6 text-center">
            <h2 class="text-xl font-semibold text-gray-700 mb-4">Сценарий не найден</h2>
            <p class="text-gray-600 mb-4">Запрошенный сценарий не найден.</p>
            <button type="button" class="cm-btn cm-btn-info" @onclick="@(() => NavigationManager.NavigateTo("/scenarios"))">
                <span>К сценариям</span>
            </button>
        </div>
    </div>
}
else if (_viewMode == "play" && _scenario.Locations.Count > 0)
{
    <!-- Play Mode: Three-panel layout -->
    <div class="flex flex-col h-screen">
        <!-- Top toolbar -->
        <div class="flex items-center justify-between px-4 py-2 bg-white border-b border-gray-200 flex-shrink-0">
            <div class="flex items-center gap-3">
                <button type="button" class="cm-btn cm-btn-secondary cm-btn-sm" @onclick="@(() => NavigationManager.NavigateTo("/scenarios"))">
                    <i class="fas fa-arrow-left"></i>
                </button>
                <h1 class="text-lg font-bold text-gray-800 truncate">@_scenario.Name</h1>
                @if (!string.IsNullOrEmpty(_scenario.Era))
                {
                    <span class="text-sm text-gray-500">@_scenario.Era</span>
                }
            </div>
            <div class="flex items-center gap-2">
                <button type="button"
                        class="cm-btn cm-btn-secondary cm-btn-sm"
                        @onclick='() => _viewMode = "overview"'>
                    <i class="fas fa-th-large mr-1"></i> Обзор
                </button>
                <button type="button"
                        class="cm-btn cm-btn-info cm-btn-sm"
                        @onclick="@(() => NavigationManager.NavigateTo($"/scenarios/{Id}/edit"))">
                    <i class="fas fa-edit mr-1"></i> Редактировать
                </button>
            </div>
        </div>

        <!-- Three-panel content -->
        <div class="flex flex-1 overflow-hidden">
            <!-- Left: Location Sidebar -->
            <div class="w-64 flex-shrink-0">
                <LocationSidebar Locations="_scenario.Locations"
                                 SelectedLocationId="_selectedLocationId"
                                 OnLocationSelected="HandleLocationSelected"/>
            </div>

            <!-- Center: Location Detail / Overview -->
            <div class="flex-1 overflow-hidden">
                @if (_selectedLocationId is null)
                {
                    <!-- Overview: show scenario description + journal -->
                    <div class="h-full overflow-y-auto p-6">
                        @if (!string.IsNullOrEmpty(_scenario.Description))
                        {
                            <div class="mb-6">
                                <h2 class="text-xl font-semibold mb-2">Описание</h2>
                                <div class="bg-gray-50 p-4 rounded-lg">
                                    <p class="text-gray-700">@_scenario.Description</p>
                                </div>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(_scenario.Journal))
                        {
                            <div class="mb-6">
                                <h2 class="text-xl font-semibold mb-2">Журнал</h2>
                                <div class="bg-gray-50 p-4 rounded-lg markdown-content">
                                    @((MarkupString)_markdownHtml)
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <LocationDetail Location="_selectedLocation"
                                    ScenarioCreatures="_scenario.ScenarioCreatures"
                                    ScenarioItems="_scenario.ScenarioItems"
                                    Npcs="_characterTemplates"
                                    Handouts="_scenario.Handouts"/>
                }
            </div>

            <!-- Right: Key Facts Panel -->
            @if (!_keyFactsPanelCollapsed)
            {
                <div class="w-80 flex-shrink-0">
                    <KeyFactsPanel KeyFacts="_scenario.KeyFacts"
                                   Handouts="_scenario.Handouts"
                                   OnToggleCollapse="() => _keyFactsPanelCollapsed = true"/>
                </div>
            }
            else
            {
                <div class="flex-shrink-0 border-l border-gray-200 bg-white">
                    <button type="button" class="p-3 text-gray-400 hover:text-gray-600"
                            @onclick="() => _keyFactsPanelCollapsed = false"
                            title="Показать ключевые факты">
                        <i class="fas fa-chevron-left"></i>
                    </button>
                </div>
            }
        </div>
    </div>
}
else
{
    <!-- Overview Mode: Original card-based layout -->
    <div class="container mx-auto px-4 py-8">
        <div class="flex justify-between items-center mb-6">
            <div>
                <button type="button" class="cm-btn cm-btn-secondary" @onclick="@(() => NavigationManager.NavigateTo("/scenarios"))">
                    <i class="fas fa-arrow-left"></i> <span>Сценарии</span>
                </button>
            </div>
            <div class="flex gap-2">
                @if (_scenario.Locations.Count > 0)
                {
                    <button type="button" class="cm-btn cm-btn-success" @onclick='() => _viewMode = "play"'>
                        <i class="fas fa-map-marked-alt"></i> <span>Режим игры</span>
                    </button>
                }
                <button type="button" class="cm-btn cm-btn-info" @onclick="@(() => NavigationManager.NavigateTo($"/scenarios/{Id}/edit"))">
                    <i class="fas fa-edit"></i> <span>Редактировать</span>
                </button>
                @if (_scenario.IsTemplate)
                {
                    <button type="button" class="cm-btn cm-btn-success" @onclick="ShowUseCampaignModal">
                        <i class="fas fa-clipboard"></i> <span>Добавить в кампанию</span>
                    </button>
                }
            </div>
        </div>

        <div class="bg-white shadow-md rounded-lg overflow-hidden mb-8">
            <div class="p-6">
                <h1 class="text-3xl font-bold mb-4">@_scenario.Name</h1>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                    <div>
                        @if (!string.IsNullOrEmpty(_scenario.Era))
                        {
                            <div class="mb-2">
                                <span class="font-semibold text-gray-700">Эпоха:</span>
                                <span class="text-gray-600 ml-2">@_scenario.Era</span>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(_scenario.Location))
                        {
                            <div class="mb-2">
                                <span class="font-semibold text-gray-700">Город:</span>
                                <span class="text-gray-600 ml-2">@_scenario.Location</span>
                            </div>
                        }
                    </div>
                    <div>
                        <div class="mb-2">
                            <span class="font-semibold text-gray-700">Тип:</span>
                            <span class="text-gray-600 ml-2">@(_scenario.IsTemplate ? "Шаблон" : "Сценарий кампании")</span>
                        </div>

                        @if (_scenario.CampaignId.HasValue)
                        {
                            <div class="mb-2">
                                <span class="font-semibold text-gray-700">Кампания:</span>
                                <a href="/campaigns/@_scenario.CampaignId" class="text-blue-600 hover:underline ml-2">
                                    @(_scenario.Campaign?.Name ?? "Перейти к кампании")
                                </a>
                            </div>
                        }
                    </div>
                </div>

                <div class="mb-6">
                    <h2 class="text-xl font-semibold mb-2">Описание</h2>
                    <div class="bg-gray-50 p-4 rounded-lg">
                        <p class="text-gray-700">
                            @(_scenario.Description ?? "Описание отсутствует.")
                        </p>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(_scenario.Journal))
                {
                    <div class="mb-6">
                        <h2 class="text-xl font-semibold mb-2">Журнал</h2>
                        <div class="bg-gray-50 p-4 rounded-lg markdown-content">
                            @((MarkupString)_markdownHtml)
                        </div>
                    </div>
                }

                <!-- Structured content summary -->
                @if (_scenario.Locations.Count > 0 || _scenario.KeyFacts.Count > 0 || _scenario.Handouts.Count > 0)
                {
                    <div class="border-t border-gray-200 pt-6 mt-6">
                        <h2 class="text-xl font-semibold mb-4">Структурированный контент</h2>
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                            @if (_scenario.Locations.Count > 0)
                            {
                                <div class="bg-accent-50 rounded-lg p-4">
                                    <h3 class="font-semibold text-accent-700 mb-2">
                                        <i class="fas fa-map-marker-alt mr-1"></i>Локации
                                    </h3>
                                    <ul class="text-sm text-gray-600 space-y-1">
                                        @foreach (var loc in _scenario.Locations.Where(l => l.ParentLocationId is null).OrderBy(l => l.Order))
                                        {
                                            <li>@loc.Name</li>
                                        }
                                    </ul>
                                </div>
                            }
                            @if (_scenario.KeyFacts.Count > 0)
                            {
                                <div class="bg-amber-50 rounded-lg p-4">
                                    <h3 class="font-semibold text-amber-700 mb-2">
                                        <i class="fas fa-key mr-1"></i>Ключевые факты
                                    </h3>
                                    <p class="text-sm text-gray-600">@_scenario.KeyFacts.Count фактов</p>
                                </div>
                            }
                            @if (_scenario.Handouts.Count > 0)
                            {
                                <div class="bg-purple-50 rounded-lg p-4">
                                    <h3 class="font-semibold text-purple-700 mb-2">
                                        <i class="fas fa-file-image mr-1"></i>Раздатки
                                    </h3>
                                    <ul class="text-sm text-gray-600 space-y-1">
                                        @foreach (var h in _scenario.Handouts.OrderBy(h => h.Order))
                                        {
                                            <li>@h.Name</li>
                                        }
                                    </ul>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Character Templates Section -->
            <div class="bg-white shadow-md rounded-lg overflow-hidden">
                <div class="bg-gray-100 px-6 py-4 border-b border-gray-200">
                    <div class="flex justify-between items-center">
                        <h2 class="text-lg font-semibold">Шаблоны персонажей</h2>
                        <button type="button" class="cm-btn cm-btn-info cm-btn-sm" @onclick="ShowAddNpcModal">
                            <i class="fas fa-plus"></i> <span>Добавить</span>
                        </button>
                    </div>
                </div>
                <div class="p-4">
                    @if (_characterTemplates.Count == 0)
                    {
                        <p class="text-gray-500 text-center py-4">Нет привязанных шаблонов персонажей.</p>
                    }
                    else
                    {
                        <div class="space-y-4">
                            @foreach (var template in _characterTemplates)
                            {
                                <CharacterTemplateCard Template="template" OnDelete="RemoveCharacterTemplate"/>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- Creatures Section -->
            <div class="bg-white shadow-md rounded-lg overflow-hidden">
                <div class="bg-gray-100 px-6 py-4 border-b border-gray-200">
                    <div class="flex justify-between items-center">
                        <h2 class="text-lg font-semibold">Существа</h2>
                        <button type="button" class="cm-btn cm-btn-info cm-btn-sm" @onclick="ShowAddCreatureModal">
                            <i class="fas fa-plus"></i> <span>Добавить</span>
                        </button>
                    </div>
                </div>
                <div class="p-4">
                    @if (_scenario.ScenarioCreatures.Count == 0)
                    {
                        <p class="text-gray-500 text-center py-4">Нет добавленных существ.</p>
                    }
                    else
                    {
                        <div class="divide-y divide-gray-200">
                            @foreach (var sc in _scenario.ScenarioCreatures)
                            {
                                <div class="py-3">
                                    <div class="flex justify-between items-start gap-2">
                                        <div class="flex-1 min-w-0">
                                            <div class="font-medium text-gray-800 truncate">@sc.Name</div>
                                            <div class="text-xs text-gray-500 mt-0.5">@sc.Type</div>
                                            @if (!string.IsNullOrEmpty(sc.Location))
                                            {
                                                <div class="text-xs text-gray-600 mt-0.5"><span class="font-medium">Место:</span> @sc.Location</div>
                                            }
                                            @if (!string.IsNullOrEmpty(sc.Notes))
                                            {
                                                <div class="text-xs text-gray-600 mt-0.5 truncate"><span class="font-medium">Заметки:</span> @sc.Notes</div>
                                            }
                                        </div>
                                        <div class="flex gap-1 flex-shrink-0">
                                            <button type="button" class="cm-btn cm-btn-info cm-btn-sm" title="Редактировать" @onclick="@(() => ShowEditCreatureModal(sc))"><i class="fas fa-edit"></i></button>
                                            <button type="button" class="cm-btn cm-btn-danger cm-btn-sm" title="Удалить" @onclick="@(() => RemoveCreature(sc))"><i class="fas fa-trash"></i></button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- Items Section -->
            <div class="bg-white shadow-md rounded-lg overflow-hidden">
                <div class="bg-gray-100 px-6 py-4 border-b border-gray-200">
                    <div class="flex justify-between items-center">
                        <h2 class="text-lg font-semibold">Предметы</h2>
                        <button type="button" class="cm-btn cm-btn-info cm-btn-sm" @onclick="ShowAddItemModal">
                            <i class="fas fa-plus"></i> <span>Добавить</span>
                        </button>
                    </div>
                </div>
                <div class="p-4">
                    @if (_scenario.ScenarioItems.Count == 0)
                    {
                        <p class="text-gray-500 text-center py-4">Нет добавленных предметов.</p>
                    }
                    else
                    {
                        <div class="divide-y divide-gray-200">
                            @foreach (var si in _scenario.ScenarioItems)
                            {
                                <div class="py-3">
                                    <div class="flex justify-between items-start gap-2">
                                        <div class="flex-1 min-w-0">
                                            <div class="font-medium text-gray-800 truncate">@si.Name</div>
                                            @if (!string.IsNullOrEmpty(si.Type))
                                            {
                                                <div class="text-xs text-gray-500 mt-0.5">@si.Type</div>
                                            }
                                            @if (!string.IsNullOrEmpty(si.Location))
                                            {
                                                <div class="text-xs text-gray-600 mt-0.5"><span class="font-medium">Место:</span> @si.Location</div>
                                            }
                                            @if (!string.IsNullOrEmpty(si.Notes))
                                            {
                                                <div class="text-xs text-gray-600 mt-0.5 truncate"><span class="font-medium">Заметки:</span> @si.Notes</div>
                                            }
                                        </div>
                                        <div class="flex gap-1 flex-shrink-0">
                                            <button type="button" class="cm-btn cm-btn-info cm-btn-sm" title="Редактировать" @onclick="@(() => ShowEditItemModal(si))"><i class="fas fa-edit"></i></button>
                                            <button type="button" class="cm-btn cm-btn-danger cm-btn-sm" title="Удалить" @onclick="@(() => RemoveItem(si))"><i class="fas fa-trash"></i></button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

<!-- Use in Campaign Modal -->
<Modal IsVisible="_showUseCampaignModal"
       OnClose="@(() => _showUseCampaignModal = false)"
       Title="Использовать в кампании"
       MaxWidth="md"
       MaxHeight="null">
    <ChildContent>
        <p class="mb-4">Выберите кампанию для добавления сценария:</p>

        @if (_campaigns.Count == 0)
        {
            <p class="text-gray-500">У вас нет кампаний. Сначала создайте кампанию.</p>
        }
        else
        {
            <div class="w-full">
                <select @bind="_selectedCampaignId"
                        class="w-full px-4 py-2 border border-primary-300 rounded-md bg-primary-50 focus:outline-none focus:ring-2 focus:ring-accent-500/25 focus:border-accent-500 hover:border-primary-400 hover:bg-white transition-colors">
                    <option value="@Guid.Empty">-- Выберите кампанию --</option>
                    @foreach (var campaign in _campaigns)
                    {
                        <option value="@campaign.Id">@campaign.Name</option>
                    }
                </select>
            </div>
        }
    </ChildContent>
    <FooterContent>
        <button type="button" class="cm-btn cm-btn-secondary" @onclick="@(() => _showUseCampaignModal = false)">
            <span>Отмена</span>
        </button>
        <button type="button" class="cm-btn cm-btn-success" disabled="@(_selectedCampaignId == Guid.Empty)" @onclick="AddToCampaign">
            <span>Добавить в кампанию</span>
        </button>
    </FooterContent>
</Modal>

<!-- Add NPC Modal -->
<AddNpcModal @ref="_addNpcModal"
             ScenarioId="Id"
             OnNpcAdded="HandleNpcAdded"/>

<!-- Add Creature Modal -->
<AddCreatureModal @ref="_addCreatureModal"
                  ScenarioId="Id"
                  OnCreatureAdded="HandleCreatureAdded"/>

<!-- Edit Creature Modal -->
<EditCreatureModal @ref="_editCreatureModal"
                   OnCreatureUpdated="HandleCreatureUpdated"/>

<!-- Add Item Modal -->
<AddItemModal @ref="_addItemModal"
              ScenarioId="Id"
              OnItemAdded="HandleItemAdded"/>

<!-- Edit Item Modal -->
<EditItemModal @ref="_editItemModal"
               OnItemUpdated="HandleItemUpdated"/>
}

@code {

    [Parameter] public Guid Id { get; set; }

    private Scenario? _scenario;
    private bool _loading = true;
    private string _markdownHtml = "";
    private bool _isKeeper;
    private string _viewMode = "overview";
    private bool _showUseCampaignModal;
    private List<Campaign> _campaigns = [];
    private Guid _selectedCampaignId = Guid.Empty;
    private List<CharacterStorageDto> _characterTemplates = [];

    // Play mode state
    private Guid? _selectedLocationId;
    private bool _keyFactsPanelCollapsed;

    private ScenarioLocation? _selectedLocation =>
        _selectedLocationId.HasValue
            ? _scenario?.Locations.FirstOrDefault(l => l.Id == _selectedLocationId.Value)
            : null;

    // Modal references
    private AddNpcModal? _addNpcModal;
    private AddCreatureModal? _addCreatureModal;
    private EditCreatureModal? _editCreatureModal;
    private AddItemModal? _addItemModal;
    private EditItemModal? _editItemModal;

    protected override async Task OnInitializedAsync()
    {
        _isKeeper = await IdentityService.IsKeeper();
        await LoadScenario();
    }

    private async Task LoadScenario()
    {
        try
        {
            _loading = true;

            var scenarioTask = ScenarioService.GetScenarioByIdAsync(Id);
            var templatesTask = CharacterService.GetCharacterTemplatesByScenarioIdAsync(Id);

            await Task.WhenAll(scenarioTask, templatesTask);

            _scenario = scenarioTask.Result;
            _characterTemplates = templatesTask.Result;

            if (_scenario?.Journal is not null)
            {
                _markdownHtml = MarkdownService.ConvertToHtml(_scenario.Journal);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading scenario {ScenarioId}", Id);
        }
        finally
        {
            _loading = false;
        }
    }

    private void HandleLocationSelected(Guid? locationId)
    {
        _selectedLocationId = locationId;
    }

    private async Task ShowUseCampaignModal()
    {
        try
        {
            _campaigns = await CampaignService.GetAvailableCompaniesAsync();
            _selectedCampaignId = Guid.Empty;
            _showUseCampaignModal = true;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading campaigns for modal");
            _campaigns = [];
            _showUseCampaignModal = true;
        }
    }

    private async Task AddToCampaign()
    {
        if (_selectedCampaignId == Guid.Empty || _scenario is null)
        {
            return;
        }

        try
        {
            var userEmail = IdentityService.GetCurrentUserEmail() ?? string.Empty;

            var newScenario = await ScenarioService.CreateScenarioFromTemplateAsync(Id, _selectedCampaignId, userEmail);

            if (newScenario is not null)
            {
                NavigationManager.NavigateTo($"/scenarios/{newScenario.Id}");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error adding scenario to campaign");
        }
        finally
        {
            _showUseCampaignModal = false;
        }
    }

    private async Task RemoveCharacterTemplate(CharacterStorageDto template)
    {
        try
        {
            await CharacterService.UnlinkCharacterTemplateFromScenarioAsync(template.Id);
            _characterTemplates = await CharacterService.GetCharacterTemplatesByScenarioIdAsync(Id);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error removing character template {TemplateId} from scenario {ScenarioId}", template.Id, Id);
        }
    }

    private async Task ShowAddCreatureModal()
    {
        if (_addCreatureModal is null)
        {
            Logger.LogWarning("AddCreatureModal reference is not initialized for scenario {ScenarioId}", Id);
            return;
        }

        await _addCreatureModal.Show();
    }

    private async Task HandleCreatureAdded(ScenarioCreature _)
    {
        await LoadScenario();
    }

    private void ShowEditCreatureModal(ScenarioCreature creature)
    {
        _editCreatureModal?.Show(creature);
    }

    private async Task HandleCreatureUpdated(ScenarioCreature _)
    {
        await LoadScenario();
    }

    private async Task RemoveCreature(ScenarioCreature creature)
    {
        try
        {
            await ScenarioService.RemoveCreatureFromScenarioAsync(Id, creature.Id);
            await LoadScenario();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error removing creature {CreatureId} from scenario {ScenarioId}", creature.Id, Id);
        }
    }

    private async Task ShowAddItemModal()
    {
        if (_addItemModal is null)
        {
            Logger.LogWarning("AddItemModal reference is not initialized for scenario {ScenarioId}", Id);
            return;
        }

        await _addItemModal.Show();
    }

    private async Task HandleItemAdded(ScenarioItem _)
    {
        await LoadScenario();
    }

    private void ShowEditItemModal(ScenarioItem item)
    {
        _editItemModal?.Show(item);
    }

    private async Task HandleItemUpdated(ScenarioItem _)
    {
        await LoadScenario();
    }

    private async Task RemoveItem(ScenarioItem item)
    {
        try
        {
            await ScenarioService.RemoveItemFromScenarioAsync(Id, item.Id);
            await LoadScenario();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error removing item {ItemId} from scenario {ScenarioId}", item.Id, Id);
        }
    }

    private async Task HandleNpcAdded(CharacterStorageDto _)
    {
        _characterTemplates = await CharacterService.GetCharacterTemplatesByScenarioIdAsync(Id);
    }

    private async Task ShowAddNpcModal()
    {
        if (_addNpcModal is null)
        {
            Logger.LogWarning("AddNpcModal reference is not initialized for scenario {ScenarioId}", Id);
            return;
        }

        await _addNpcModal.Show();
    }

}

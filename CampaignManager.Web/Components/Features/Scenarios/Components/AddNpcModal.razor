@using CampaignManager.Web.Components.Features.Scenarios.Model
@using CampaignManager.Web.Components.Features.Scenarios.Services
@using CampaignManager.Web.Components.Features.Characters.Services
@using CampaignManager.Web.Components.Features.Characters.Model
@using CampaignManager.Web.Components.Shared
@using CampaignManager.Web.Extensions
@using CampaignManager.Web.Model

<Modal IsVisible="_isVisible"
       OnClose="Hide"
       Title="@ModalTitle"
       MaxWidth="lg"
       HeaderColorScheme="primary">
    <ChildContent>
        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <div class="mb-4 p-3 rounded-md bg-red-50 text-red-700 border border-red-200">
                @_errorMessage
            </div>
        }

        <div class="mb-4">
            <input type="text"
                   placeholder="Поиск по имени..."
                   @bind-value="_searchTerm"
                   @bind-value:event="oninput"
                   class="cm-input"/>
        </div>

        @if (FilterByType == CharacterType.NonPlayerCharacter)
        {
            <div class="mb-4">
                <label class="block text-sm font-medium text-gray-700 mb-1">Роль НПС</label>
                <select @bind="_selectedRole"
                        class="cm-input">
                    @foreach (var role in Enum.GetValues<NpcRole>())
                    {
                        <option value="@role">@role.ToRussianString()</option>
                    }
                </select>
            </div>
        }

        <div class="grid grid-cols-1 gap-3 max-h-[50vh] overflow-y-auto">
            @if (!FilteredNpcs.Any())
            {
                <div class="text-center p-4 text-gray-500">
                    Нет доступных шаблонов.
                </div>
            }
            else
            {
                @foreach (var npc in FilteredNpcs)
                {
                    <div
                        class="border p-3 rounded-lg hover:bg-gray-50 cursor-pointer transition-all duration-200 @(_selectedNpc?.Id == npc.Id ? "border-primary-500 bg-primary-50" : "border-gray-200")"
                        @onclick="() => SelectNpc(npc)">
                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-2">
                                <h3 class="font-medium">@npc.CharacterName</h3>
                                @if (npc.Character?.CharacterType == CharacterType.NonPlayerCharacter)
                                {
                                    <Badge Variant="error" Size="sm" Rounded="full" WithBorder="false">НПС</Badge>
                                }
                                else
                                {
                                    <Badge Variant="info" Size="sm" Rounded="full" WithBorder="false">Преген</Badge>
                                }
                            </div>
                            <Button OnClick="() => SelectNpc(npc)" Variant="info" Size="sm">
                                Выбрать
                            </Button>
                        </div>
                        <div class="mt-1 text-sm text-gray-600">
                            @if (!string.IsNullOrEmpty(npc.Character?.PersonalInfo?.Occupation))
                            {
                                <span class="mr-3">@npc.Character.PersonalInfo.Occupation</span>
                            }
                            @if (npc.Character?.PersonalInfo?.Age is not null)
                            {
                                <span>@npc.Character.PersonalInfo.Age лет</span>
                            }
                        </div>
                    </div>
                }
            }
        </div>
    </ChildContent>
    <FooterContent>
		<Button OnClick="Hide" Variant="secondary">Отмена</Button>
		<Button OnClick="AddNpcToScenario" Variant="info" IsDisabled="@(_selectedNpc == null)">Добавить</Button>
    </FooterContent>
</Modal>

@code {
    [Parameter] public Guid ScenarioId { get; set; }
    [Parameter] public EventCallback<CharacterStorageDto> OnNpcAdded { get; set; }
    [Parameter] public CharacterType? FilterByType { get; set; }

    [Inject] private CharacterService CharacterService { get; set; } = null!;

    private bool _isVisible;
    private string _searchTerm = string.Empty;
    private List<CharacterStorageDto> _availableNpcs = [];
    private CharacterStorageDto? _selectedNpc;
    private string? _errorMessage;
    private NpcRole _selectedRole = NpcRole.Neutral;

    private string ModalTitle => FilterByType switch
    {
        CharacterType.NonPlayerCharacter => "Добавить НПС в сценарий",
        CharacterType.PlayerCharacter => "Добавить преген-персонажа в сценарий",
        _ => "Добавить персонажа в сценарий"
    };

    private IEnumerable<CharacterStorageDto> FilteredNpcs
    {
        get
        {
            IEnumerable<CharacterStorageDto> result = _availableNpcs;

            if (FilterByType.HasValue)
            {
                result = result.Where(n => n.Character?.CharacterType == FilterByType.Value);
            }

            if (!string.IsNullOrWhiteSpace(_searchTerm))
            {
                result = result.Where(n => n.CharacterName.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase));
            }

            return result.Take(10);
        }
    }

    public async Task Show()
    {
        _selectedNpc = null;
        _searchTerm = string.Empty;
        _errorMessage = null;
        _selectedRole = NpcRole.Neutral;

        await LoadAvailableNpcs();

        _isVisible = true;
        await InvokeAsync(StateHasChanged);
    }

    public void Hide()
    {
        _isVisible = false;
        _ = InvokeAsync(StateHasChanged);
    }

    private void SelectNpc(CharacterStorageDto npc)
    {
        _selectedNpc = npc;
    }

    private async Task LoadAvailableNpcs()
    {
        try
        {
            _availableNpcs = await CharacterService.GetAllCharacterTemplatesAsync();
            _errorMessage = null;
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Error loading NPCs: {ex.Message}");
            _availableNpcs = [];
            _errorMessage = "Не удалось загрузить шаблоны персонажей. Попробуйте еще раз.";
        }
    }

    private async Task AddNpcToScenario()
    {
        if (_selectedNpc is null)
        {
            _errorMessage = "Выберите шаблон персонажа перед добавлением.";
            return;
        }

        try
        {
            var addedNpc = await CharacterService.SaveCharacterTemplateWithScenarioAsync(
                _selectedNpc.Id, ScenarioId, _selectedRole);
            await OnNpcAdded.InvokeAsync(addedNpc);
            _errorMessage = null;
            Hide();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Error adding NPC to scenario: {ex.Message}");
            _errorMessage = "Не удалось добавить шаблон персонажа в сценарий.";
            await InvokeAsync(StateHasChanged);
        }
    }

}

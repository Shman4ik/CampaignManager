@using CampaignManager.Web.Components.Features.Scenarios.Model
@using CampaignManager.Web.Components.Features.Scenarios.Services
@using CampaignManager.Web.Components.Shared

<Modal IsVisible="_isVisible"
       OnClose="Hide"
       Title="Редактировать существо"
       MaxWidth="lg"
       HeaderColorScheme="primary">
    <ChildContent>
        @if (_creature is not null)
        {
            <div class="mb-4 p-3 bg-gray-50 rounded-lg">
                <div class="font-semibold text-gray-800">@_creature.Name</div>
                <div class="text-sm text-gray-500 mt-1">@_creature.Type</div>
            </div>

            <div class="space-y-3">
                <div>
                    <label for="edit-creature-location" class="block text-sm font-medium text-gray-700 mb-1">Расположение (опционально)</label>
                    <input type="text"
                           id="edit-creature-location"
                           @bind="_location"
                           class="cm-input"/>
                </div>

                <div>
                    <label for="edit-creature-notes" class="block text-sm font-medium text-gray-700 mb-1">Заметки (опционально)</label>
                    <textarea id="edit-creature-notes"
                              @bind="_notes"
                              class="cm-input !min-h-[80px]"></textarea>
                </div>
            </div>
        }
    </ChildContent>
    <FooterContent>
        <Button OnClick="Hide" Variant="secondary">Отмена</Button>
        <Button OnClick="Save" Variant="info" IsDisabled="@(_creature is null)">Сохранить</Button>
    </FooterContent>
</Modal>

@code {
    [Parameter] public EventCallback<ScenarioCreature> OnCreatureUpdated { get; set; }

    [Inject] private ScenarioService ScenarioService { get; set; } = null!;
    [Inject] private ILogger<EditCreatureModal> Logger { get; set; } = null!;

    private bool _isVisible;
    private ScenarioCreature? _creature;
    private string _location = string.Empty;
    private string _notes = string.Empty;

    public void Show(ScenarioCreature creature)
    {
        _creature = creature;
        _location = creature.Location ?? string.Empty;
        _notes = creature.Notes ?? string.Empty;
        _isVisible = true;
        StateHasChanged();
    }

    public void Hide()
    {
        _isVisible = false;
        StateHasChanged();
    }

    private async Task Save()
    {
        if (_creature is null) return;

        try
        {
            _creature.Location = _location;
            _creature.Notes = _notes;

            await ScenarioService.UpdateCreatureInScenarioAsync(_creature);
            await OnCreatureUpdated.InvokeAsync(_creature);
            Hide();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error updating creature {CreatureId} in scenario", _creature.Id);
        }
    }
}

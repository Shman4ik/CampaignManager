@using CampaignManager.Web.Components.Features.Characters.Model
@using CampaignManager.Web.Components.Features.Characters.Services
@using CampaignManager.Web.Components.Features.Scenarios.Model
@using CampaignManager.Web.Components.Features.Scenarios.Services
@using CampaignManager.Web.Model
@using CampaignManager.Web.Utilities.Services
@inject ScenarioService ScenarioService
@inject CharacterService CharacterService
@inject IdentityService IdentityService
@inject NavigationManager NavigationManager
@inject MarkdownService MarkdownService

@rendermode InteractiveServer

@if (_scenarios is not null && _scenarios.Count > 0)
{
    <div class="oneshot-section">
        @foreach (var scenario in _scenarios)
        {
            var pregens = scenario.Npcs
                .Where(n => n.Character?.CharacterType == CharacterType.PlayerCharacter)
                .ToList();
            <div class="oneshot-card">
                <!-- Header -->
                <div class="scenario-hd">
                    <div class="hd-left">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.7)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                            <circle cx="12" cy="12" r="3"></circle>
                        </svg>
                        <span class="hd-label">Активный ваншот</span>
                    </div>
                    @if (scenario.ScheduledDate.HasValue)
                    {
                        <span class="hd-date">
                            @scenario.ScheduledDate.Value.ToString("d MMMM yyyy, HH:mm", System.Globalization.CultureInfo.GetCultureInfo("ru-RU"))
                        </span>
                    }
                </div>

                <!-- Body -->
                <div class="card-body">
                    <div class="body-layout">
                        <!-- Left: Scenario info -->
                        <div class="scenario-info">
                            <h2 class="scenario-title">@scenario.Name</h2>

                            @if (!string.IsNullOrEmpty(scenario.AnnouncementText))
                            {
                                <div class="scenario-desc markdown-content">
                                    @((MarkupString)MarkdownService.ConvertToHtml(scenario.AnnouncementText))
                                </div>
                            }
                            else if (!string.IsNullOrEmpty(scenario.Description))
                            {
                                <p class="scenario-desc">@scenario.Description</p>
                            }

                            <div class="meta-tags">
                                @if (!string.IsNullOrEmpty(scenario.Era))
                                {
                                    <span class="era-badge">@scenario.Era</span>
                                }
                                @if (!string.IsNullOrEmpty(scenario.Location))
                                {
                                    <span class="location-text">@scenario.Location</span>
                                }
                            </div>
                        </div>

                        <!-- Right: Characters (hidden on mobile) -->
                        @if (pregens.Count > 0)
                        {
                            <div class="pregens-panel">
                                <div class="pregens-title">Доступные персонажи (@pregens.Count)</div>
                                @foreach (var pregen in pregens)
                                {
                                    var pregenId = pregen.Id;
                                    var isReserved = pregen.CampaignPlayerId.HasValue;
                                    var isMine = isReserved && !string.IsNullOrEmpty(_currentUserEmail)
                                                 && pregen.CampaignPlayer is not null
                                                 && string.Equals(pregen.CampaignPlayer.PlayerEmail, _currentUserEmail, StringComparison.OrdinalIgnoreCase);
                                    <div class="pregen-row">
                                        <div class="pregen-info" @onclick="() => NavigateToCharacter(pregenId)">
                                            <div class="pregen-avatar">
                                                @(pregen.CharacterName?.Length > 0 ? pregen.CharacterName[0].ToString().ToUpper() : "?")
                                            </div>
                                            <div>
                                                <div class="pregen-name">@pregen.CharacterName</div>
                                                @if (!string.IsNullOrEmpty(pregen.Character?.PersonalInfo?.Occupation))
                                                {
                                                    <div class="pregen-occ">@pregen.Character.PersonalInfo.Occupation</div>
                                                }
                                            </div>
                                        </div>
                                        @if (isMine)
                                        {
                                            <button class="action-btn release-btn" @onclick="() => OpenReleaseConfirm(pregen)">Освободить</button>
                                        }
                                        else if (isReserved)
                                        {
                                            @if (_isKeeperOrAdmin)
                                            {
                                                <button class="action-btn release-btn" @onclick="() => OpenReleaseConfirm(pregen)">Освободить</button>
                                            }
                                            else
                                            {
                                                <span class="reserved-label">Забронирован</span>
                                            }
                                        }
                                        else
                                        {
                                            <AuthorizeView>
                                                <Authorized>
                                                    <button class="action-btn reserve-btn" @onclick="() => OpenReserveConfirm(pregen, scenario)">Забронировать</button>
                                                </Authorized>
                                                <NotAuthorized>
                                                    <button class="action-btn ghost-btn" @onclick='() => NavigationManager.NavigateTo("/api/account/login", true)'>Войти</button>
                                                </NotAuthorized>
                                            </AuthorizeView>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!string.IsNullOrEmpty(_notification))
    {
        <div class="mb-4">
            <NotificationAlert Type="@_notificationType" Message="@_notification" OnClose="ClearNotification" />
        </div>
    }

    <ConfirmationModal IsVisible="_showConfirm"
                       Title="Забронировать персонажа"
                       Message="@($"Забронировать «{_pendingPregen?.CharacterName}» на ваншот «{_pendingScenario?.Name}»? После подтверждения персонаж станет вашим на эту игру.")"
                       ConfirmText="Забронировать"
                       CancelText="Отмена"
                       WarningText=""
                       IconType="info"
                       OnConfirm="ConfirmReserve"
                       OnCancel="CancelReserve" />

    <ConfirmationModal IsVisible="_showReleaseConfirm"
                       Title="Освободить персонажа"
                       Message="@($"Освободить «{_pendingPregen?.CharacterName}»? Персонаж снова станет доступен для бронирования.")"
                       ConfirmText="Освободить"
                       CancelText="Отмена"
                       WarningText=""
                       IconType="warning"
                       OnConfirm="ConfirmRelease"
                       OnCancel="CancelRelease" />
}

@code {
    private List<Scenario>? _scenarios;
    private string? _currentUserEmail;
    private bool _isKeeperOrAdmin;
    private bool _showConfirm;
    private bool _showReleaseConfirm;
    private CharacterStorageDto? _pendingPregen;
    private Scenario? _pendingScenario;
    private string? _notification;
    private string _notificationType = "info";

    protected override async Task OnInitializedAsync()
    {
        _currentUserEmail = IdentityService.GetCurrentUserEmail();
        _isKeeperOrAdmin = await IdentityService.IsKeeper();
        await LoadScenariosAsync();
    }

    private async Task LoadScenariosAsync()
    {
        _scenarios = await ScenarioService.GetPublishedScenariosAsync();
    }

    private void NavigateToCharacter(Guid characterId)
    {
        NavigationManager.NavigateTo($"/character/{characterId}");
    }

    private void OpenReserveConfirm(CharacterStorageDto pregen, Scenario scenario)
    {
        _pendingPregen = pregen;
        _pendingScenario = scenario;
        _showConfirm = true;
    }

    private void CancelReserve()
    {
        _showConfirm = false;
        _pendingPregen = null;
        _pendingScenario = null;
    }

    private async Task ConfirmReserve()
    {
        if (_pendingPregen is null)
        {
            _showConfirm = false;
            return;
        }

        var pregenId = _pendingPregen.Id;
        _showConfirm = false;

        try
        {
            await CharacterService.ReservePregenAsync(pregenId);
            ScenarioService.InvalidatePublishedCache();
            await LoadScenariosAsync();
            _notification = "Персонаж успешно забронирован";
            _notificationType = "success";
            NavigationManager.NavigateTo($"/character/{pregenId}");
        }
        catch (InvalidOperationException ex)
        {
            _notification = ex.Message;
            _notificationType = "error";
            await LoadScenariosAsync();
        }
        catch (UnauthorizedAccessException)
        {
            NavigationManager.NavigateTo("/api/account/login", true);
        }
        finally
        {
            _pendingPregen = null;
            _pendingScenario = null;
        }
    }

    private void OpenReleaseConfirm(CharacterStorageDto pregen)
    {
        _pendingPregen = pregen;
        _showReleaseConfirm = true;
    }

    private void CancelRelease()
    {
        _showReleaseConfirm = false;
        _pendingPregen = null;
    }

    private async Task ConfirmRelease()
    {
        if (_pendingPregen is null)
        {
            _showReleaseConfirm = false;
            return;
        }

        var pregenId = _pendingPregen.Id;
        _showReleaseConfirm = false;

        try
        {
            await CharacterService.ReleasePregenAsync(pregenId);
            await LoadScenariosAsync();
            _notification = "Персонаж освобождён";
            _notificationType = "success";
        }
        catch (InvalidOperationException ex)
        {
            _notification = ex.Message;
            _notificationType = "error";
        }
        catch (UnauthorizedAccessException ex)
        {
            _notification = ex.Message;
            _notificationType = "error";
        }
        finally
        {
            _pendingPregen = null;
        }
    }

    private void ClearNotification()
    {
        _notification = null;
        StateHasChanged();
    }
}

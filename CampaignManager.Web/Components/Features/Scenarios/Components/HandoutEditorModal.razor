@using CampaignManager.Web.Components.Features.Scenarios.Model
@using CampaignManager.Web.Components.Shared
@using CampaignManager.Web.Utilities.Services
@inject MarkdownService MarkdownService

<Modal IsVisible="_isVisible"
       OnClose="Hide"
       Title="@(_isEdit ? "Редактировать раздатку" : "Добавить раздатку")"
       MaxWidth="lg"
       HeaderColorScheme="primary">
    <ChildContent>
        <div class="space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Название</label>
                    <input type="text" @bind="_model.Name" class="cm-input" placeholder="Название раздатки"/>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">URL файла</label>
                    <input type="text" @bind="_model.FileUrl" class="cm-input" placeholder="Ссылка на изображение или файл"/>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(_model.FileUrl))
            {
                <div class="border rounded-md p-2 bg-gray-50">
                    <img src="@_model.FileUrl" alt="@_model.Name" class="max-h-48 mx-auto rounded"/>
                </div>
            }

            <div>
                <div class="flex items-center justify-between mb-1">
                    <label class="block text-sm font-medium text-gray-700">Описание (Markdown)</label>
                    <Button ButtonType="button" OnClick="TogglePreview" Variant="info" Size="sm">
                        @(_showPreview ? "Редактор" : "Просмотр")
                    </Button>
                </div>
                @if (_showPreview && !string.IsNullOrEmpty(_model.Description))
                {
                    <div class="border p-4 rounded-md bg-gray-50 markdown-content min-h-[150px] max-h-[300px] overflow-y-auto">
                        @((MarkupString)MarkdownService.ConvertToHtml(_model.Description))
                    </div>
                }
                else
                {
                    <textarea @bind="_model.Description" class="cm-input" rows="6"
                              placeholder="Текстовое содержание раздатки..."></textarea>
                }
            </div>
        </div>
    </ChildContent>
    <FooterContent>
        <div class="flex justify-end gap-2">
            <Button ButtonType="button" OnClick="Hide" Variant="secondary">Отмена</Button>
            <Button ButtonType="button" OnClick="Save" Variant="info" IsDisabled="@(string.IsNullOrWhiteSpace(_model.Name))">
                @(_isEdit ? "Сохранить" : "Добавить")
            </Button>
        </div>
    </FooterContent>
</Modal>

@code {
    [Parameter] public EventCallback<ScenarioHandout> OnSaved { get; set; }

    private bool _isVisible;
    private bool _isEdit;
    private bool _showPreview;
    private ScenarioHandout _model = new() { Name = "" };

    public void Show(ScenarioHandout? editHandout = null, int nextOrder = 0)
    {
        _isEdit = editHandout is not null;

        if (editHandout is not null)
        {
            _model = new ScenarioHandout
            {
                Id = editHandout.Id,
                Name = editHandout.Name,
                Description = editHandout.Description,
                FileUrl = editHandout.FileUrl,
                Order = editHandout.Order
            };
        }
        else
        {
            _model = new ScenarioHandout
            {
                Name = "",
                Order = nextOrder
            };
        }

        _showPreview = false;
        _isVisible = true;
        StateHasChanged();
    }

    private void Hide()
    {
        _isVisible = false;
        StateHasChanged();
    }

    private void TogglePreview() => _showPreview = !_showPreview;

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_model.Name)) return;
        await OnSaved.InvokeAsync(_model);
        Hide();
    }
}

@using CampaignManager.Web.Components.Features.Scenarios.Model
@using CampaignManager.Web.Components.Shared
@using CampaignManager.Web.Utilities.Services
@inject MarkdownService MarkdownService

<Modal IsVisible="_isVisible"
       OnClose="Hide"
       Title="@(_isEdit ? "Редактировать факт" : "Добавить ключевой факт")"
       MaxWidth="lg"
       HeaderColorScheme="primary">
    <ChildContent>
        <div class="space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Заголовок</label>
                    <input type="text" @bind="_model.Title" class="cm-input" placeholder="Заголовок факта"/>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Тип</label>
                    <select @bind="_model.Type" class="cm-input">
                        <option value="@KeyFactType.Backstory">Предыстория</option>
                        <option value="@KeyFactType.Truth">Зловещая истина</option>
                        <option value="@KeyFactType.Timeline">Хронология</option>
                        <option value="@KeyFactType.Reward">Награды</option>
                    </select>
                </div>
            </div>

            <div>
                <div class="flex items-center justify-between mb-1">
                    <label class="block text-sm font-medium text-gray-700">Содержание (Markdown)</label>
                    <Button ButtonType="button" OnClick="TogglePreview" Variant="info" Size="sm">
                        @(_showPreview ? "Редактор" : "Просмотр")
                    </Button>
                </div>
                @if (_showPreview && !string.IsNullOrEmpty(_model.Content))
                {
                    <div class="border p-4 rounded-md bg-gray-50 markdown-content min-h-[200px] max-h-[400px] overflow-y-auto">
                        @((MarkupString)MarkdownService.ConvertToHtml(_model.Content))
                    </div>
                }
                else
                {
                    <textarea @bind="_model.Content" class="cm-input" rows="8"
                              placeholder="Содержание факта..."></textarea>
                }
            </div>
        </div>
    </ChildContent>
    <FooterContent>
        <div class="flex justify-end gap-2">
            <Button ButtonType="button" OnClick="Hide" Variant="secondary">Отмена</Button>
            <Button ButtonType="button" OnClick="Save" Variant="info" IsDisabled="@(string.IsNullOrWhiteSpace(_model.Title))">
                @(_isEdit ? "Сохранить" : "Добавить")
            </Button>
        </div>
    </FooterContent>
</Modal>

@code {
    [Parameter] public EventCallback<ScenarioKeyFact> OnSaved { get; set; }

    private bool _isVisible;
    private bool _isEdit;
    private bool _showPreview;
    private ScenarioKeyFact _model = new() { Title = "" };

    public void Show(ScenarioKeyFact? editFact = null, int nextOrder = 0)
    {
        _isEdit = editFact is not null;

        if (editFact is not null)
        {
            _model = new ScenarioKeyFact
            {
                Id = editFact.Id,
                Title = editFact.Title,
                Content = editFact.Content,
                Type = editFact.Type,
                Order = editFact.Order
            };
        }
        else
        {
            _model = new ScenarioKeyFact
            {
                Title = "",
                Order = nextOrder
            };
        }

        _showPreview = false;
        _isVisible = true;
        StateHasChanged();
    }

    private void Hide()
    {
        _isVisible = false;
        StateHasChanged();
    }

    private void TogglePreview() => _showPreview = !_showPreview;

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_model.Title)) return;
        await OnSaved.InvokeAsync(_model);
        Hide();
    }
}

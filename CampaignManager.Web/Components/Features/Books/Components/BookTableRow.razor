@using CampaignManager.Web.Components.Features.Books.Model
@using CampaignManager.Web.Components.Shared
@using CampaignManager.Web.Extensions
@namespace CampaignManager.Web.Components.Features.Books.Components

<tr class="@(IsExpanded ? "bg-primary-50" : "hover:bg-gray-50") transition-all duration-200 cursor-pointer active:bg-gray-100"
    @onclick="ToggleExpand">
    <td class="px-4 sm:px-6 py-4 font-semibold text-gray-900">
        <div class="flex items-center gap-3">
            <button type="button"
                    class="w-8 h-8 flex items-center justify-center text-primary-600 hover:text-primary-800 hover:bg-primary-50 rounded-lg transition-colors"
                    @onclick:stopPropagation="true"
                    @onclick="ToggleExpand">
                <i class="fas @(IsExpanded ? "fa-chevron-up" : "fa-chevron-down")"></i>
            </button>
            <span>@Book.Name</span>
        </div>
    </td>
    <td class="px-4 sm:px-6 py-4">
        <Badge Variant="@(Book.BookType == BookType.MythosBook ? "error" : "secondary")">
            @Book.BookType.ToRussianString()
        </Badge>
    </td>
    <td class="px-4 sm:px-6 py-4 text-gray-700 font-medium">@(!string.IsNullOrWhiteSpace(Book.Language) ? Book.Language : "—")</td>
    <td class="px-4 sm:px-6 py-4 text-gray-700 font-medium">@(!string.IsNullOrWhiteSpace(Book.Year) ? Book.Year : "—")</td>
    <td class="px-4 sm:px-6 py-4 text-gray-700 font-medium">@(!string.IsNullOrWhiteSpace(Book.Author) ? Book.Author : "—")</td>
    <td class="px-4 sm:px-6 py-4 text-gray-700 font-medium">
        @if (Book.BookType == BookType.MythosBook && Book.MythosRating.HasValue)
        {
            <span>ЗМ @Book.MythosRating</span>
        }
        else if (Book.BookType == BookType.OccultBook && Book.OccultismBonus.HasValue)
        {
            <span>+@(Book.OccultismBonus)%</span>
        }
        else
        {
            <span>—</span>
        }
    </td>
    <td class="px-4 sm:px-6 py-4 text-center" @onclick:stopPropagation="true">
        <div class="flex flex-col sm:flex-row gap-2 justify-center">
            <button @onclick="() => OnEdit.InvokeAsync(Book)"
                    class="min-h-[44px] px-4 py-2 text-primary-600 hover:text-primary-800 bg-primary-50 hover:bg-primary-100 rounded-lg text-sm font-semibold flex items-center justify-center gap-2 transition-all duration-200 border border-primary-200">
                <i class="fas fa-edit"></i>
                <span>Изменить</span>
            </button>
            <button @onclick="() => OnDelete.InvokeAsync(Book)"
                    class="min-h-[44px] px-4 py-2 text-error-600 hover:text-error-800 bg-error-50 hover:bg-error-100 rounded-lg text-sm font-semibold flex items-center justify-center gap-2 transition-all duration-200 border border-error-200">
                <i class="fas fa-trash-alt"></i>
                <span>Удалить</span>
            </button>
        </div>
    </td>
</tr>

@if (IsExpanded)
{
    <tr class="bg-gradient-to-r from-gray-50 to-white border-t-2 border-primary-200 book-expand-row">
        <td colspan="7" class="px-4 sm:px-6 py-6">
            <div class="bg-white rounded-xl p-6 shadow-inner border-2 border-gray-100 space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div class="space-y-1">
                        <h5 class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Название</h5>
                        <p class="text-base font-medium text-gray-900">@Book.Name</p>
                    </div>
                    <div class="space-y-1">
                        <h5 class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Категория</h5>
                        <p class="text-base font-medium text-gray-900">@Book.BookType.ToRussianString()</p>
                    </div>
                    <div class="space-y-1">
                        <h5 class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Язык</h5>
                        <p class="text-base font-medium text-gray-900">@(!string.IsNullOrWhiteSpace(Book.Language) ? Book.Language : "—")</p>
                    </div>
                    <div class="space-y-1">
                        <h5 class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Год / век</h5>
                        <p class="text-base font-medium text-gray-900">@(!string.IsNullOrWhiteSpace(Book.Year) ? Book.Year : "—")</p>
                    </div>
                    <div class="space-y-1">
                        <h5 class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Автор</h5>
                        <p class="text-base font-medium text-gray-900">@(!string.IsNullOrWhiteSpace(Book.Author) ? Book.Author : "—")</p>
                    </div>
                    <div class="space-y-1">
                        <h5 class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Потеря рассудка</h5>
                        <p class="text-base font-medium text-gray-900">@(!string.IsNullOrWhiteSpace(Book.SanityLoss) ? Book.SanityLoss : "—")</p>
                    </div>

                    @if (Book.BookType == BookType.MythosBook)
                    {
                        <div class="space-y-1">
                            <h5 class="text-sm font-semibold text-gray-500 uppercase tracking-wide">МКН (начальное)</h5>
                            <p class="text-base font-medium text-gray-900">@(Book.CthulhuMythosInitial.HasValue ? $"+{Book.CthulhuMythosInitial}" : "—")</p>
                        </div>
                        <div class="space-y-1">
                            <h5 class="text-sm font-semibold text-gray-500 uppercase tracking-wide">МКП (полное)</h5>
                            <p class="text-base font-medium text-gray-900">@(Book.CthulhuMythosFull.HasValue ? $"+{Book.CthulhuMythosFull}" : "—")</p>
                        </div>
                        <div class="space-y-1">
                            <h5 class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Значение Мифов</h5>
                            <p class="text-base font-medium text-gray-900">@(Book.MythosRating.HasValue ? Book.MythosRating.ToString() : "—")</p>
                        </div>
                    }

                    @if (Book.BookType == BookType.OccultBook && Book.OccultismBonus.HasValue)
                    {
                        <div class="space-y-1">
                            <h5 class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Бонус к оккультизму</h5>
                            <p class="text-base font-medium text-gray-900">+@(Book.OccultismBonus)%</p>
                        </div>
                    }

                    @if (Book.StudyWeeks.HasValue)
                    {
                        <div class="space-y-1">
                            <h5 class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Время изучения</h5>
                            <p class="text-base font-medium text-gray-900">@Book.StudyWeeks нед.</p>
                        </div>
                    }
                </div>

                @if (Book.AlternativeNames.Count > 0)
                {
                    <div>
                        <h5 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-3">Альтернативные названия</h5>
                        <div class="flex flex-wrap gap-2">
                            @foreach (var altName in Book.AlternativeNames)
                            {
                                <Badge Variant="secondary">@altName</Badge>
                            }
                        </div>
                    </div>
                }

                @if (Book.PossibleSpells.Count > 0)
                {
                    <div>
                        <h5 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-3">Возможные заклинания</h5>
                        <div class="flex flex-wrap gap-2">
                            @foreach (var spell in Book.PossibleSpells)
                            {
                                <Badge Variant="primary">@spell</Badge>
                            }
                        </div>
                    </div>
                }

                <div>
                    <h5 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-3">Описание</h5>
                    <p class="text-base text-gray-700 whitespace-pre-wrap leading-relaxed">@Book.Description</p>
                </div>
            </div>
        </td>
    </tr>
}

@code {
    [Parameter] public Book Book { get; set; } = new() { Name = string.Empty, BookType = BookType.MythosBook };
    [Parameter] public bool IsExpanded { get; set; }
    [Parameter] public EventCallback<Book> OnEdit { get; set; }
    [Parameter] public EventCallback<Book> OnDelete { get; set; }
    [Parameter] public EventCallback OnToggleExpand { get; set; }

    private Task ToggleExpand()
    {
        return OnToggleExpand.InvokeAsync();
    }
}

@using CampaignManager.Web.Components.Features.Campaigns.Models
@using CampaignManager.Web.Components.Features.Campaigns.Services
@using CampaignManager.Web.Components.Features.Characters.Model
@using CampaignManager.Web.Utilities.Services
@inject CampaignService CampaignService
@inject IdentityService UserInformationService
@inject NavigationManager NavigationManager

@rendermode InteractiveServer

<div class="campaigns-section">
    <div class="campaigns-header">
        <span class="campaigns-title">Ваши кампании</span>
    </div>

    @if (!IsUserAuthenticated)
    {
        <div class="cm-info-banner">
            <i class="fa-solid fa-circle-info mr-1.5"></i>Войдите в систему, чтобы увидеть свои кампании.
        </div>
    }
    else if (UserCampaigns is null)
    {
        <p class="cm-empty"><i class="fa-solid fa-spinner fa-spin mr-1"></i>Загрузка...</p>
    }
    else if (UserCampaigns.Count == 0)
    {
        <p class="cm-empty">У вас пока нет доступных кампаний.</p>
    }
    else
    {
        <div class="campaigns-grid">
            @foreach (var campaign in UserCampaigns)
            {
                var isKeeper = CurrentUserId == campaign.KeeperEmail;
                var userCharacter = GetUserCharacter(campaign);
                var npcs = isKeeper && _isKeeper ? GetCampaignNpcs(campaign) : [];

                <div class="cm-card campaign-card">
                    <div class="campaign-card-header">
                        <span class="campaign-card-name" title="@campaign.Name">@campaign.Name</span>
                        @if (isKeeper)
                        {
                            <Badge Variant="accent" Size="sm" Rounded="full" WithBorder="false">Хранитель</Badge>
                        }
                    </div>
                    <div class="campaign-card-body">
                        <div class="campaign-meta">
                            <span class="campaign-meta-label">Хранитель:</span>
                            <span class="campaign-meta-value">@campaign.KeeperEmail</span>
                        </div>
                        <div class="campaign-meta">
                            <span class="campaign-meta-label">Игроков:</span>
                            <span class="campaign-meta-value">@(campaign.Players?.Count ?? 0)</span>
                        </div>

                        @if (isKeeper && _isKeeper)
                        {
                            <button type="button" class="cm-btn cm-btn-primary cm-btn-sm campaign-full-btn"
                                    @onclick="() => AddNpc(campaign.Id)">
                                <i class="fa-solid fa-plus"></i>Добавить NPC
                            </button>
                        }

                        @if (userCharacter is not null)
                        {
                            <div class="campaign-char-box">
                                <div class="campaign-char-name">@userCharacter.CharacterName</div>
                                <div class="campaign-char-occ">@userCharacter.Character.PersonalInfo.Occupation</div>
                                <button type="button" class="cm-btn cm-btn-primary cm-btn-sm campaign-full-btn"
                                        @onclick="() => EditCharacter(userCharacter.Id)">
                                    <i class="fa-solid fa-user"></i>Открыть персонажа
                                </button>
                            </div>
                        }
                        else
                        {
                            <div class="campaign-no-char">
                                <p class="campaign-no-char-text">Нет персонажа в этой кампании</p>
                                <button type="button" class="cm-btn cm-btn-secondary cm-btn-sm campaign-full-btn"
                                        @onclick="() => CreateNewCharacter(campaign.Id)">
                                    <i class="fa-solid fa-plus"></i>Создать персонажа
                                </button>
                            </div>
                        }

                        @if (isKeeper && _isKeeper && npcs.Count > 0)
                        {
                            <div class="campaign-npcs">
                                <div class="campaign-npcs-title">NPC (@npcs.Count)</div>
                                @foreach (var npc in npcs)
                                {
                                    <div class="campaign-npc-row">
                                        <span class="campaign-npc-name" title="@npc.CharacterName">@npc.CharacterName</span>
                                        <button type="button" class="cm-btn cm-btn-secondary cm-btn-sm"
                                                @onclick="() => EditCharacter(npc.Id)">
                                            Открыть
                                        </button>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<Campaign>? UserCampaigns;
    private bool IsUserAuthenticated => CurrentUserId is not null;
    private string? CurrentUserId;
    private bool _isKeeper;

    protected override async Task OnInitializedAsync()
    {
        CurrentUserId = UserInformationService.GetCurrentUserEmail();
        if (IsUserAuthenticated)
        {
            UserCampaigns = await CampaignService.GetUserCampaignsAsync();
            _isKeeper = await UserInformationService.IsKeeper();
        }
    }

    private CharacterStorageDto? GetUserCharacter(Campaign campaign) =>
        campaign.Players?
            .FirstOrDefault(p => p.PlayerEmail == CurrentUserId)
            ?.Characters?
            .Where(p => p.Status == CharacterStatus.Active)
            .SingleOrDefault();

    private List<CharacterStorageDto> GetCampaignNpcs(Campaign campaign) =>
        campaign.Players?
            .SelectMany(p => p.Characters ?? [])
            .Where(c => c.Character.CharacterType == CharacterType.NonPlayerCharacter)
            .ToList() ?? [];

    private void EditCharacter(Guid characterId) =>
        NavigationManager.NavigateTo($"/character/{characterId}");

    private void CreateNewCharacter(Guid campaignId) =>
        NavigationManager.NavigateTo($"/character/create/{campaignId}");

    private void AddNpc(Guid campaignId) =>
        NavigationManager.NavigateTo($"/character/create/{campaignId}/npc");
}

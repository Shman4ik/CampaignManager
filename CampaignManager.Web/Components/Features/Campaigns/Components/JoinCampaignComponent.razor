@using CampaignManager.Web.Components.Features.Campaigns.Models
@using CampaignManager.Web.Components.Features.Campaigns.Services
@inject CampaignService CampaignService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

@if (_hasCampaigns)
{
    <div class="cm-section">
        <div class="cm-section-header">
            <span class="cm-section-title">Доступные кампании</span>
        </div>

        @if (!string.IsNullOrEmpty(NotificationMessage))
        {
            <div class="mb-3">
                <NotificationAlert Type="@_notifType" Message="@NotificationMessage" OnClose="ClearNotification"/>
            </div>
        }

        <div class="cm-grid-cards">
            @foreach (var campaign in AvailableCampaigns.Where(c => !IsUserInCampaign(c)))
            {
                <div class="cm-card">
                    <div class="cm-card-header">
                        <span class="font-semibold text-sm truncate" style="color:var(--color-primary-800);">@campaign.Name</span>
                        <span class="text-xs" style="color:var(--color-primary-400);">@campaign.CreatedAt.ToString("dd.MM.yyyy")</span>
                    </div>
                    <div class="cm-card-body" style="display:flex;flex-direction:column;gap:0.5rem;">
                        <div class="cm-meta">
                            <span class="cm-meta-label">Хранитель:</span>
                            <span>@campaign.KeeperEmail</span>
                        </div>

                        @if (IsUserAuthorized)
                        {
                            <div style="display:flex;flex-direction:column;gap:0.375rem;">
                                <label class="text-xs font-semibold" style="color:var(--color-primary-600);">Ваше имя</label>
                                <input type="text"
                                       class="cm-input cm-input-sm"
                                       placeholder="Введите имя..."
                                       value="@UserName"
                                       @oninput="@(e => UserName = e.Value?.ToString())"/>
                                <button type="button"
                                        class="cm-btn cm-btn-primary cm-btn-sm"
                                        disabled="@(string.IsNullOrWhiteSpace(UserName))"
                                        @onclick="async () => await JoinCampaignAsync(campaign.Id, UserName ?? string.Empty)">
                                    <i class="fa-solid fa-right-to-bracket mr-1"></i>Присоединиться
                                </button>
                            </div>
                        }
                        else
                        {
                            <p class="text-xs text-center" style="color:var(--color-primary-400);">
                                <a href="/api/account/login" style="color:var(--color-accent-600);">Войдите</a>, чтобы присоединиться
                            </p>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    private List<Campaign> AvailableCampaigns { get; set; } = [];
    private List<Campaign> UserCampaigns { get; set; } = [];
    private bool IsUserAuthorized;
    private string UserEmail = string.Empty;
    private string? UserName;
    private bool _hasCampaigns;

    private string NotificationMessage { get; set; } = string.Empty;
    private string _notifType = "info";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        IsUserAuthorized = authState.User.Identity?.IsAuthenticated ?? false;
        UserEmail = authState.User?.FindFirst(ClaimTypes.Email)?.Value ?? string.Empty;
        UserName = authState.User?.FindFirstValue(ClaimTypes.Name) ?? string.Empty;

        if (IsUserAuthorized)
        {
            var availableTask = CampaignService.GetAvailableCompaniesAsync();
            var userTask = CampaignService.GetUserCampaignsAsync();
            await Task.WhenAll(availableTask, userTask);
            AvailableCampaigns = await availableTask;
            UserCampaigns = await userTask;
        }
        else
        {
            AvailableCampaigns = await CampaignService.GetAvailableCompaniesAsync();
        }

        _hasCampaigns = AvailableCampaigns.Any(c => !IsUserInCampaign(c));
    }

    private bool IsUserInCampaign(Campaign campaign) =>
        UserCampaigns?.Any(c => c.Id == campaign.Id) ?? false;

    private async Task JoinCampaignAsync(Guid campaignId, string userName)
    {
        if (!IsUserAuthorized || string.IsNullOrWhiteSpace(userName)) return;
        try
        {
            var ok = await CampaignService.JoinCampaignAsync(campaignId, userName);
            if (ok)
            {
                ShowNotification("Вы успешно присоединились к кампании!", "success");
                await Task.Delay(1200);
                NavigationManager.NavigateTo("/", true);
            }
            else
            {
                ShowNotification("Не удалось присоединиться. Возможно, вы уже участник.", "warning");
            }
        }
        catch (Exception ex)
        {
            ShowNotification($"Ошибка: {ex.Message}", "error");
        }
    }

    private void ShowNotification(string message, string type)
    {
        NotificationMessage = message;
        _notifType = type;
        StateHasChanged();
    }

    private void ClearNotification()
    {
        NotificationMessage = string.Empty;
        StateHasChanged();
    }
}

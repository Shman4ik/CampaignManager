@using CampaignManager.Web.Components.Features.Campaigns.Models
@using CampaignManager.Web.Components.Features.Campaigns.Services
@using CampaignManager.Web.Components.Features.Characters.Model
@using CampaignManager.Web.Utilities.Services
@inject CampaignService CampaignService
@inject IdentityService UserInformationService
@inject NavigationManager NavigationManager

@rendermode InteractiveServer

@if (IsUserAuthenticated && IsUserKeeper)
{
    <div class="cm-section">
        <div class="cm-section-header">
            <span class="cm-section-title">Персонажи в ваших кампаниях</span>
        </div>

        @if (KeeperCampaigns is null)
        {
            <p class="cm-empty"><i class="fa-solid fa-spinner fa-spin mr-1"></i>Загрузка...</p>
        }
        else if (KeeperCampaigns.Count == 0)
        {
            <p class="cm-empty">У вас пока нет кампаний Хранителя.</p>
        }
        else
        {
            @foreach (var campaign in KeeperCampaigns)
            {
                var expanded = _expandedCampaigns.GetValueOrDefault(campaign.Id, false);
                <div class="cm-accordion">
                    <button class="cm-accordion-trigger" @onclick="() => ToggleCampaign(campaign.Id)">
                        <div style="display:flex;align-items:center;gap:0.625rem;min-width:0;flex:1;">
                            <span class="font-semibold text-sm truncate" style="color:var(--color-primary-800);">@campaign.Name</span>
                            <Badge Variant="@CampaignStatusVariant(campaign.Status)" Size="sm" Rounded="full" WithBorder="false">
                                @CampaignStatusLabel(campaign.Status)
                            </Badge>
                        </div>
                        <div style="display:flex;align-items:center;gap:0.75rem;flex-shrink:0;">
                            <span class="text-xs" style="color:var(--color-primary-400);">
                                <i class="fa-solid fa-users mr-1"></i>@(campaign.Players?.Count ?? 0)
                            </span>
                            <i class="fa-solid @(expanded ? "fa-chevron-up" : "fa-chevron-down") text-xs"
                               style="color:var(--color-primary-400);"></i>
                        </div>
                    </button>

                    @if (expanded)
                    {
                        <div class="cm-accordion-body" style="padding:0;overflow-x:auto;">
                            @if (campaign.Players is null || campaign.Players.Count == 0)
                            {
                                <p class="cm-empty">В этой кампании пока нет игроков.</p>
                            }
                            else
                            {
                                <table class="cm-table">
                                    <thead>
                                        <tr>
                                            <th>Игрок</th>
                                            <th>Персонаж</th>
                                            <th>Профессия</th>
                                            <th>Тип</th>
                                            <th>Статус</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var player in campaign.Players)
                                        {
                                            @if (player.Characters is not null && player.Characters.Count > 0)
                                            {
                                                @foreach (var character in player.Characters)
                                                {
                                                    <tr>
                                                        <td>@player.PlayerName</td>
                                                        <td class="font-medium">@character.CharacterName</td>
                                                        <td>@character.Character.PersonalInfo.Occupation</td>
                                                        <td>
                                                            <Badge Variant="@CharTypeVariant(character.Character.CharacterType)"
                                                                   Size="sm" Rounded="full" WithBorder="false">
                                                                @CharTypeLabel(character.Character.CharacterType)
                                                            </Badge>
                                                        </td>
                                                        <td>
                                                            <Badge Variant="@CharStatusVariant(character.Status)"
                                                                   Size="sm" Rounded="full" WithBorder="false">
                                                                @CharStatusLabel(character.Status)
                                                            </Badge>
                                                        </td>
                                                        <td>
                                                            <button type="button" class="cm-btn cm-btn-secondary cm-btn-sm"
                                                                    @onclick="() => ViewCharacter(character.Id)">
                                                                Открыть
                                                            </button>
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                            else
                                            {
                                                <tr>
                                                    <td>@player.PlayerName</td>
                                                    <td colspan="5" style="color:var(--color-primary-400);">Нет персонажей</td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            }
                        </div>
                    }
                </div>
            }
        }
    </div>
}

@code {
    private List<Campaign>? KeeperCampaigns;
    private bool IsUserAuthenticated => CurrentUserId is not null;
    private bool IsUserKeeper;
    private string? CurrentUserId;
    private Dictionary<Guid, bool> _expandedCampaigns = [];

    protected override async Task OnInitializedAsync()
    {
        CurrentUserId = UserInformationService.GetCurrentUserEmail();
        if (IsUserAuthenticated)
        {
            var allCampaigns = await CampaignService.GetUserCampaignsAsync();
            KeeperCampaigns = allCampaigns
                .Where(c => c.KeeperEmail == CurrentUserId)
                .ToList();

            _expandedCampaigns = KeeperCampaigns.ToDictionary(
                c => c.Id,
                c => c.Status == CampaignStatus.Active);
        }

        IsUserKeeper = await UserInformationService.IsKeeper();
    }

    private void ToggleCampaign(Guid id)
    {
        _expandedCampaigns[id] = !_expandedCampaigns.GetValueOrDefault(id, false);
    }

    private void ViewCharacter(Guid id) => NavigationManager.NavigateTo($"/character/{id}");

    private static string CampaignStatusVariant(CampaignStatus s) => s switch
    {
        CampaignStatus.Active    => "success",
        CampaignStatus.Planning  => "accent",
        CampaignStatus.OnHold    => "warning",
        CampaignStatus.Completed => "secondary",
        _                        => "primary"
    };

    private static string CampaignStatusLabel(CampaignStatus s) => s switch
    {
        CampaignStatus.Active    => "Активна",
        CampaignStatus.Planning  => "Планирование",
        CampaignStatus.OnHold    => "Пауза",
        CampaignStatus.Completed => "Завершена",
        _                        => s.ToString()
    };

    private static string CharTypeVariant(CharacterType t) => t switch
    {
        CharacterType.PlayerCharacter    => "accent",
        CharacterType.NonPlayerCharacter => "secondary",
        _                               => "primary"
    };

    private static string CharTypeLabel(CharacterType t) => t switch
    {
        CharacterType.PlayerCharacter    => "Игрок",
        CharacterType.NonPlayerCharacter => "NPC",
        _                               => t.ToString()
    };

    private static string CharStatusVariant(CharacterStatus s) => s switch
    {
        CharacterStatus.Active   => "success",
        CharacterStatus.Inactive => "warning",
        CharacterStatus.Retired  => "error",
        CharacterStatus.Archived => "secondary",
        _                        => "primary"
    };

    private static string CharStatusLabel(CharacterStatus s) => s switch
    {
        CharacterStatus.Active   => "Активен",
        CharacterStatus.Inactive => "Неактивен",
        CharacterStatus.Retired  => "Выведен",
        CharacterStatus.Archived => "Архив",
        _                        => s.ToString()
    };
}

@page "/campaigns"
@using CampaignManager.Web.Components.Features.Campaigns.Models
@using CampaignManager.Web.Components.Features.Campaigns.Services
@using CampaignManager.Web.Components.Shared.Model
@using CampaignManager.Web.Utilities
@using CampaignManager.Web.Utilities.Services
@attribute [Authorize]
@inject CampaignService CampaignService
@inject NavigationManager NavigationManager
@inject IdentityService IdentityService
@inject ILogger<CampaignsPage> Logger
@rendermode InteractiveServer

<PageTitle>Кампании</PageTitle>

<PageHeader Title="Кампании">
    <Actions>
        @if (_isKeeper)
        {
            <button type="button" class="cm-btn cm-btn-primary" @onclick="OpenAddModal">
                <i class="fas fa-plus"></i> <span>Создать кампанию</span>
            </button>
        }
    </Actions>
</PageHeader>

@if (!_isKeeper)
{
    <div class="max-w-7xl mx-auto px-4 py-6">
        <Alert Type="error" Title="Доступ запрещён">
            Эта страница доступна только для Хранителя.
        </Alert>
    </div>
}
else
{
    <div class="max-w-7xl mx-auto px-4 py-6">

        <!-- Filters -->
        <div class="flex flex-col sm:flex-row gap-3 mb-6">
            <div class="flex-1 min-w-0">
                <input type="search" placeholder="Поиск по названию..."
                       class="cm-input"
                       @bind="_searchTerm" @bind:event="oninput" />
            </div>
            <div class="w-full sm:w-48 flex-shrink-0">
                <select class="cm-input" @bind="_statusFilter">
                    <option value="">Все статусы</option>
                    @foreach (var status in Enum.GetValues<CampaignStatus>())
                    {
                        <option value="@status">@GetStatusLabel(status)</option>
                    }
                </select>
            </div>
        </div>

        <!-- Loading -->
        @if (_loading)
        {
            <div class="flex justify-center items-center h-48">
                <div class="animate-spin rounded-full h-12 w-12 border-t-2 border-b-2 border-primary-500"></div>
            </div>
        }
        else if (!FilteredCampaigns.Any())
        {
            <div class="cm-card">
                <div class="cm-card-body text-center">
                    <i class="fas fa-scroll text-4xl text-gray-300 mb-4 block"></i>
                    @if (_campaigns.Count == 0)
                    {
                        <p class="text-lg text-gray-600 mb-1">Кампаний пока нет.</p>
                        <p class="text-gray-500">Создайте свою первую кампанию.</p>
                    }
                    else
                    {
                        <p class="cm-empty">Нет кампаний по заданным фильтрам.</p>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                @foreach (var campaign in FilteredCampaigns)
                {
                    <div class="cm-card hover:shadow-lg transition-shadow duration-300 flex flex-col h-full">
                        <div class="cm-card-body flex-grow space-y-3">
                            <div class="flex items-start justify-between gap-2">
                                <h2 class="cm-h5 truncate">@campaign.Name</h2>
                                <Badge Variant="@GetStatusVariant(campaign.Status)" Size="sm" Rounded="full" WithBorder="false">
                                    @GetStatusLabel(campaign.Status)
                                </Badge>
                            </div>
                            <div class="text-sm text-gray-500 space-y-1">
                                <div><span class="font-medium text-gray-700">Игроков:</span> @(campaign.Players?.Count ?? 0)</div>
                                <div><span class="font-medium text-gray-700">Создана:</span> @campaign.CreatedAt.ToString("dd.MM.yyyy")</div>
                            </div>
                        </div>
                        <div class="bg-gray-50 px-4 py-3 border-t border-gray-100 grid grid-cols-2 gap-1.5">
                            <button type="button" class="cm-btn cm-btn-secondary cm-btn-sm justify-center"
                                    @onclick="@(() => OpenEditModal(campaign))">
                                <i class="fas fa-edit"></i> <span>Изменить</span>
                            </button>
                            <button type="button" class="cm-btn cm-btn-error cm-btn-sm justify-center"
                                    @onclick="@(() => ConfirmDelete(campaign))">
                                <i class="fas fa-trash"></i> <span>Удалить</span>
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Add Campaign Modal -->
    <Modal IsVisible="_showAddModal"
           OnClose="CloseAddModal"
           Title="Создать кампанию"
           MaxWidth="md"
           MaxHeight="null">
        <ChildContent>
            <EditForm Model="@_addModel" OnValidSubmit="@CreateCampaign" FormName="addCampaignForm">
                <DataAnnotationsValidator />
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Название кампании</label>
                        <InputText @bind-Value="_addModel.Name" class="cm-input" placeholder="Введите название..." />
                        <ValidationMessage For="@(() => _addModel.Name)" class="text-red-500 text-xs mt-1" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Статус</label>
                        <InputSelect @bind-Value="_addModel.Status" class="cm-input">
                            @foreach (var status in Enum.GetValues<CampaignStatus>())
                            {
                                <option value="@status">@GetStatusLabel(status)</option>
                            }
                        </InputSelect>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Эпоха</label>
                        <InputSelect @bind-Value="_addModel.Era" class="cm-input">
                            <option value="@Eras.Classic">1920-е (классика)</option>
                            <option value="@Eras.Modern">Современность</option>
                            <option value="@(Eras.Classic | Eras.Modern)">Обе эпохи</option>
                        </InputSelect>
                    </div>
                    @if (!string.IsNullOrEmpty(_addError))
                    {
                        <div class="text-sm text-red-600 bg-red-50 border border-red-200 rounded-md px-3 py-2">
                            @_addError
                        </div>
                    }
                </div>
                <div class="flex justify-end gap-2 mt-6">
                    <button type="button" class="cm-btn cm-btn-secondary" @onclick="CloseAddModal">
                        <span>Отмена</span>
                    </button>
                    <button type="submit" class="cm-btn cm-btn-primary" disabled="@_saving">
                        @if (_saving)
                        {
                            <i class="fas fa-spinner fa-spin"></i>
                        }
                        <span>@(_saving ? "Создание..." : "Создать")</span>
                    </button>
                </div>
            </EditForm>
        </ChildContent>
    </Modal>

    <!-- Edit Campaign Modal -->
    <Modal IsVisible="@(_showEditModal && _editCampaign is not null)"
           OnClose="CloseEditModal"
           Title="Изменить кампанию"
           MaxWidth="md"
           MaxHeight="null">
        <ChildContent>
            <EditForm Model="@_editModel" OnValidSubmit="@UpdateCampaign" FormName="editCampaignForm">
                <DataAnnotationsValidator />
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Название кампании</label>
                        <InputText @bind-Value="_editModel.Name" class="cm-input" />
                        <ValidationMessage For="@(() => _editModel.Name)" class="text-red-500 text-xs mt-1" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Статус</label>
                        <InputSelect @bind-Value="_editModel.Status" class="cm-input">
                            @foreach (var status in Enum.GetValues<CampaignStatus>())
                            {
                                <option value="@status">@GetStatusLabel(status)</option>
                            }
                        </InputSelect>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Эпоха</label>
                        <InputSelect @bind-Value="_editModel.Era" class="cm-input">
                            <option value="@Eras.Classic">1920-е (классика)</option>
                            <option value="@Eras.Modern">Современность</option>
                            <option value="@(Eras.Classic | Eras.Modern)">Обе эпохи</option>
                        </InputSelect>
                    </div>
                    @if (!string.IsNullOrEmpty(_editError))
                    {
                        <div class="text-sm text-red-600 bg-red-50 border border-red-200 rounded-md px-3 py-2">
                            @_editError
                        </div>
                    }
                </div>
                <div class="flex justify-end gap-2 mt-6">
                    <button type="button" class="cm-btn cm-btn-secondary" @onclick="CloseEditModal">
                        <span>Отмена</span>
                    </button>
                    <button type="submit" class="cm-btn cm-btn-primary" disabled="@_saving">
                        @if (_saving)
                        {
                            <i class="fas fa-spinner fa-spin"></i>
                        }
                        <span>@(_saving ? "Сохранение..." : "Сохранить")</span>
                    </button>
                </div>
            </EditForm>
        </ChildContent>
    </Modal>

    <!-- Delete Confirmation Modal -->
    <ConfirmationModal IsVisible="_showDeleteModal"
                       OnConfirm="DeleteCampaign"
                       OnCancel="@(() => { _showDeleteModal = false; _campaignToDelete = null; })"
                       Title="Удалить кампанию"
                       Message="@($"Вы уверены, что хотите удалить кампанию \"{_campaignToDelete?.Name}\"? Все игроки и персонажи будут удалены безвозвратно.")"
                       ConfirmText="Удалить"
                       IconType="error"
                       IsLoading="_deleting" />
}

@code {
    private List<Campaign> _campaigns = [];
    private bool _loading = true;
    private bool _isKeeper;

    // Filters
    private string _searchTerm = string.Empty;
    private string _statusFilter = string.Empty;

    // Add modal state
    private bool _showAddModal;
    private CampaignCreateModel _addModel = new();
    private string _addError = string.Empty;

    // Edit modal state
    private bool _showEditModal;
    private Campaign? _editCampaign;
    private CampaignCreateModel _editModel = new();
    private string _editError = string.Empty;

    // Delete modal state
    private bool _showDeleteModal;
    private Campaign? _campaignToDelete;

    // Shared
    private bool _saving;
    private bool _deleting;

    private IEnumerable<Campaign> FilteredCampaigns => _campaigns
        .Where(c => string.IsNullOrWhiteSpace(_searchTerm) ||
                    c.Name.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase))
        .Where(c => string.IsNullOrEmpty(_statusFilter) ||
                    c.Status.ToString() == _statusFilter);

    protected override async Task OnInitializedAsync()
    {
        _isKeeper = await IdentityService.IsKeeper();
        if (_isKeeper)
        {
            await LoadCampaigns();
        }
    }

    private async Task LoadCampaigns()
    {
        try
        {
            _loading = true;
            _campaigns = await CampaignService.GetKeeperCampaignsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading keeper campaigns");
        }
        finally
        {
            _loading = false;
        }
    }

    // ── Add modal ───────────────────────────────────────────────

    private void OpenAddModal()
    {
        _addModel = new CampaignCreateModel();
        _addError = string.Empty;
        _showAddModal = true;
    }

    private void CloseAddModal()
    {
        _showAddModal = false;
    }

    private async Task CreateCampaign()
    {
        _saving = true;
        _addError = string.Empty;
        try
        {
            var result = await CampaignService.CreateCampaignAsync(_addModel.Name, _addModel.Status, _addModel.Era);
            if (!result.IsSuccess)
            {
                _addError = result.Error!;
                return;
            }
            _showAddModal = false;
            await LoadCampaigns();
        }
        finally
        {
            _saving = false;
        }
    }

    // ── Edit modal ───────────────────────────────────────────────

    private void OpenEditModal(Campaign campaign)
    {
        _editCampaign = campaign;
        _editModel = new CampaignCreateModel { Name = campaign.Name, Status = campaign.Status, Era = campaign.Era };
        _editError = string.Empty;
        _showEditModal = true;
    }

    private void CloseEditModal()
    {
        _showEditModal = false;
        _editCampaign = null;
    }

    private async Task UpdateCampaign()
    {
        if (_editCampaign is null) return;
        var campaignId = _editCampaign.Id;
        _saving = true;
        _editError = string.Empty;
        try
        {
            var result = await CampaignService.UpdateCampaignAsync(campaignId, _editModel.Name, _editModel.Status, _editModel.Era);
            if (!result.IsSuccess)
            {
                _editError = result.Error!;
                return;
            }
            _showEditModal = false;
            _editCampaign = null;
            await LoadCampaigns();
        }
        finally
        {
            _saving = false;
        }
    }

    // ── Delete modal ─────────────────────────────────────────────

    private void ConfirmDelete(Campaign campaign)
    {
        _campaignToDelete = campaign;
        _showDeleteModal = true;
    }

    private async Task DeleteCampaign()
    {
        if (_campaignToDelete is null) return;
        _deleting = true;
        try
        {
            var result = await CampaignService.DeleteCampaignAsync(_campaignToDelete.Id);
            if (result.IsSuccess)
            {
                await LoadCampaigns();
            }
            else
            {
                Logger.LogWarning("Delete campaign failed: {Error}", result.Error);
            }
        }
        finally
        {
            _deleting = false;
            _showDeleteModal = false;
            _campaignToDelete = null;
        }
    }

    // ── Helpers ──────────────────────────────────────────────────

    private static string GetStatusLabel(CampaignStatus status) => status switch
    {
        CampaignStatus.Planning => "Планирование",
        CampaignStatus.Active => "Активна",
        CampaignStatus.OnHold => "На паузе",
        CampaignStatus.Completed => "Завершена",
        _ => status.ToString()
    };

    private static string GetStatusVariant(CampaignStatus status) => status switch
    {
        CampaignStatus.Planning  => "secondary",
        CampaignStatus.Active    => "success",
        CampaignStatus.OnHold    => "warning",
        CampaignStatus.Completed => "accent",
        _                        => "primary"
    };
}

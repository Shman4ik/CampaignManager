@using CampaignManager.Web.Components.Features.Admin.Services
@using CampaignManager.Web.Utilities.Services
@inject IdentityService IdentityService
@inject AdminService AdminService
@rendermode InteractiveServer

@if (_visible)
{
    <div class="bg-gradient-to-r from-slate-50 to-stone-50 border border-slate-200 rounded-lg p-6 mb-6">
        <div class="flex items-start gap-4">
            <div class="flex-shrink-0">
                <i class="fa-solid fa-hat-wizard text-3xl text-slate-500"></i>
            </div>
            <div class="flex-1">
                <h3 class="text-lg font-semibold text-gray-800 mb-1">Хотите стать Хранителем?</h3>
                <p class="text-gray-600 text-sm mb-3">
                    Хранители могут создавать кампании, сценарии, редактировать вики-контент и управлять NPC.
                    Подайте заявку — и администратор рассмотрит её.
                </p>
                @if (_submitted)
                {
                    <div class="text-green-600 text-sm font-medium">
                        <i class="fa-solid fa-check mr-1"></i> Заявка отправлена! Ожидайте рассмотрения.
                    </div>
                }
                else
                {
                    <button class="cm-btn cm-btn-info text-sm" @onclick="ShowModal">
                        <i class="fa-solid fa-paper-plane mr-1"></i> Подать заявку
                    </button>
                }
            </div>
        </div>
    </div>
}

@if (_showModal)
{
    <Modal Title="Заявка на роль Хранителя" OnClose="CloseModal">
        <div class="space-y-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Почему вы хотите стать Хранителем?</label>
                <textarea @bind="_message" rows="4"
                          class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500"
                          placeholder="Расскажите о своём опыте вождения CoC или других TTRPG..."></textarea>
            </div>
            <div class="flex justify-end gap-2">
                <button class="cm-btn cm-btn-secondary" @onclick="CloseModal">Отмена</button>
                <button class="cm-btn cm-btn-info" @onclick="SubmitAsync" disabled="@string.IsNullOrWhiteSpace(_message)">
                    Отправить
                </button>
            </div>
        </div>
    </Modal>
}

@code {
    private bool _visible;
    private bool _showModal;
    private bool _submitted;
    private string? _message;

    protected override async Task OnInitializedAsync()
    {
        var isKeeper = await IdentityService.IsKeeper();
        if (isKeeper) return;

        var hasPending = await IdentityService.HasPendingKeeperApplicationAsync();
        _visible = !hasPending;
        _submitted = hasPending;
    }

    private void ShowModal()
    {
        _message = null;
        _showModal = true;
    }

    private void CloseModal()
    {
        _showModal = false;
    }

    private async Task SubmitAsync()
    {
        if (string.IsNullOrWhiteSpace(_message)) return;

        var result = await AdminService.SubmitApplicationAsync(_message);
        if (result is not null)
        {
            _submitted = true;
            _showModal = false;
        }
    }
}

@using CampaignManager.Web.Components.Features.Admin.Services
@using CampaignManager.Web.Utilities.Services
@inject IdentityService IdentityService
@inject AdminService AdminService
@inject UserPreferencesService UserPreferencesService
@rendermode InteractiveServer

@if (_visible)
{
    <div class="bg-gradient-to-r from-slate-50 to-stone-50 border border-slate-200 rounded-lg p-6 mb-6">
        <div class="flex items-start gap-4">
            <div class="flex-shrink-0">
                <i class="fa-solid fa-hat-wizard text-3xl text-slate-500"></i>
            </div>
            <div class="flex-1">
                <h3 class="text-lg font-semibold text-gray-800 mb-1">Хотите стать Хранителем?</h3>
                <p class="text-gray-600 text-sm mb-3">
                    Хранители могут создавать кампании, сценарии, редактировать вики-контент и управлять NPC.
                    Подайте заявку — и администратор рассмотрит её.
                </p>
                @if (_submitted)
                {
                    <div class="text-green-600 text-sm font-medium">
                        <i class="fa-solid fa-check mr-1"></i> Заявка отправлена! Ожидайте рассмотрения.
                    </div>
                }
                else
                {
                    <button class="cm-btn cm-btn-info text-sm" @onclick="SubmitAsync" disabled="@_submitting">
                        @if (_submitting)
                        {
                            <i class="fa-solid fa-spinner fa-spin mr-1"></i>
                        }
                        else
                        {
                            <i class="fa-solid fa-paper-plane mr-1"></i>
                        }
                        Подать заявку
                    </button>
                }
            </div>
            <button class="text-gray-400 hover:text-gray-600 transition-colors flex-shrink-0"
                    @onclick="DismissAsync"
                    title="Скрыть">
                <i class="fa-solid fa-xmark text-lg"></i>
            </button>
        </div>
    </div>
}
else if (_dismissed)
{
    <div class="mb-6">
        <button @onclick="RestoreAsync"
                class="inline-flex items-center gap-1.5 rounded-full bg-slate-100 hover:bg-slate-200 text-slate-500 hover:text-slate-700 text-xs px-3 py-1.5 transition-colors">
            <i class="fa-solid fa-hat-wizard"></i>
            Стать Хранителем?
        </button>
    </div>
}

@code {
    private const string DismissedKey = "becomeKeeperCard.dismissed";

    private bool _visible;
    private bool _dismissed;
    private bool _submitted;
    private bool _submitting;

    protected override async Task OnInitializedAsync()
    {
        var isKeeper = await IdentityService.IsKeeper();
        if (isKeeper) return;

        var dismissed = await UserPreferencesService.GetAsync(DismissedKey);
        if (dismissed == "true")
        {
            _dismissed = true;
            return;
        }

        var hasPending = await IdentityService.HasPendingKeeperApplicationAsync();
        _submitted = hasPending;
        _visible = true;
    }

    private async Task DismissAsync()
    {
        _visible = false;
        _dismissed = true;
        await UserPreferencesService.SetAsync(DismissedKey, "true");
    }

    private async Task RestoreAsync()
    {
        _dismissed = false;
        _visible = true;
        await UserPreferencesService.SetAsync(DismissedKey, "false");
    }

    private async Task SubmitAsync()
    {
        if (_submitting) return;
        _submitting = true;
        var result = await AdminService.SubmitApplicationAsync(string.Empty);
        _submitting = false;
        if (result is not null)
            _submitted = true;
    }
}

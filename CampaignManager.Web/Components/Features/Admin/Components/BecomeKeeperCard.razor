@using CampaignManager.Web.Components.Features.Admin.Services
@using CampaignManager.Web.Utilities.Services
@inject IdentityService IdentityService
@inject AdminService AdminService
@inject UserPreferencesService UserPreferencesService
@rendermode InteractiveServer

@if (_visible)
{
    <div class="cm-card cm-section" style="border-left:3px solid var(--color-accent-400);">
        <div class="cm-card-body" style="display:flex;align-items:flex-start;gap:0.875rem;">
            <div style="width:2.25rem;height:2.25rem;border-radius:var(--cm-radius-md);background:var(--color-primary-100);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <i class="fa-solid fa-hat-wizard" style="color:var(--color-primary-500);font-size:1rem;"></i>
            </div>
            <div style="flex:1;min-width:0;">
                <div class="font-semibold text-sm" style="color:var(--color-primary-800);margin-bottom:0.25rem;">Хотите стать Хранителем?</div>
                <p class="text-xs" style="color:var(--color-primary-500);margin-bottom:0.625rem;line-height:1.5;">
                    Хранители создают кампании, сценарии, редактируют вики и управляют NPC. Подайте заявку — администратор рассмотрит её.
                </p>
                @if (_submitted)
                {
                    <span class="text-xs font-medium" style="color:var(--color-success-600);">
                        <i class="fa-solid fa-circle-check mr-1"></i>Заявка отправлена — ожидайте рассмотрения.
                    </span>
                }
                else
                {
                    <button class="cm-btn cm-btn-secondary cm-btn-sm" @onclick="SubmitAsync" disabled="@_submitting">
                        @if (_submitting)
                        {
                            <i class="fa-solid fa-spinner fa-spin"></i>
                        }
                        else
                        {
                            <i class="fa-solid fa-paper-plane mr-1"></i>
                        }
                        Подать заявку
                    </button>
                }
            </div>
            <button class="cm-btn cm-btn-secondary cm-btn-sm" @onclick="DismissAsync"
                    style="flex-shrink:0;min-height:28px;padding:0 0.5rem;" title="Скрыть">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
    </div>
}
else if (_dismissed)
{
    <div class="cm-section" style="margin-bottom:0.75rem;">
        <button @onclick="RestoreAsync"
                class="cm-btn cm-btn-secondary cm-btn-sm"
                style="font-size:0.75rem;">
            <i class="fa-solid fa-hat-wizard mr-1"></i>Стать Хранителем?
        </button>
    </div>
}

@code {
    private const string DismissedKey = "becomeKeeperCard.dismissed";

    private bool _visible;
    private bool _dismissed;
    private bool _submitted;
    private bool _submitting;

    protected override async Task OnInitializedAsync()
    {
        var isKeeper = await IdentityService.IsKeeper();
        if (isKeeper) return;

        var dismissed = await UserPreferencesService.GetAsync(DismissedKey);
        if (dismissed == "true")
        {
            _dismissed = true;
            return;
        }

        _submitted = await IdentityService.HasPendingKeeperApplicationAsync();
        _visible = true;
    }

    private async Task DismissAsync()
    {
        _visible = false;
        _dismissed = true;
        await UserPreferencesService.SetAsync(DismissedKey, "true");
    }

    private async Task RestoreAsync()
    {
        _dismissed = false;
        _visible = true;
        await UserPreferencesService.SetAsync(DismissedKey, "false");
    }

    private async Task SubmitAsync()
    {
        if (_submitting) return;
        _submitting = true;
        var result = await AdminService.SubmitApplicationAsync(string.Empty);
        _submitting = false;
        if (result is not null) _submitted = true;
    }
}

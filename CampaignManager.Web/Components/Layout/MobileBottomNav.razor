@using CampaignManager.Web.Components.Features.Admin.Services
@using CampaignManager.Web.Components.Layout.Services
@using CampaignManager.Web.Utilities.Services
@rendermode InteractiveServer
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IdentityService IdentityService
@inject AdminService AdminService
@inject LastCharacterService LastCharacterService
@implements IDisposable

<!-- Bottom nav bar -->
<div class="mobile-bottom-nav">
    <div class="flex h-full">
        <a href="/" class="mobile-tab @(IsExactHome() ? "mobile-tab--active" : "")">
            <i class="fa-solid fa-house"></i>
            <span>Главная</span>
        </a>
        <a href="/combat" class="mobile-tab @(IsActive("/combat") ? "mobile-tab--active" : "")">
            <i class="fa-solid fa-crosshairs"></i>
            <span>Бой</span>
        </a>
        <a href="/chase" class="mobile-tab @(IsActive("/chase") ? "mobile-tab--active" : "")">
            <i class="fa-solid fa-person-running"></i>
            <span>Погоня</span>
        </a>
        @if (_lastCharacterId is not null)
        {
            <a href="/character/@_lastCharacterId" class="mobile-tab @(IsOnCharacterPage() ? "mobile-tab--active" : "")">
                <i class="fa-solid fa-user"></i>
                <span style="max-width:56px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@_lastCharacterName</span>
            </a>
        }
        else
        {
            <span class="mobile-tab mobile-tab--disabled">
                <i class="fa-solid fa-user"></i>
                <span>Персонаж</span>
            </span>
        }
        <button class="mobile-tab @(_drawerOpen ? "mobile-tab--active" : "")" @onclick="ToggleDrawer">
            <i class="fa-solid fa-bars"></i>
            <span>Ещё</span>
        </button>
    </div>
</div>

<!-- Drawer -->
@if (_drawerOpen)
{
    <div class="mobile-drawer-overlay" @onclick="CloseDrawer"></div>
    <div class="mobile-drawer">
        <div class="mobile-drawer-handle-area" @onclick="CloseDrawer">
            <div class="mobile-drawer-handle"></div>
        </div>
        <div class="mobile-drawer-content">
            <div class="mobile-drawer-section-title">Основное</div>
            <a href="/campaigns" @onclick="CloseDrawer" class="mobile-drawer-item">
                <i class="fa-solid fa-map"></i>
                <span>Кампании</span>
            </a>
            @if (_isKeeper)
            {
                <a href="/scenarios" @onclick="CloseDrawer" class="mobile-drawer-item">
                    <i class="fa-solid fa-scroll"></i>
                    <span>Сценарии</span>
                </a>
                <a href="/npcs" @onclick="CloseDrawer" class="mobile-drawer-item">
                    <i class="fa-solid fa-person"></i>
                    <span>NPC</span>
                </a>
            }

            <div class="mobile-drawer-section-title">Вики</div>
            <a href="/weapons" @onclick="CloseDrawer" class="mobile-drawer-item">
                <i class="fa-solid fa-gun"></i>
                <span>Оружие</span>
            </a>
            <a href="/bestiary" @onclick="CloseDrawer" class="mobile-drawer-item">
                <i class="fa-solid fa-skull"></i>
                <span>Существа</span>
            </a>
            <a href="/items" @onclick="CloseDrawer" class="mobile-drawer-item">
                <i class="fa-solid fa-box"></i>
                <span>Предметы</span>
            </a>
            <a href="/occupations" @onclick="CloseDrawer" class="mobile-drawer-item">
                <i class="fa-solid fa-briefcase"></i>
                <span>Профессии</span>
            </a>
            <a href="/skills" @onclick="CloseDrawer" class="mobile-drawer-item">
                <i class="fa-solid fa-book"></i>
                <span>Навыки</span>
            </a>
            <a href="/spells" @onclick="CloseDrawer" class="mobile-drawer-item">
                <i class="fa-solid fa-hat-wizard"></i>
                <span>Заклинания</span>
            </a>
            <a href="/books" @onclick="CloseDrawer" class="mobile-drawer-item">
                <i class="fa-solid fa-book-open"></i>
                <span>Книги</span>
            </a>

            @if (_isAdmin)
            {
                <div class="mobile-drawer-section-title">Система</div>
                <a href="/admin/users" @onclick="CloseDrawer" class="mobile-drawer-item">
                    <i class="fa-solid fa-users"></i>
                    <span>Пользователи</span>
                </a>
                <a href="/admin/applications" @onclick="CloseDrawer" class="mobile-drawer-item">
                    <i class="fa-solid fa-gear"></i>
                    <span>Заявки</span>
                    @if (_pendingCount > 0)
                    {
                        <span class="mobile-drawer-badge">@_pendingCount</span>
                    }
                </a>
            }
        </div>
    </div>
}

@code {
    private bool _drawerOpen;
    private string? _lastCharacterId;
    private string? _lastCharacterName;
    private bool _isKeeper;
    private bool _isAdmin;
    private int _pendingCount;

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
        LastCharacterService.OnChanged += OnLastCharacterChanged;

        // Pick up whatever was already set this session
        _lastCharacterId = LastCharacterService.CharacterId;
        _lastCharacterName = LastCharacterService.CharacterName;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // Restore from localStorage for page reloads (service is empty after reload)
        if (_lastCharacterId is null)
        {
            _lastCharacterId = await JS.InvokeAsync<string?>("localStorage.getItem", "last-character-id");
            _lastCharacterName = await JS.InvokeAsync<string?>("localStorage.getItem", "last-character-name");
        }

        _isKeeper = await IdentityService.IsKeeper();
        _isAdmin = await IdentityService.IsAdministrator();
        if (_isAdmin)
            _pendingCount = await AdminService.GetPendingApplicationsCountAsync();

        StateHasChanged();
    }

    private void OnLastCharacterChanged()
    {
        _lastCharacterId = LastCharacterService.CharacterId;
        _lastCharacterName = LastCharacterService.CharacterName;
        InvokeAsync(StateHasChanged);
    }

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
    private void CloseDrawer() => _drawerOpen = false;

    private bool IsExactHome() =>
        Nav.Uri == Nav.BaseUri || Nav.Uri == Nav.BaseUri.TrimEnd('/');

    private bool IsActive(string href) =>
        Nav.Uri.Contains(href, StringComparison.OrdinalIgnoreCase);

    private bool IsOnCharacterPage() =>
        Nav.Uri.Contains("/character/", StringComparison.OrdinalIgnoreCase);

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        _drawerOpen = false;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
        LastCharacterService.OnChanged -= OnLastCharacterChanged;
    }
}

@using Microsoft.AspNetCore.WebUtilities
@using CampaignManager.Web.Utilities.Services
@using CampaignManager.Web.Components.Features.Admin.Services
@rendermode InteractiveServer
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IdentityService IdentityService
@inject AdminService AdminService
@implements IDisposable

@if (_tabletExpanded)
{
    <div class="tablet-sidebar-backdrop" @onclick="CollapseTablet"></div>
}

<div class="sidebar @(_collapsed ? "collapsed" : "") @(_tabletExpanded ? "tablet-expanded" : "")">
    <!-- Logo -->
    <div class="sidebar-logo">
        <div class="sidebar-logo-icon sidebar-logo-icon--cthulhu">
            <img src="/logo.svg" width="28" height="28" aria-hidden="true" alt="Campaign Manager logo" />
        </div>
        <div class="sidebar-logo-text">Campaign Manager</div>
    </div>

    <!-- Nav -->
    <nav class="sidebar-nav">
        <div class="sidebar-section">Основное</div>
        <SidebarItem Href="/" Icon="fa-house" Label="Главная"/>
        <AuthorizeView>
            <SidebarItem Href="/combat" Icon="fa-crosshairs" Label="Бой"/>
            <SidebarItem Href="/chase" Icon="fa-person-running" Label="Погоня"/>
            <SidebarItem Href="/campaigns" Icon="fa-map" Label="Кампании"/>
        </AuthorizeView>
        <AuthorizeView Policy="RequireKeeper">
            <SidebarItem Href="/scenarios" Icon="fa-scroll" Label="Сценарии"/>
            <SidebarItem Href="/npcs" Icon="fa-person" Label="NPC"/>
        </AuthorizeView>

        <AuthorizeView>
            <div class="sidebar-section">Вики</div>
            <SidebarItem Href="/weapons" Icon="fa-gun" Label="Оружие"/>
            <SidebarItem Href="/bestiary" Icon="fa-skull" Label="Существа"/>
            <SidebarItem Href="/items" Icon="fa-box" Label="Предметы"/>
            <SidebarItem Href="/occupations" Icon="fa-briefcase" Label="Профессии"/>
            <SidebarItem Href="/skills" Icon="fa-book" Label="Навыки"/>
            <SidebarItem Href="/spells" Icon="fa-hat-wizard" Label="Заклинания"/>
            <SidebarItem Href="/books" Icon="fa-book-open" Label="Книги"/>
        </AuthorizeView>

        <AuthorizeView Policy="RequireAdministratorRole">
            <div class="sidebar-section">Система</div>
            <SidebarItem Href="/admin/users" Icon="fa-users" Label="Пользователи"/>
            <SidebarItem Href="/admin/applications" Icon="fa-gear" Label="Заявки"
                         Badge="@(_pendingCount > 0 ? _pendingCount.ToString() : null)"/>
        </AuthorizeView>
    </nav>

    <!-- Footer / Auth -->
    <div class="sidebar-footer">
        <AuthorizeView>
            <Authorized>
                <!-- User row -->
                <div class="sidebar-item" style="cursor:default;gap:8px;">
                    <span class="sidebar-icon">
                        <div style="width:22px;height:22px;border-radius:50%;background:var(--cm-gradient-primary);display:flex;align-items:center;justify-content:center;color:white;font-size:10px;font-weight:700;flex-shrink:0;">
                            @(context.User.Identity?.Name?.Length > 0 ? char.ToUpper(context.User.Identity.Name[0]) : '?')
                        </div>
                    </span>
                    <span class="sidebar-label" style="font-size:12.5px;overflow:hidden;text-overflow:ellipsis;flex:1;min-width:0;">
                        @context.User.Identity?.Name
                    </span>
                </div>
                <!-- Logout -->
                <button class="sidebar-item" style="width:100%;background:none;border:none;text-align:left;cursor:pointer;"
                        @onclick="Logout">
                    <span class="sidebar-icon"><i class="fa-solid fa-right-from-bracket" style="font-size:13px;"></i></span>
                    <span class="sidebar-label" style="font-size:12.5px;">Выйти</span>
                </button>
            </Authorized>
            <NotAuthorized>
                @if (_checkingAuth)
                {
                    <div class="sidebar-item" style="cursor:default;color:var(--color-primary-400);font-size:12px;">
                        <span class="sidebar-icon"><i class="fa-solid fa-spinner fa-spin" style="font-size:12px;"></i></span>
                        <span class="sidebar-label">Проверка...</span>
                    </div>
                }
                else
                {
                    @if (_silentLoginFailed)
                    {
                        <div style="padding:6px 8px;font-size:11px;color:var(--color-warning-600);line-height:1.4;" class="sidebar-label">
                            Автовход не удался
                        </div>
                    }
                    @if (_accessDenied)
                    {
                        <div style="padding:6px 8px;font-size:11px;color:var(--color-error-600);line-height:1.4;" class="sidebar-label">
                            Доступ запрещён
                        </div>
                    }
                    <button class="sidebar-item" style="width:100%;background:none;border:none;text-align:left;cursor:pointer;"
                            @onclick="ManualLogin">
                        <span class="sidebar-icon">
                            <svg style="width:14px;height:14px;" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48">
                                <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                                <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                                <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                                <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
                            </svg>
                        </span>
                        <span class="sidebar-label" style="font-size:12.5px;">Войти с Google</span>
                    </button>
                }
            </NotAuthorized>
        </AuthorizeView>
    </div>
</div>

<!-- Collapse toggle button -->
<button class="sidebar-collapse-btn"
        style="left: @ToggleBtnLeft"
        @onclick="ToggleSidebar"
        title="@(IsVisuallyExpanded ? "Свернуть" : "Развернуть")">
    <i class="fa-solid @(IsVisuallyExpanded ? "fa-chevron-left" : "fa-chevron-right")" style="font-size:10px"></i>
</button>

@code {
    private bool _collapsed = true;
    private bool _tabletExpanded;
    private bool _checkingAuth = true;
    private bool _silentLoginFailed;
    private bool _accessDenied;
    private bool _loginFailed;
    private int _pendingCount;

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;

        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var q = QueryHelpers.ParseQuery(uri.Query);
        if (q.TryGetValue("authStatus", out var s))
        {
            _silentLoginFailed = s == "silentFailed";
            _accessDenied      = s == "accessDenied";
            _loginFailed       = s == "failed";
        }
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        _tabletExpanded = false;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }

    private bool IsVisuallyExpanded => _tabletExpanded || !_collapsed;

    private string ToggleBtnLeft =>
        _tabletExpanded ? "var(--sidebar-width)"
            : _collapsed ? "var(--sidebar-width-collapsed)"
                : "var(--sidebar-width)";

    private void CollapseTablet()
    {
        _tabletExpanded = false;
    }

    private async Task ToggleSidebar()
    {
        var width = await JS.InvokeAsync<double>("eval", "window.innerWidth");
        if (width is >= 769 and <= 1100)
        {
            _tabletExpanded = !_tabletExpanded;
        }
        else
        {
            _collapsed = !_collapsed;
            await JS.InvokeVoidAsync("localStorage.setItem", "sidebar-collapsed", _collapsed.ToString().ToLower());
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // Restore sidebar collapsed state — default to collapsed
        var stored = await JS.InvokeAsync<string?>("localStorage.getItem", "sidebar-collapsed");
        _collapsed = stored != "false";
        StateHasChanged();

        // Clean up authStatus from URL
        if (_silentLoginFailed || _accessDenied || _loginFailed)
        {
            if (_silentLoginFailed)
            {
                try
                {
                    var m = await JS.InvokeAsync<IJSObjectReference>("import", "/js/topbar-auth.js");
                    await m.InvokeVoidAsync("noteSilentFailure");
                }
                catch { }
            }
            Nav.NavigateTo(Nav.Uri.Split('?')[0], replace: true);
        }

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (!user.Identity?.IsAuthenticated ?? true)
        {
            // Attempt silent login once
            try
            {
                var m = await JS.InvokeAsync<IJSObjectReference>("import", "/js/topbar-auth.js");
                var skip = await m.InvokeAsync<bool>("shouldSkipSilentLogin");
                if (!skip)
                {
                    await m.InvokeVoidAsync("markSilentAttempt");
                    var returnUrl = "/" + Nav.ToBaseRelativePath(Nav.Uri);
                    var hint = await m.InvokeAsync<string?>("getLoginHint");
                    var loginUrl = $"/api/account/login?mode=silent&returnUrl={Uri.EscapeDataString(returnUrl)}";
                    if (!string.IsNullOrEmpty(hint))
                        loginUrl += $"&loginHint={Uri.EscapeDataString(hint)}";
                    Nav.NavigateTo(loginUrl, true);
                    return;
                }
            }
            catch { }

            _checkingAuth = false;
            StateHasChanged();
            return;
        }

        // Authenticated — load extras
        _checkingAuth = false;
        var isAdmin = await IdentityService.IsAdministrator();
        if (isAdmin)
            _pendingCount = await AdminService.GetPendingApplicationsCountAsync();

        // Save login hint
        try
        {
            var email = user.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value;
            if (!string.IsNullOrEmpty(email))
            {
                var m = await JS.InvokeAsync<IJSObjectReference>("import", "/js/topbar-auth.js");
                await m.InvokeVoidAsync("saveLoginHint", email);
            }
        }
        catch { }

        StateHasChanged();
    }

    private async Task Logout()
    {
        try
        {
            var m = await JS.InvokeAsync<IJSObjectReference>("import", "/js/topbar-auth.js");
            await m.InvokeVoidAsync("setSkipSilentLogin");
            await m.InvokeVoidAsync("clearLoginHint");
        }
        catch { }
        Nav.NavigateTo("api/account/logout", true);
    }

    private async Task ManualLogin()
    {
        try
        {
            var m = await JS.InvokeAsync<IJSObjectReference>("import", "/js/topbar-auth.js");
            await m.InvokeVoidAsync("clearSilentFlags");
        }
        catch { }
        var returnUrl = "/" + Nav.ToBaseRelativePath(Nav.Uri);
        Nav.NavigateTo($"/api/account/login?mode=interactive&returnUrl={Uri.EscapeDataString(returnUrl)}", true);
    }
}

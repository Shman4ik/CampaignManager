{
  "AllowedHosts": "*",
  "Authorization": {
    "AllowedEmails": [],
    "AllowedDomains": [],
    "AdminEmails": []
  },
  "Community": {
    "GitHubRepoUrl": "https://github.com/Shman4ik/CampaignManager",
    "GitHubIssuesUrl": "https://github.com/Shman4ik/CampaignManager/issues/new",
    "DonateUrl": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Components.Server.Circuits": "Critical"
    },
    "Console": {
      "FormatterName": "simple",
      "FormatterOptions": {
        "SingleLine": true,
        "TimestampFormat": "HH:mm:ss ",
        "ColorBehavior": "Enabled",
        "IncludeScopes": false
      }
    }
  },
  "Minio": {
    "Endpoint": "s3.dmnet.dev",
    "Secure": true,
    "BucketName": "campain-manager"
  }
}